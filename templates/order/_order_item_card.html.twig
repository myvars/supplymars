{# Single order item card with product image, price, quantity, and supplier toggle.
   Used on: order show page (inside _order_items_card). Variable: orderItem (CustomerOrderItem) #}
<li class="first:mt-3">
    <twig:Card
        editLink="{{ orderItem.allowEdit ? path('app_order_item_edit', {'id': orderItem.publicId.value }) : null }}"
        padding="p-0"
    >
        <div data-controller="toggle" data-action="click->toggle#toggle" class="overflow-hidden rounded-xl">
            <div class="flex items-center hover:bg-gray-50 dark:bg-gray-800 dark:hover:bg-gray-700">
                <a href="{{ path('app_catalog_product_show', {'id': orderItem.product.publicId.value }) }}"
                   data-turbo-frame="body"
                   data-action="click->toggle#toggle"
                >
                    <twig:ProductImage
                        imageName="{{ orderItem.product.hasProductImage ? orderItem.product.getFirstImage.imageName : null }}"
                        filter="small_thumbnail"
                        alt="{{ orderItem.product.name }}"
                    ></twig:ProductImage>
                </a>
                <div class="w-full p-3">
                    <p class="mb-1.5 text-sm font-medium text-gray-700 line-clamp-1 dark:text-gray-200">{{ orderItem.product.name }}</p>
                    <div class="flex items-center justify-between">
                        <div class="flex items-center gap-3 text-sm">
                            <span class="font-medium tabular-nums text-gray-900 dark:text-white">{{ orderItem.priceIncVat|format_currency('GBP') }}</span>
                            <span class="text-gray-500 dark:text-gray-400">
                                {% if orderItem.outstandingQty is same as orderItem.quantity %}
                                    Qty: {{ orderItem.quantity }}
                                {% else %}
                                    Qty: {{ orderItem.outstandingQty }} of {{ orderItem.quantity }}
                                {% endif %}
                            </span>
                            <span class="hidden text-gray-400 md:inline dark:text-gray-500">#{{ '%05d'|format(orderItem.product.id) }}</span>
                        </div>
                        <a href="{{ path('app_order_item_status_log', {'id':orderItem.publicId.value }) }}"
                           data-turbo-frame="modal"
                           data-action="click->toggle#toggle"
                        >
                            <twig:StatusBadge status="{{ orderItem.status.value }}" :interactive="true"/>
                        </a>
                    </div>
                </div>
            </div>
            {% if orderItem.allowEdit %}
                {{ include('order/_order_item_supplier_card.html.twig', {orderItem: orderItem}) }}
            {% endif %}
        </div>
    </twig:Card>
</li>
