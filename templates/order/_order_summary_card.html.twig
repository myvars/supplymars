<twig:Card>
    <div class="flex justify-between text-sm text-gray-500 dark:text-gray-400">
        <div>
            <p class="mb-1 text-gray-300 dark:text-gray-200">Delivery Address</p>
            <p>{{ order.customer.fullName }}</p>
            <p>{{ order.shippingAddress.street }}</p>
            {% if order.shippingAddress.street2 is not null %}
                <p>{{ order.shippingAddress.street2 }}</p>
            {% endif %}
            <p>{{ order.shippingAddress.city }}, {{ order.shippingAddress.postCode }}</p>
            <p>{{ order.shippingAddress.country }}</p>
        </div>
        <div>
            <p class="mb-1 text-gray-300 dark:text-gray-200">Order Summary</p>
            <div class="flex justify-between">
                <p class="me-10">Item(s)<span class="inline-flex max-md:hidden ms-1">subtotal</span>:</p>
                {% if order.isCancelled %}
                    <p>{{ 0.00|format_currency('GBP') }}</p>
                {% else %}
                    <p>{{ (order.totalPrice - order.shippingPrice)|format_currency('GBP') }}</p>
                {% endif %}
            </div>
            <div class="flex justify-between">
                <p class="me-10">Shipping:</p>
                {% if order.isCancelled %}
                    <p>{{ 0.00|format_currency('GBP') }}</p>
                {% else %}
                    <p>{{ order.shippingPrice|format_currency('GBP') }}</p>
                {% endif %}
            </div>
            <div class="flex justify-between">
                <p class="me-10">VAT:</p>
                <p>{{ (order.totalPriceIncVat - order.totalPrice)|format_currency('GBP') }}</p>
            </div>
            <div class="mt-1 flex justify-between text-gray-300 dark:text-gray-200">
                <p class="me-10">Total:</p>
                <p>{{ order.totalPriceIncVat|format_currency('GBP') }}</p>
            </div>
        </div>
    </div>
</twig:Card>
