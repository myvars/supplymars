<ul
    data-toggle-target="toggleable"
    class="hidden w-full divide-y divide-gray-100 border-t border-gray-100 bg-gray-50/50 dark:divide-gray-800 dark:border-gray-700 dark:bg-gray-900/80"
>
    {% if orderItem.outstandingQty > 0 %}
        {% for supplierProduct in orderItem.product.activeSupplierProducts %}
            <a href="{{ path('app_purchase_order_item_add',{
                'id': orderItem.publicId.value,
                'supplierProductId': supplierProduct.publicId.value
            }) }}"
               data-turbo-prefetch="false"
               data-turbo-frame="body"
            >
                <li class="flex items-center justify-between px-3 py-2.5 text-sm transition-colors hover:bg-gray-100 dark:hover:bg-gray-700">
                    <div>
                        <p class="font-medium text-gray-700 line-clamp-1 dark:text-gray-300">{{ supplierProduct.supplier.name }}</p>
                        <p class="mt-0.5 text-xs text-gray-400 dark:text-gray-500">{{ supplierProduct.productCode }}</p>
                    </div>
                    <div class="text-right">
                        <p class="font-medium tabular-nums text-gray-900 dark:text-white">{{ supplierProduct.cost|format_currency('GBP') }}</p>
                        <p class="mt-0.5 text-xs">
                            {% if supplierProduct.hasStock %}
                                <span class="text-green-600 dark:text-green-400">{{ supplierProduct.stock }} in stock</span>
                            {% else %}
                                <span class="text-amber-600 dark:text-amber-400">{{ supplierProduct.leadTimeDays }}d lead time</span>
                            {% endif %}
                        </p>
                    </div>
                </li>
            </a>
        {% else %}
            <li class="px-3 py-3 text-center text-sm text-gray-400 dark:text-gray-500">No suppliers found</li>
        {% endfor %}
    {% endif %}
</ul>
