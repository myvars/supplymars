{% extends 'base.html.twig' %}

{% block title %}{{ section }} index{% endblock %}

{% block body %}
    <twig:DataList
        section="{{ section }}"
        results="{{ results }}"
    >
        <twig:block name="list_sort">
            <twig:SortLink sortValue="id">Order</twig:SortLink>
            <twig:SortLink sortValue="createdAt">Created</twig:SortLink>
            <twig:SortLink sortValue="customer.fullName">Customer</twig:SortLink>
            <twig:SortLink sortValue="totalPriceIncVat">Total</twig:SortLink>
            <twig:SortLink sortValue="status">Status</twig:SortLink>
        </twig:block>

        <twig:block name="list_item">
            <div class="flex justify-between items-center">
                <p class="mb-1 items-center text-xl text-gray-900 dark:text-white">Order #{{ '%06d'|format(result.id) }}</p>
                <p class="text-lg font-extralight"> £{{ result.totalPriceIncVat|number_format(2) }}</p>
            </div>
            <p class="mb-1 text-sm">
                {{ result.createdAt|date('jS M Y H:i') }}
                {% if result.customerOrderRef is not null %}
                    - {{ result.customerOrderRef }}
                {% endif %}
            </p>
            <div class="flex justify-between items-center text-gray-600 dark:text-gray-500">
                <p>{{ result.customer.fullName }}</p>
                <p>{{ result.status.value|title }}</p>
            </div>
            <twig:block name="list_item_edit"></twig:block>
        </twig:block>

        <twig:block name="list_add">
            <twig:Button
                tag="a"
                href="{{ path('app_'~section|lower|u.snake~'_new') }}"
                class="flex items-center space-x-1 font-bold"
                data-turbo-frame="modal"
            >
                <twig:ux:icon name="flowbite:circle-plus-outline" class="w-5"/>
                <span>Add {{ section }}</span>
            </twig:Button>
        </twig:block>

        <twig:block name="filter"></twig:block>
    </twig:DataList>

{% endblock %}