{% extends 'base.html.twig' %}

{% block title %}Order Search{% endblock %}

{% block body %}
    <twig:Search
        flowModel="{{ flowModel }}"
        flowRoute="{{ flowRoute }}"
        results="{{ results }}"
    >
        <twig:block name="sort">
            <twig:Card>
                <div class="flex justify-between overflow-auto">
                    <twig:SortLink sortValue="id">Order</twig:SortLink>
                    <twig:SortLink sortValue="createdAt">Created</twig:SortLink>
                    <twig:SortLink sortValue="customer.fullName">Customer</twig:SortLink>
                    <twig:SortLink sortValue="totalPriceIncVat">Total</twig:SortLink>
                    <twig:SortLink sortValue="status">Status</twig:SortLink>
                </div>
            </twig:Card>
        </twig:block>

        <twig:block name="list_item">
            <twig:Card showLink="{{ path('app_order_show', {'id': result.publicId.value }) }}">
                <div class="flex items-center justify-between">
                    <p class="text-lg text-gray-900 dark:text-white">
                        Order #{{ '%06d'|format(result.id) }}
                        {% if result.customerOrderRef is not null %}
                            <span class="text-sm text-gray-600 dark:text-gray-500">- {{ result.customerOrderRef }}</span>
                        {% endif %}
                    </p>
                    <p class="text-base font-extralight"> {{ result.totalPriceIncVat|format_currency('GBP') }}</p>
                </div>
                <p class="mb-1 text-base">{{ result.customer.fullName }}</p>
                <p class="flex items-center justify-between text-sm">
                    <span class="text-gray-600 me-1 dark:text-gray-500">{{ result.createdAt|date('jS M Y H:i') }}</span>
                    {{ result.status.value|title }}
                </p>
            </twig:Card>
        </twig:block>

        <twig:block name="add">
            <twig:Button
                tag="a"
                href="{{ path('app_order_new') }}"
                class="flex items-center font-bold space-x-1"
                data-turbo-frame="modal"
            >
                <twig:ux:icon name="flowbite:circle-plus-outline" class="w-5"/>
                <span>Create Order</span>
            </twig:Button>
        </twig:block>

    </twig:Search>

{% endblock %}
