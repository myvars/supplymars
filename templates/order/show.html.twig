{% extends 'base.html.twig' %}

{% block title %}Order Details{% endblock %}

{% block body %}

    <div class="m-3 space-y-4">
        {{ include('order/_order_card.html.twig', {order: result}) }}
        {{ include('order/_order_summary_card.html.twig', {order: result}) }}
        {{ include('order/_order_items_card.html.twig', {order: result}) }}
        {% if result.purchaseOrders|length > 0 %}
            <p class="px-1 text-xs font-medium uppercase tracking-wide text-gray-400 dark:text-gray-500">Purchase Orders</p>
            {% for purchaseOrder in result.purchaseOrders %}
                {{ include('purchasing/purchase_order/_order_po_card.html.twig', {purchaseOrder: purchaseOrder}) }}
            {% endfor %}
        {% endif %}
        <div class="flex">
            <a href="{{ path('app_order_index') }}"
               class="inline-flex items-center gap-1 text-sm font-medium text-primary-600 hover:text-primary-700 dark:text-primary-400 dark:hover:text-primary-300"
               data-turbo-frame="body">
                <twig:ux:icon name="bi:arrow-left" class="h-3.5 w-3.5"/>
                View all orders
            </a>
        </div>
    </div>

{% endblock %}
