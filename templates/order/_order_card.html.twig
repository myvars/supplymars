{# Order header card with customer, status, dates, and cancel action.
   Used on: order show page. Variable: order (CustomerOrder), result (same entity) #}
<twig:Card editLink="{{ order.allowEdit ? path('app_order_cancel_confirm', {id: result.publicId.value}) : null }}"
           editIcon="bi:x-lg"
           statusHighlight="{{ order.status.value }}">
    <h5 class="flex items-center text-xl font-semibold text-gray-900 dark:text-white">
        Order #{{ '%06d'|format(result.id) }}
        <a href="{{ path('app_order_lock_toggle_status', {id: result.publicId.value}) }}"
           data-turbo-frame="body"
           data-turbo-prefetch="false"
           data-order-lock="{{ result.orderLock ? 'locked' : 'unlocked' }}"
           class="flex items-center text-base ms-3 {{ result.orderLock ? 'text-yellow-600 hover:text-yellow-500 dark:text-yellow-500 dark:hover:text-yellow-300' : 'text-blue-600 hover:text-blue-500 dark:text-blue-400 dark:hover:text-blue-300' }}"
        >
            {% if result.orderLock is not null %}
                <twig:ux:icon name="flowbite:lock-solid" class="w-4 me-1"/>
                <span class="text-sm me-1 max-md:hidden">Locked by</span>
                <span class="text-sm">{{ result.orderLock.fullName }}</span>
            {% else %}
                <twig:ux:icon name="flowbite:lock-open-solid" class="w-4 me-1.5"/>
            {% endif %}
        </a>
    </h5>
    <div class="mt-1.5 flex items-center justify-between">
        <p class="text-sm text-gray-500 dark:text-gray-400">
            {{ order.createdAt|date('jS M Y H:i') }}
            {% if order.customerOrderRef is not null %}
                <span class="mx-1 text-gray-300 dark:text-gray-600">&middot;</span>
                <span>{{ order.customerOrderRef }}</span>
            {% endif %}
        </p>
        <div class="flex items-center gap-2">
            {% if order.allowEdit %}
                <a href="{{ path('app_order_allocate', {id: result.publicId.value}) }}"
                   data-turbo-frame="body"
                   data-turbo-prefetch="false"
                   class="flex items-center gap-1 text-sm text-blue-600 hover:text-blue-500 dark:text-blue-400 dark:hover:text-blue-300"
                >
                    <twig:ux:icon name="bi:lightning-fill" class="h-4 w-4"/>
                    <span>Allocate</span>
                </a>
            {% endif %}
            <a href="{{ path('app_order_status_log', {'id': result.publicId.value }) }}"
               data-turbo-frame="modal"
            >
                <twig:StatusBadge status="{{ order.status.value }}" :interactive="true"/>
            </a>
        </div>
    </div>
</twig:Card>
