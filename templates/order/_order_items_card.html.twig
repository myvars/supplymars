<twig:Card>
    <div class="flex w-full items-center justify-between">
        <p class="text-gray-500 dark:text-gray-300">
            {{ order.lineCount }} {% if order.lineCount == 1 %}line{% else %}lines{% endif %}
            <span class="ms-1 text-grey-600 dark:text-gray-400">
                {{ order.itemCount }} {% if order.itemCount == 1 %}item{% else %}items{% endif %}
            </span>
        </p>
        {% if order.allowEdit %}
            <twig:Button
                tag="a"
                href="{{ path('app_order_item_new', {id: order.id}) }}"
                class="flex items-center font-bold space-x-1"
                data-turbo-frame="modal"
            >
                <twig:ux:icon name="flowbite:circle-plus-outline" class="w-4"/>
                <span>Add Item</span>
            </twig:Button>
        {% endif %}
    </div>
    <ul class="w-full space-y-3">
        {% for orderItem in order.customerOrderItems %}
            {% if orderItem.outstandingQty > 0 %}
                {{ include('order_item/_order_item_card.html.twig', {orderItem: orderItem}) }}
            {% endif %}
        {% endfor %}
    </ul>
</twig:Card>