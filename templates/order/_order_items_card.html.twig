{# Order items list — iterates order items as sub-cards.
   Used on: order show page. Variable: order (CustomerOrder) #}
<twig:Card title="Order Items">
    <div class="flex w-full items-center justify-between">
        <p class="text-gray-500 dark:text-gray-300">
            {{ order.lineCount }} {% if order.lineCount == 1 %}line{% else %}lines{% endif %}
            <span class="ms-1 text-gray-400 dark:text-gray-500">
                ({{ order.itemCount }} {% if order.itemCount == 1 %}item{% else %}items{% endif %})
            </span>
        </p>
        {% if order.allowEdit %}
            <twig:Button
                tag="a"
                variant="alternative"
                href="{{ path('app_order_item_new', {id: order.publicId.value}) }}"
                data-turbo-frame="modal"
            >
                <twig:ux:icon name="bi:plus-lg" class="h-4 w-4"/>
                <span>Add Item</span>
            </twig:Button>
        {% endif %}
    </div>
    <ul class="w-full space-y-3">
        {% for orderItem in order.customerOrderItems %}
            {% if orderItem.outstandingQty > 0 %}
                {{ include('order/_order_item_card.html.twig', {orderItem: orderItem}) }}
            {% endif %}
        {% endfor %}
    </ul>
</twig:Card>
