{% extends 'modalBase.html.twig' %}

{% block title %}Cancel {{ section|title }}{% endblock %}

{% block body %}

    <twig:Dialog title="Cancel {{ section }}">
        <p class="mb-4 text-sm font-light text-gray-500 dark:text-gray-400">
            Are you sure you want to cancel this {{ section }}?
        </p>
        <form method="post" action="{{ path('app_order_cancel', {'id': result.id}) }}">
            <input type="hidden" name="_token" value="{{ csrf_token('delete'~result.id) }}">
            <twig:Button type="submit" variant="warning" class="w-full">Cancel</twig:Button>
        </form>
    </twig:Dialog>

{% endblock %}