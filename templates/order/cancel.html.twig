{% extends 'shared/turbo/modal_base.html.twig' %}

{% block title %}Cancel Order{% endblock %}

{% block body %}

    <twig:ConfirmDialog
        title="Cancel Order"
        formAction="{{ path('app_order_cancel', {'id': result.publicId.value}) }}"
        csrfId="delete{{ result.publicId.value }}"
        confirmLabel="Cancel Order"
        confirmVariant="warning"
        cancelLabel="Go Back"
    >
        <twig:block name="message">
            <p class="mb-4 text-sm font-light text-gray-500 dark:text-gray-400">
                Are you sure you want to cancel this Order?
            </p>
        </twig:block>
    </twig:ConfirmDialog>

{% endblock %}
