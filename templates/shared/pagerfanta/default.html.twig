{%- extends '@Pagerfanta/default.html.twig' -%}

{%- block pager_widget -%}
    <nav role="navigation" class="flex items-center">
        <span class="isolate inline-flex gap-1">{{- block('pager') -}}</span>
    </nav>
{%- endblock pager_widget -%}

{%- block page_link -%}
    <a
        href="{{- path -}}"
        class="inline-flex h-8 min-w-8 items-center justify-center rounded-md px-2.5 text-sm font-medium
        text-gray-600 hover:bg-gray-100 hover:text-gray-900
        dark:text-gray-400 dark:hover:bg-gray-800 dark:hover:text-white
        transition-all duration-150 active:scale-90"
    >{{- page -}}</a>
{%- endblock page_link -%}

{%- block current_page_link -%}
    <span aria-current="page">
        <span class="inline-flex h-8 min-w-8 items-center justify-center rounded-md bg-gray-200 px-2.5 text-sm font-medium
            text-gray-900 cursor-default dark:bg-gray-700 dark:text-white"
        >{{- page -}}</span>
    </span>
{%- endblock current_page_link -%}

{%- block previous_page_link -%}
    <a
        href="{{- path -}}"
        rel="prev"
        class="inline-flex h-8 items-center justify-center rounded-md px-2.5 text-sm font-medium
        text-gray-600 hover:bg-gray-100 hover:text-gray-900
        dark:text-gray-400 dark:hover:bg-gray-800 dark:hover:text-white
        transition-all duration-150 active:scale-90"
    >
        <span class="inline-flex max-md:hidden">Previous</span>
        <span class="inline-flex md:hidden">&lt;</span>
    </a>
{%- endblock previous_page_link -%}

{%- block previous_page_link_disabled -%}
    <span aria-disabled="true">
        <span class="inline-flex h-8 items-center justify-center rounded-md px-2.5 text-sm font-medium
            text-gray-300 dark:text-gray-600
            cursor-default"
        >
            <span class="inline-flex max-md:hidden">Previous</span>
            <span class="inline-flex md:hidden">&lt;</span>
        </span>
    </span>
{%- endblock previous_page_link_disabled -%}

{%- block next_page_link -%}
    <a
        href="{{- path -}}"
        rel="next"
        class="inline-flex h-8 items-center justify-center rounded-md px-2.5 text-sm font-medium
        text-gray-600 hover:bg-gray-100 hover:text-gray-900
        dark:text-gray-400 dark:hover:bg-gray-800 dark:hover:text-white
        transition-all duration-150 active:scale-90"
    >
        <span class="inline-flex max-md:hidden">Next</span>
        <span class="inline-flex md:hidden">&gt;</span>
    </a>
{%- endblock next_page_link -%}

{%- block next_page_link_disabled -%}
    <span aria-disabled="true">
        <span class="inline-flex h-8 items-center justify-center rounded-md px-2.5 text-sm font-medium
            text-gray-300 dark:text-gray-600
            cursor-default"
        >
            <span class="inline-flex max-md:hidden">Next</span>
            <span class="inline-flex md:hidden">&gt;</span>
        </span>
    </span>
{%- endblock next_page_link_disabled -%}

{%- block ellipsis -%}
    <span aria-disabled="true">
        <span class="inline-flex h-8 min-w-8 items-center justify-center rounded-md px-1 text-sm
            text-gray-400 dark:text-gray-500
            cursor-default"
        >&hellip;</span>
    </span>
{%- endblock ellipsis -%}
