{# Turbo stream response that triggers navigate/refresh. #}
{% block stream_success %}
    <turbo-stream action="update" target="modal"><template></template></turbo-stream>

    {% if navigateUrl is defined and navigateUrl is not null %}
        {# Navigate to a different page (e.g., after deleting from show page) #}
        <turbo-stream action="update" target="turbo-navigate">
            <template>
                <script data-turbo-temporary>Turbo.visit("{{ navigateUrl|e('js') }}");</script>
            </template>
        </turbo-stream>
    {% else %}
        {# Refresh current page in place #}
        <turbo-stream action="refresh" id="page-refresh"></turbo-stream>
    {% endif %}
{% endblock %}
