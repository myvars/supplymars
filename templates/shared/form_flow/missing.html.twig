{# Fallback when a specific template is not found. #}
{% extends 'shared/turbo/modal_base.html.twig' %}

{% block title %}Missing Template{% endblock %}

{% block body %}

    <twig:Dialog title="Unexpected Error">
        <div class="mx-auto max-w-(--breakpoint-sm) text-center">
            <h1 class="mb-4 text-2xl font-bold tracking-tight text-gray-900 dark:text-white md:text-4xl">Template is
                missing</h1>
            <p class="mb-4 text-lg font-light text-gray-500 dark:text-gray-400">Sorry, we can't find that page!</p>
            <twig:Button
                tag="a"
                href="{{ flowBackLink|default(path('app_homepage')) }}"
                class="flex items-center font-bold space-x-1"
            >
                Continue
            </twig:Button>
        </div>
    </twig:Dialog>

{% endblock %}
