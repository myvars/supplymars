{#
    Inline Edit Form Template (Turbo-native pattern)

    Replaces the entire turbo-frame content with a form.
    Cancel link reloads the display. Submit returns a turbo-stream.

    Variables:
    - form: The Symfony form view
    - context: InlineEditContext with frameId, entity, cancelUrl, etc.
#}
<turbo-frame id="{{ context.frameId }}" class="animate-scale-in relative inline-flex items-center gap-1 rounded-md bg-gray-50 p-0.5 ring-1 ring-gray-200/60 shadow-sm dark:bg-white/[0.04] dark:ring-white/[0.06] dark:shadow-none">
    {{ form_start(form, {
        'attr': {
            'class': 'contents',
        }
    }) }}
        {# Hidden sizer span for auto-grow - must match input font styling #}
        <span data-inline-edit-target="sizer"
              class="absolute invisible whitespace-pre [font-size:inherit] [font-weight:inherit]"
              aria-hidden="true"></span>

        {# Input styled to match the text it replaces #}
        {% for field in form %}
            {% if field.vars.name != '_token' %}
                {{ form_widget(field, {
                    'attr': {
                        'class': 'min-w-0 px-1.5 py-0.5 rounded-md [font-size:inherit] [font-weight:inherit] [color:inherit] bg-transparent border-none outline-none ring-0 focus:ring-0 focus:outline-none transition-all ' ~ (field.vars.attr.class ?? ''),
                    }
                }) }}
                {% if field.vars.errors|length > 0 %}
                    <span class="text-xs text-red-600 dark:text-red-400">
                        {{ form_errors(field) }}
                    </span>
                {% endif %}
            {% endif %}
        {% endfor %}

        {# Compact action buttons #}
        <button type="submit"
                class="p-1 rounded-md text-primary-500 hover:text-primary-700 hover:bg-primary-50 dark:text-primary-400 dark:hover:text-primary-300 dark:hover:bg-primary-500/15 transition-all hover:scale-110 active:scale-95 shrink-0"
                title="Save (Enter)"
                aria-label="Save">
            <twig:ux:icon name="bi:check-lg" class="h-4 w-4"/>
        </button>
        <a href="{{ cancelUrl }}"
           data-inline-edit-target="cancel"
           class="p-1 rounded-md text-gray-400 hover:text-gray-600 hover:bg-gray-100 dark:text-gray-500 dark:hover:text-gray-300 dark:hover:bg-white/[0.08] transition-all hover:scale-110 active:scale-95 shrink-0"
           title="Cancel (Escape)"
           aria-label="Cancel">
            <twig:ux:icon name="bi:x-lg" class="h-4 w-4"/>
        </a>

        {{ form_rest(form) }}
    {{ form_end(form) }}

    {# Form-level errors #}
    {% if form.vars.errors|length > 0 %}
        <span class="text-xs text-red-600 dark:text-red-400">
            {{ form_errors(form) }}
        </span>
    {% endif %}
</turbo-frame>
