{# FormFlow filter template. Renders as modal via modal_base.
   Variables: flowModel (string), form (FormView) #}
{% extends 'shared/turbo/modal_base.html.twig' %}

{% block title %}{{ flowModel }} Filter{% endblock %}

{% block body %}

    <twig:Dialog title="{{ flowModel }} Filter">
        <twig:FlowForm :form="form" buttonLabel="Apply Filter"/>
    </twig:Dialog>

{% endblock %}

