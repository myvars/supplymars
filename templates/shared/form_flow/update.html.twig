{% extends 'shared/turbo/modal_base.html.twig' %}

{% block title %}Edit {{ flowModel }}{% endblock %}

{% block body %}

    <twig:Dialog title="Edit {{ flowModel }}">
        {{ include('shared/form_flow/_form.html.twig', {'button_label': 'Update '~flowModel}) }}
        {% if flowAllowDelete %}
            <hr class="my-6 h-px border-0 bg-gray-200 dark:bg-gray-700">
            <twig:Button
                tag="a"
                href="{{ path('app_'~flowRoute~'_delete_confirm', {'id': result.id}) }}"
                type="submit"
                variant="danger"
                class="w-full"
                data-turbo-prefetch="false">
                Delete
            </twig:Button>
        {% endif %}
    </twig:Dialog>

{% endblock %}

