{% extends 'base.html.twig' %}

{% block title %}Order Dashboard{% endblock %}

{% block body %}

        <turbo-frame id="reports">

            <twig:Card>
            {% if report.summary is not null %}
                <div class="mb-3 flex items-center justify-between">
                    <div class="flex items-center justify-start">
                        <a href="{{ path('app_dashboard') }}"
                           class="flex items-center text-gray-600 dark:text-gray-500 dark:hover:text-gray-300"
                           data-turbo-frame="body"
                        >
                            <twig:ux:icon name="ic:sharp-bar-chart" class="h-5 w-5 me-1"/>
                            Order Summary
                        </a>
                    </div>
                    {{ include('dashboard/_sales_durations.html.twig') }}
                </div>

                {{ include('dashboard/_order_sales_summary.html.twig', {summary: report.summary}) }}

                {% if report.orderSalesChart %}
                    <div
                        class="mt-3 flex h-64 flex-wrap justify-around rounded bg-white text-center font-light dark:border-gray-700 dark:bg-gray-900 md:h-auto">
                        {{ render_chart(report.orderSalesChart, {'data-controller': 'bar_chart', 'class': 'w-full h-full'}) }}
                    </div>
                {% endif %}

                {% if report.orderProgressChart %}
                    <div class="my-3 flex items-center justify-start">
                        <p class="text-gray-600 dark:text-gray-500">Order Progress</p>
                    </div>
                    <div
                        class="flex h-64 flex-wrap justify-around rounded bg-white text-center font-light dark:border-gray-700 dark:bg-gray-900 md:h-auto">
                        {{ render_chart(report.orderProgressChart, {'data-controller': 'doughnut_chart', 'class': ''}) }}
                    </div>
                {% endif %}

            {% endif %}
            </twig:Card>

        </turbo-frame>

{% endblock %}