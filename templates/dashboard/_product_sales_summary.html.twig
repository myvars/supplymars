<div
    class="flex flex-wrap justify-around rounded bg-white text-center font-light dark:border-gray-700 dark:bg-gray-900">

    <div class="w-full px-6 py-4 md:w-auto">
        <a href="{{ path(app.current_route, app.request.query.all|merge({'sort': 'salesQty'})) }}"
           class="hover:text-gray-400 dark:hover:text-gray-300"
        >
            <p class="mb-1">Sales Qty</p>
            <p class="text-xl font-bold text-gray-900 dark:text-gray-300">
                {{ summary.salesQty|default(0) }}
            </p>
        </a>
    </div>
    <div class="w-full px-6 pb-4 md:w-auto md:py-4">
        <a href="{{ path(app.current_route, app.request.query.all|merge({'sort': 'salesCost'})) }}"
           class="hover:text-gray-400 dark:hover:text-gray-300"
        >
            <p class="mb-1">Sales Cost</p>
            <p class="text-xl font-bold text-gray-900 dark:text-gray-300">
                {{ summary.salesCost|default(0)|format_currency('GBP', { max_fraction_digit:0 }) }}
            </p>
        </a>
    </div>
    <div class="w-full px-6 md:w-auto md:py-4">
        <a href="{{ path(app.current_route, app.request.query.all|merge({'sort': 'salesProfit'})) }}"
           class="hover:text-gray-400 dark:hover:text-gray-300"
        >
            <p class="mb-1">Sales profit</p>
            <p class="text-xl font-bold text-gray-900 dark:text-gray-300">
                {{ summary.salesProfit|default(0)|format_currency('GBP', { max_fraction_digit:0 }) }}
            </p>
        </a>
    </div>
    <div class="w-full px-6 py-4 md:w-auto">
        <a href="{{ path(app.current_route, app.request.query.all|merge({'sort': 'salesMargin'})) }}"
           class="hover:text-gray-400 dark:hover:text-gray-300"
        >
            <p class="mb-1">Gross Margin</p>
            <p class="text-xl font-bold text-gray-900 dark:text-gray-300">
                {{ '%0.2f%%'|format(summary.salesMargin|default(0)) }}
            </p>
        </a>
    </div>
</div>