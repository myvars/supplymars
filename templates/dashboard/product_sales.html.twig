{% extends 'base.html.twig' %}

{% block title %}Product Sales Dashboard{% endblock %}

{% block body %}

    <turbo-frame id="reports">
        <twig:Card>
            {% if report.summary is not null %}
                <div class="mb-3 flex items-center justify-between">
                    <div class="flex items-center justify-start">
                        {% if report.type == 'all' %}
                        <a href="{{ path('app_dashboard') }}"
                           class="flex items-center text-gray-600 dark:text-gray-500 dark:hover:text-gray-300"
                           data-turbo-frame="body"
                        >
                            <twig:ux:icon name="ic:sharp-bar-chart" class="h-5 w-5 me-1"/>
                            Product Sales
                        </a>
                        {% else %}
                            <p class="text-gray-600 dark:text-gray-500">
                                <span class="hidden md:inline">{{ report.type|title }} Sales</span>
                                <span class="md:hidden">Sales</span>
                            </p>
                        {% endif %}
                    </div>
                    {{ include('dashboard/_sales_durations.html.twig') }}
                </div>

                {{ include('dashboard/_product_sales_summary.html.twig', {summary: report.summary}) }}

                {% if report.productSalesChart %}
                    <div
                        class="mt-3 flex h-64 flex-wrap justify-around rounded-sm bg-white text-center font-light dark:border-gray-700 dark:bg-gray-900 md:h-auto">
                        {{ render_chart(report.productSalesChart, {'data-controller': 'bar_chart', 'class': 'w-full h-full'}) }}
                    </div>
                {% endif %}

            {% endif %}

            {% if report.sales %}
                <div class="mt-3 flex items-center justify-between">
                    <p class="text-gray-600 dark:text-gray-500">
                        <span class="hidden md:inline">Top Products</span>
                        <span class="md:hidden">Sales</span>
                    </p>
                    {% if not report.summary %}
                        {{ include('dashboard/_sales_durations.html.twig') }}
                    {% endif %}
                </div>

                <div class="relative mt-3 overflow-x-auto shadow-md sm:rounded-sm">
                    <table class="w-full text-left text-sm text-gray-500 dark:text-gray-400">
                        <thead class="bg-gray-50 text-xs uppercase text-gray-700 dark:bg-gray-700 dark:text-gray-400">
                        <tr>
                            <th scope="col" class="px-6 py-3">
                                Product name
                            </th>
                            <th scope="col" class="px-6 py-3">
                                <div class="flex justify-center">
                                    <twig:SortLink sortValue="salesQty">Qty</twig:SortLink>
                                </div>
                            </th>
                            <th scope="col" class="px-6 py-3">
                                <div class="flex justify-end">
                                    <twig:SortLink sortValue="salesCost">Cost</twig:SortLink>
                                </div>
                            </th>
                            <th scope="col" class="px-6 py-3">
                                <div class="flex justify-end">
                                    <twig:SortLink sortValue="salesProfit">Profit</twig:SortLink>
                                </div>
                            </th>
                            <th scope="col" class="px-6 py-3">
                                <div class="flex justify-center">
                                    <twig:SortLink sortValue="salesMargin">Margin</twig:SortLink>
                                </div>
                            </th>
                        </tr>
                        </thead>
                        <tbody>
                        {% for sale in report.sales %}
                            <tr class="border-b odd:bg-white even:bg-gray-50 dark:border-gray-700 dark:odd:bg-gray-900 dark:even:bg-gray-800">
                                <th scope="row"
                                    class="whitespace-nowrap px-6 py-4 font-medium text-gray-900 dark:text-gray-300">
                                    <a href="{{ path('app_product_show', {'id': sale.id }) }}"
                                       class="dark:hover:text-white"
                                       data-turbo-frame="body"
                                    >
                                        {{ sale.name|slug.truncate(30, '...') }}
                                    </a>
                                </th>
                                <td class="px-6 py-4 text-center">
                                    {{ sale.salesQty }}
                                </td>
                                <td class="px-6 py-4 text-right">
                                    {{ sale.salesValue|format_currency('GBP', { max_fraction_digit:0 }) }}
                                </td>
                                <td class="px-6 py-4 text-right">
                                    {{ sale.salesProfit|format_currency('GBP', { max_fraction_digit:0 }) }}
                                </td>
                                <td class="px-6 py-4 text-center">
                                    {{ '%0.2f%%'|format(sale.salesMargin) }}
                                </td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}
        </twig:Card>
    </turbo-frame>

{% endblock %}