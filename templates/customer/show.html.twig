{# Customer detail page — composes _customer_card, _customer_insights_card,
   and _customer_addresses_card. Variable: result (User), insights (?CustomerInsights) #}
{% extends 'base.html.twig' %}

{% block title %}Customer Details{% endblock %}

{% block body %}

    <div class="m-3 space-y-4">
        <twig:Breadcrumb :href="path('app_customer_index')" label="Customers" :current="result.fullName"/>
        {{ include('customer/_customer_card.html.twig', {customer: result}) }}
        {% if insights is defined and insights is not null %}
            {{ include('customer/_customer_insights_card.html.twig', {insights: insights, customer: result}) }}
        {% endif %}
        {% if result.addresses.count > 0 %}
            {{ include('customer/_customer_addresses_card.html.twig', {customer: result}) }}
        {% endif %}
    </div>

{% endblock %}