{% extends 'base.html.twig' %}

{% block title %}Forgot password{% endblock %}

{% block body %}
    {% embed 'customer/_auth_layout.html.twig' %}
        {% block auth_content %}
            <div class="flex flex-col items-center text-center">
                <div class="mb-4 flex h-14 w-14 items-center justify-center rounded-full bg-primary-100 dark:bg-primary-900/30">
                    <twig:ux:icon name="bi:key" class="h-7 w-7 text-primary-600 dark:text-primary-400"/>
                </div>
                <h1 class="text-xl font-bold leading-tight tracking-tight text-gray-900 dark:text-white md:text-2xl">
                    Forgot Password
                </h1>
                <p class="mt-2 text-sm text-gray-500 dark:text-gray-400">
                    Enter your email address and we'll send you a link to reset your password.
                </p>
            </div>
            {% for flash_error in app.flashes('reset_password_error') %}
                <twig:Alert type="danger">{{ flash_error }}</twig:Alert>
            {% endfor %}
            {{ form_start(requestForm, {
                'attr': {
                    'class': 'space-y-4 md:space-y-6',
                    'novalidate': 'novalidate',
                }
            }) }}
            {{ form_row(requestForm.email) }}
            <twig:Button type="submit" class="w-full">Send Reset Link</twig:Button>
            <p class="text-center text-sm font-light text-gray-500 dark:text-gray-400">
                Remembered your details?
                <a
                    href="{{ path('app_login') }}"
                    class="font-medium text-primary-600 hover:underline dark:text-primary-500"
                >Login here</a>
            </p>
            {{ form_end(requestForm) }}
        {% endblock %}
    {% endembed %}
{% endblock %}
