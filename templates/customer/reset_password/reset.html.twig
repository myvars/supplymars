{% extends 'base.html.twig' %}

{% block title %}Reset password{% endblock %}

{% block body %}
    {% embed 'customer/_auth_layout.html.twig' %}
        {% block auth_content %}
            <div class="flex flex-col items-center text-center">
                <div class="mb-4 flex h-14 w-14 items-center justify-center rounded-full bg-primary-100 dark:bg-primary-900/30">
                    <twig:ux:icon name="bi:shield-lock" class="h-7 w-7 text-primary-600 dark:text-primary-400"/>
                </div>
                <h1 class="text-xl font-bold leading-tight tracking-tight text-gray-900 dark:text-white md:text-2xl">
                    Change Password
                </h1>
                <p class="mt-2 text-sm text-gray-500 dark:text-gray-400">
                    Enter your new password below.
                </p>
            </div>
            {{ form_start(form, {
                'attr': {
                    'class': 'space-y-4 md:space-y-6',
                    'novalidate': 'novalidate',
                }
            }) }}
            {{ form_row(form.plainPassword) }}
            <twig:Button type="submit" class="w-full" data-turbo-frame="_top">Reset password</twig:Button>
            {{ form_end(form) }}
        {% endblock %}
    {% endembed %}
{% endblock %}
