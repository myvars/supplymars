{% extends 'base.html.twig' %}

{% block title %}Password Reset Email Sent{% endblock %}

{% block body %}
    {% embed 'customer/_auth_layout.html.twig' %}
        {% block auth_content %}
            <div class="flex flex-col items-center text-center">
                <div class="mb-4 flex h-14 w-14 items-center justify-center rounded-full bg-green-100 dark:bg-green-900/30">
                    <twig:ux:icon name="bi:envelope-check" class="h-7 w-7 text-green-600 dark:text-green-400"/>
                </div>
                <h1 class="text-xl font-bold leading-tight tracking-tight text-gray-900 dark:text-white md:text-2xl">
                    Check Your Email
                </h1>
            </div>
            <p class="text-center text-sm text-gray-600 dark:text-gray-300">
                If an account matching your email exists, we've sent a link to reset your password.
            </p>
            <div class="rounded-lg border border-amber-200 bg-amber-50 p-3 dark:border-amber-800/50 dark:bg-amber-900/20">
                <p class="flex items-center gap-2 text-sm text-amber-800 dark:text-amber-300">
                    <twig:ux:icon name="bi:clock" class="h-4 w-4 shrink-0"/>
                    This link will expire in
                    {{ resetToken.expirationMessageKey|trans(resetToken.expirationMessageData, 'ResetPasswordBundle') }}.
                </p>
            </div>
            <p class="text-center text-sm font-light text-gray-500 dark:text-gray-400">
                Didn't receive an email? Check your spam folder or
                <a
                    href="{{ path('app_forgot_password_request') }}"
                    class="font-medium text-primary-600 hover:underline dark:text-primary-500"
                ><span class="whitespace-nowrap">try again</span></a>.
            </p>
        {% endblock %}
    {% endembed %}
{% endblock %}
