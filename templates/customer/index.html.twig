{% extends 'base.html.twig' %}

{% block title %}Customer Search{% endblock %}

{% block body %}
    <twig:Search
        flowModel="{{ flowModel }}"
        routes="{{ routes }}"
        results="{{ results }}"
        showFilter="{{ false }}"
        showAdd="{{ false }}"
    >
        <twig:block name="sort">
            <twig:SortLink sortValue="id">Id</twig:SortLink>
            <twig:SortLink sortValue="fullName">Name</twig:SortLink>
            <twig:SortLink sortValue="email">Email</twig:SortLink>
            <twig:SortLink sortValue="isVerified">Verified</twig:SortLink>
        </twig:block>

        <twig:block name="list_item">
            <twig:Card
                editLink="{{ path('app_customer_edit', {'id': result.publicId.value }) }}"
                showLink="{{ path('app_customer_show', {'id': result.publicId.value }) }}"
                statusHighlight="{{ result.isVerified ? 'VERIFIED' : 'UNVERIFIED' }}"
            >
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-lg font-semibold text-gray-900 line-clamp-1 dark:text-white">
                            {{ result.fullName }}
                        </p>
                        <p class="text-sm text-gray-500 dark:text-gray-400">{{ result.email }}</p>
                    </div>
                    <div class="flex items-center gap-2">
                        {% if result.isAdmin %}
                            <twig:StatusBadge status="ADMIN"/>
                        {% endif %}
                        <twig:StatusBadge status="{{ result.isVerified ? 'VERIFIED' : 'UNVERIFIED' }}"/>
                    </div>
                </div>
            </twig:Card>
        </twig:block>
    </twig:Search>

{% endblock %}
