{% extends 'base.html.twig' %}

{% block title %}Customer Search{% endblock %}

{% block body %}
    <twig:Search
        flowModel="{{ flowModel }}"
        flowRoute="{{ flowRoute }}"
        results="{{ results }}"
    >
        <twig:block name="sort">
            <twig:Card>
                <div class="flex justify-between overflow-auto">
                    <twig:SortLink sortValue="id">Id</twig:SortLink>
                    <twig:SortLink sortValue="fullName">Name</twig:SortLink>
                    <twig:SortLink sortValue="email">Email</twig:SortLink>
                    <twig:SortLink sortValue="isVerified">Verified</twig:SortLink>
                </div>
            </twig:Card>
        </twig:block>

        <twig:block name="list_item">
            <twig:Card
                editLink="{{ path('app_customer_edit', {'id': result.publicId.value }) }}"
                showLink="{{ path('app_customer_show', {'id': result.publicId.value }) }}"
            >
                <p class="mb-1 text-lg text-gray-900 line-clamp-1 dark:text-white">
                    {{ result.fullName }}
                    {% if result.isAdmin %}
                        <span
                            class="text-base font-extralight text-red-500 ms-1 dark:text-red-400">(Administrator)
                        </span>
                    {% endif %}
                </p>
                <p class="mt-1 flex items-center justify-between">
                    <span class="text-base font-extralight me-1">{{ result.email }}</span>
                    {% if result.isVerified %}
                        <span class="text-green-500">Verified</span>
                    {% else %}
                        <span class="text-red-500">Unverified</span>
                    {% endif %}
                </p>
            </twig:Card>
        </twig:block>

        <twig:block name="filter"></twig:block>
    </twig:Search>

{% endblock %}
