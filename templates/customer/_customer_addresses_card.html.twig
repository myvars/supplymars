<twig:Card title="Addresses ({{ customer.addresses.count }})">
    <div class="-mx-3 -mb-1 divide-y divide-gray-100 dark:divide-gray-700/50">
        {% for address in customer.addresses %}
            <div class="flex items-start gap-3 px-3 py-3">
                <twig:ux:icon name="bi:geo-alt" class="mt-0.5 h-4 w-4 shrink-0 text-gray-400 dark:text-gray-500"/>
                <div class="text-sm">
                    {% if address.defaultBillingAddress %}
                        <p class="mb-1 text-xs font-medium text-primary-600 dark:text-primary-400">Billing Address</p>
                    {% elseif address.defaultShippingAddress %}
                        <p class="mb-1 text-xs font-medium text-primary-600 dark:text-primary-400">Default Shipping Address</p>
                    {% endif %}
                    <p class="text-gray-900 dark:text-white">{{ address.street }}</p>
                    {% if address.street2 is not null %}
                        <p class="text-gray-900 dark:text-white">{{ address.street2 }}</p>
                    {% endif %}
                    <p class="text-gray-500 dark:text-gray-400">{{ address.city }}, {{ address.postCode }}</p>
                    <p class="text-gray-500 dark:text-gray-400">{{ address.country }}</p>
                </div>
            </div>
        {% endfor %}
    </div>
</twig:Card>