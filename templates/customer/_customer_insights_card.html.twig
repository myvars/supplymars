<twig:Card>
    <div class="mb-3 flex items-center justify-between">
        <div class="flex items-center gap-2 text-lg font-medium text-gray-900 dark:text-gray-300">
            <twig:ux:icon name="ic:sharp-bar-chart" class="h-5 w-5"/>
            Customer Insights
        </div>
        {% set segmentColors = {
            'new': 'bg-blue-100 text-blue-800 dark:bg-blue-900/50 dark:text-blue-300',
            'returning': 'bg-green-100 text-green-800 dark:bg-green-900/50 dark:text-green-300',
            'loyal': 'bg-purple-100 text-purple-800 dark:bg-purple-900/50 dark:text-purple-300',
            'lapsed': 'bg-red-100 text-red-800 dark:bg-red-900/50 dark:text-red-300',
        } %}
        <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold {{ segmentColors[insights.segment]|default('bg-gray-100 text-gray-800') }}">
            {{ insights.segment|upper }}
        </span>
    </div>

    {% set ordersUrl = path('app_order_index', {customerId: customer.id}) %}
    <div class="grid grid-cols-2 gap-3 md:grid-cols-3">
        <twig:KpiCard title="Total Revenue" value="{{ insights.totalRevenue|default(0) }}" valueType="currency" href="{{ ordersUrl }}"/>
        <twig:KpiCard title="Order Count" value="{{ insights.orderCount|default(0) }}" href="{{ ordersUrl }}"/>
        <twig:KpiCard title="Avg Order Value" value="{{ insights.averageOrderValue|default(0) }}" valueType="currency" href="{{ ordersUrl }}"/>
        <twig:KpiCard title="Customer Rank" value="{{ insights.revenueRank|default(0) }}"/>
        <twig:KpiCard title="First Order" value="{{ insights.firstOrderDate ? insights.firstOrderDate|ago : '-' }}" valueType="text" href="{{ path('app_order_index', {customerId: customer.id, sortDirection: 'ASC'}) }}"/>
        <twig:KpiCard title="Last Order" value="{{ insights.lastOrderDate ? insights.lastOrderDate|ago : '-' }}" valueType="text" href="{{ ordersUrl }}"/>
    </div>

    {% if insights.reviewCount > 0 %}
        <div class="mt-3 grid grid-cols-2 gap-3 md:grid-cols-3">
            <twig:KpiCard title="Published Reviews" value="{{ insights.reviewCount }}"/>
        </div>
    {% endif %}
</twig:Card>
