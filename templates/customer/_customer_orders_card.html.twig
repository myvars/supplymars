<twig:Card title="Orders">
    <a href="{{ path('app_order_index', {customerId: result.id}) }}"
       class="group flex items-center justify-between text-sm text-gray-600 dark:text-gray-400"
       data-turbo-frame="body"
    >
        <span class="flex items-center gap-2">
            <twig:ux:icon name="bi:bag" class="h-4 w-4 text-gray-400 dark:text-gray-500"/>
            <span class="font-medium text-gray-900 dark:text-white">{{ result.customerOrders.count }}</span>
            {{ result.customerOrders.count == 1 ? 'order': 'orders' }} from this customer
        </span>
        <twig:ux:icon name="bi:arrow-right" class="h-4 w-4 text-gray-400 transition-transform duration-150 group-hover:translate-x-0.5 group-hover:text-primary-500 dark:text-gray-500"/>
    </a>
</twig:Card>
