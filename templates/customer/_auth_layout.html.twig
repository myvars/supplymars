<section class="relative rounded-sm bg-gray-50 dark:bg-gray-900 md:h-screen" style="background: url({{ asset('images/martian_landscape.webp') }}) center center no-repeat; background-size: cover;">
    <div class="absolute inset-0 bg-gradient-to-b from-gray-950/50 via-gray-950/20 to-gray-950/70 pointer-events-none"></div>
    <div class="relative mx-auto flex flex-col items-center px-6 py-8 lg:py-0">
        <div class="w-full rounded-xl bg-white/95 shadow-2xl backdrop-blur-sm dark:border dark:border-white/[0.1] dark:bg-gray-800/90 dark:shadow-2xl dark:shadow-black/40 dark:backdrop-blur-xl sm:max-w-md md:m-10 xl:p-0">
            <div class="p-6 space-y-5 sm:p-8">
                {% block auth_content %}{% endblock %}
            </div>
        </div>
    </div>
</section>
