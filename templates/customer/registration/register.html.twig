{% extends 'shared/turbo/modal_base.html.twig' %}

{% block title %}Sign Up{% endblock %}

{% block body %}
    {% embed 'customer/_auth_layout.html.twig' %}
        {% block auth_content %}
            <div class="flex flex-col items-center text-center">
                <div class="mb-4 flex h-14 w-14 items-center justify-center rounded-full bg-primary-100 dark:bg-primary-900/30">
                    <twig:ux:icon name="bi:person-plus" class="h-7 w-7 text-primary-600 dark:text-primary-400"/>
                </div>
                <h1 class="text-xl font-bold leading-tight tracking-tight text-gray-900 dark:text-white md:text-2xl">
                    Create an account
                </h1>
            </div>
            {% for flash_error in app.flashes('verify_email_error') %}
                <twig:Alert type="danger">{{ flash_error }}</twig:Alert>
            {% endfor %}
            {% for flash_error in app.flashes('danger') %}
                <twig:Alert type="danger">{{ flash_error }}</twig:Alert>
            {% endfor %}
            {{ form_start(form, {
                'attr': {
                    'class': 'space-y-4 md:space-y-6',
                    'novalidate': 'novalidate',
                }
            }) }}
            {{ form_row(form.fullName) }}
            {{ form_row(form.email) }}
            {{ form_row(form.plainPassword) }}
            <div>
                <div class="flex items-center">
                    <input type="checkbox" id="registration_form_agreeTerms"
                           name="{{ field_name(form.agreeTerms) }}"
                           required="required"
                           class="h-4 w-4 rounded-sm border-gray-300 bg-gray-100 text-primary-600 focus:ring-2 focus:ring-primary-500 dark:border-gray-600 dark:bg-gray-700 dark:ring-offset-gray-800 dark:focus:ring-primary-600"
                           value="{{ field_value(form.agreeTerms) }}">
                    <label class="ml-2 text-sm font-light text-gray-500 dark:text-gray-400"
                           for="registration_form_agreeTerms">
                        I accept the
                        <a
                            class="font-medium text-primary-600 hover:underline dark:text-primary-500"
                            href="{{ path('app_terms_page') }}"
                        >Terms and Conditions</a>
                    </label>
                </div>
                <div class="form-error">
                    {{ form_errors(form.agreeTerms) }}
                </div>
            </div>
            {{ form_row(form.turnstileResponse) }}
            <twig:Button type="submit" class="w-full" data-turbo-frame="_top">Create account</twig:Button>
            <p class="text-center text-sm font-light text-gray-500 dark:text-gray-400">
                Already have an account?
                <a
                    href="{{ path('app_login') }}"
                    class="font-medium text-primary-600 hover:underline dark:text-primary-500"
                >Login here</a>
            </p>
            {{ form_end(form) }}
        {% endblock %}
    {% endembed %}
{% endblock %}
