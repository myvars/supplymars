<div class="relative h-full w-full bg-white border border-gray-200 rounded-lg shadow dark:bg-gray-800 dark:border-gray-700">
    <a href="{{ path('app_customer_edit', {id: customer.id})}}"
       class="absolute -top-1.5 -right-1 p-1.5 bg-white text-yellow-500 border border-gray-600 rounded-full shadow-lg dark:bg-gray-700 dark:hover:bg-gray-600"
       data-turbo-frame="modal"
    >
        <twig:ux:icon name="mynaui:edit-one" class="w-6 h-6 p-0.5" />
    </a>
    <div class="p-3 text-sm text-gray-500 dark:text-gray-400">
        <p class="text-gray-600 dark:text-gray-500">Customer</p>
        <p class="mb-1 text-xl text-gray-900 dark:text-white">
            {{ customer.fullName|u.truncate(30, '...') }}
            {% if result.isAdmin %}
                <span class="ms-2 text-base font-extralight text-red-500 dark:text-red-400">(Administrator)</span>
            {% endif %}
        </p>
        <p class="font-extralight">{{ customer.email }}</p>
        <div class="mt-3 flex items-center justify-between">
            <p class="me-10 text-xs text-gray-600 dark:text-gray-500">Updated {{ customer.updatedAt|ago }}</p>
            {% if customer.isVerified %}
                <p class="text-green-500">Verified</p>
            {% else %}
                <p class="text-green-500">Unverified</p>
            {% endif %}
        </div>
    </div>
</div>