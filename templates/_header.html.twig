<header class="mt-3">
    <nav class="rounded-t-lg border-b border-gray-700/50 bg-gray-900 shadow-lg"
         data-controller="basic-drawer"
         data-basic-drawer-drawer-id-value="side-menu"
    >
        <div class="mx-auto flex max-w-(--breakpoint-xl) flex-wrap items-center justify-between px-4 py-2.5">

            <div class="flex items-center justify-end">
                <button id="navigationButton"
                        type="button"
                        class="inline-flex h-9 w-9 items-center justify-center rounded-lg p-2 text-sm text-gray-400 transition-colors hover:bg-gray-700/70 hover:text-gray-200 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-gray-500"
                        data-action="click->basic-drawer#open"
                >
                    <span class="sr-only">Open side menu</span>
                    <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 17 14"><path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M1 1h15M1 7h15M1 13h15"/></svg>
                </button>
                <a href="{{ path('app_homepage') }}" class="mx-4 flex items-center space-x-3 rtl:space-x-reverse"
                   data-turbo-frame="body">
                    {{ include('_logo.html.twig', { 'logoHeight': 32 }) }}
                </a>
            </div>
            <div class="flex items-center gap-1 md:order-2">
                <div data-controller="theme-toggle">
                    <button type="button"
                            class="inline-flex h-9 w-9 items-center justify-center rounded-lg p-2 text-sm text-gray-400 transition-colors hover:bg-gray-700/70 hover:text-gray-200 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-gray-500"
                            data-action="theme-toggle#toggle"
                    >
                        <span class="sr-only">Toggle dark mode</span>
                        <span data-theme-toggle-target="sunIcon" class="hidden">
                            <twig:ux:icon name="flowbite:sun-solid" class="h-5 w-5"/>
                        </span>
                        <span data-theme-toggle-target="moonIcon" class="hidden">
                            <twig:ux:icon name="flowbite:moon-solid" class="h-5 w-5"/>
                        </span>
                    </button>
                </div>
                {% if is_granted('IS_AUTHENTICATED_REMEMBERED') %}
                    <div class="relative" data-controller="toggle" data-toggle-close-on-click-outside-value="true">
                        <button type="button"
                                class="flex items-center rounded-full p-1 transition-opacity hover:opacity-80 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-gray-500"
                                data-action="click->toggle#toggle">
                            <span class="sr-only">Open user menu</span>
                            <img class="h-7 w-7 rounded-full ring-2 ring-gray-600" src="{{ asset('images/avatar.png') }}" alt="user photo">
                        </button>
                        <div
                            class="absolute right-0 top-full z-50 mt-2 hidden w-52 list-none overflow-hidden rounded-lg bg-gray-800 text-base shadow-xl ring-1 ring-white/10 divide-y divide-gray-700/50"
                            data-toggle-target="toggleable">
                            <div class="px-4 py-3">
                                <p class="text-sm font-medium text-white">{{ app.user.fullName }}</p>
                                <p class="mt-0.5 truncate text-xs text-gray-400">{{ app.user.userIdentifier }}</p>
                            </div>
                            <ul class="py-1.5">
                                <li>
                                    <a href="{{ path('app_customer_show', { id: app.user.publicId  }) }}"
                                       class="flex items-center gap-2 px-4 py-2 text-sm text-gray-300 transition-colors hover:bg-gray-700 hover:text-white"
                                       data-turbo-frame="body"
                                    >
                                        <twig:ux:icon name="flowbite:cog-solid" class="h-4 w-4 text-gray-500"/>
                                        Settings
                                    </a>
                                </li>
                                <li>
                                    <a href="{{ path('app_logout') }}"
                                       class="flex items-center gap-2 px-4 py-2 text-sm text-gray-300 transition-colors hover:bg-gray-700 hover:text-white"
                                       data-turbo-prefetch="false"
                                       data-turbo-frame="_top"
                                    >
                                        <twig:ux:icon name="flowbite:arrow-right-to-bracket-outline" class="h-4 w-4 text-gray-500"/>
                                        Sign Out
                                    </a>
                                </li>
                            </ul>
                        </div>
                    </div>
                {% else %}
                    <a
                        href="{{ path('app_login') }}"
                        class="ml-1 text-sm font-medium text-gray-400 transition-colors hover:text-white"
                        data-turbo-frame="_top"
                    >Sign In</a>
                {% endif %}
            </div>
        </div>
        {{ include('_menu.html.twig') }}
    </nav>
</header>
