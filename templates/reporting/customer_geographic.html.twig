{% extends 'base.html.twig' %}

{% block title %}Customer Geographic Report{% endblock %}

{% block body %}

    <div class="m-3">
    <turbo-frame id="reports" refresh="morph">
        <twig:Card>
            {{ include('reporting/_customer_insights_nav.html.twig') }}

            <div class="grid grid-cols-1 gap-px overflow-hidden rounded-lg bg-gray-900/5 dark:bg-white/5 md:grid-cols-3">
                <div class="flex flex-col items-center justify-center gap-1 overflow-hidden bg-white px-3 py-4 dark:bg-gray-800 sm:px-5">
                    <p class="text-xs font-medium uppercase tracking-wide text-gray-500 dark:text-gray-400">Top City by Revenue</p>
                    <span class="truncate text-xl font-semibold text-gray-900 dark:text-gray-100 sm:text-2xl">
                        {{ report.summary.topCity|default('-') }}
                    </span>
                </div>
                <twig:KpiCard title="Cities with Orders" value="{{ report.summary.cityCount|default(0) }}"/>
                <twig:KpiCard title="Avg Revenue/City" value="{{ report.summary.avgRevenuePerCity|default(0) }}" valueType="currency"/>
            </div>

            {% if report.geoChart %}
                <div class="mt-3 flex items-center justify-start">
                    <p class="font-medium text-gray-600 dark:text-gray-500">Revenue by City</p>
                </div>
                <div
                    class="mt-3 flex h-60 md:h-72 flex-wrap justify-around rounded-lg border border-gray-200/80 bg-white text-center font-light dark:border-white/[0.06] dark:bg-gray-800">
                    {{ render_chart(report.geoChart, {'data-controller': 'doughnut_chart', 'class': ''}) }}
                </div>
            {% endif %}

            {% if report.geoData is not empty %}
                <div class="relative mt-3 overflow-x-auto rounded-lg border border-gray-200/80 dark:border-white/[0.06]">
                    <table class="w-full text-left text-sm text-gray-500 dark:text-gray-400">
                        <caption class="sr-only">Revenue by City</caption>
                        <thead class="bg-gray-100 text-xs font-semibold uppercase text-gray-700 dark:bg-gray-700 dark:text-gray-400">
                        <tr>
                            <th scope="col" class="px-6 py-3">City</th>
                            <th scope="col" class="px-6 py-3">
                                <div class="flex justify-center">
                                    <twig:SortLink sortValue="customerCount">Customers</twig:SortLink>
                                </div>
                            </th>
                            <th scope="col" class="px-6 py-3">
                                <div class="flex justify-center">
                                    <twig:SortLink sortValue="orderCount">Orders</twig:SortLink>
                                </div>
                            </th>
                            <th scope="col" class="px-6 py-3">
                                <div class="flex justify-end">
                                    <twig:SortLink sortValue="orderValue">Revenue</twig:SortLink>
                                </div>
                            </th>
                            <th scope="col" class="px-6 py-3">
                                <div class="flex justify-end">
                                    <twig:SortLink sortValue="averageOrderValue">AOV</twig:SortLink>
                                </div>
                            </th>
                        </tr>
                        </thead>
                        <tbody>
                        {% for geo in report.geoData %}
                            <tr class="border-b odd:bg-white even:bg-gray-50 transition-colors hover:bg-gray-100 dark:border-white/[0.06] dark:odd:bg-gray-900 dark:even:bg-gray-800 dark:hover:bg-gray-700/50">
                                <th scope="row"
                                    class="whitespace-nowrap px-6 py-4 font-medium text-gray-900 dark:text-white">
                                    {{ geo.city }}
                                </th>
                                <td class="px-6 py-4 text-center">
                                    {{ geo.customerCount }}
                                </td>
                                <td class="px-6 py-4 text-center">
                                    {{ geo.orderCount }}
                                </td>
                                <td class="px-6 py-4 text-right">
                                    {{ geo.orderValue|default(0)|price_rounded }}
                                </td>
                                <td class="px-6 py-4 text-right">
                                    {{ geo.averageOrderValue|default(0)|price_rounded }}
                                </td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}
        </twig:Card>
    </turbo-frame>
    </div>

{% endblock %}
