{% extends 'base.html.twig' %}

{% block title %}Customer Segments Report{% endblock %}

{% block body %}

    <div class="m-3">
    <turbo-frame id="reports" refresh="morph">
        <twig:Card>
            {{ include('reporting/_customer_insights_nav.html.twig') }}

            <div class="grid grid-cols-2 gap-3 md:grid-cols-4">
                <twig:KpiCard title="New" value="{{ report.summary.new|default(0) }}"/>
                <twig:KpiCard title="Returning" value="{{ report.summary.returning|default(0) }}"/>
                <twig:KpiCard title="Loyal" value="{{ report.summary.loyal|default(0) }}"/>
                <twig:KpiCard title="Lapsed" value="{{ report.summary.lapsed|default(0) }}"/>
            </div>

            {% if report.segmentChart %}
                <div class="mt-3 flex items-center justify-start">
                    <p class="font-medium text-gray-600 dark:text-gray-500">Revenue by Segment</p>
                </div>
                <div
                    class="mt-3 flex h-60 md:h-72 flex-wrap justify-around rounded-lg border border-gray-200/80 bg-white text-center font-light dark:border-gray-700 dark:bg-gray-800">
                    {{ render_chart(report.segmentChart, {'data-controller': 'doughnut_chart', 'class': ''}) }}
                </div>
            {% endif %}

            {% if report.segmentData is not empty %}
                <div class="relative mt-3 overflow-x-auto rounded-lg border border-gray-200/80 dark:border-gray-700">
                    <table class="w-full text-left text-sm text-gray-500 dark:text-gray-400">
                        <thead class="bg-gray-100 text-xs font-semibold uppercase text-gray-700 dark:bg-gray-700 dark:text-gray-400">
                        <tr>
                            <th scope="col" class="px-6 py-3">Segment</th>
                            <th scope="col" class="px-6 py-3">
                                <div class="flex justify-center">
                                    <twig:SortLink sortValue="customerCount">Customers</twig:SortLink>
                                </div>
                            </th>
                            <th scope="col" class="px-6 py-3">
                                <div class="flex justify-center">
                                    <twig:SortLink sortValue="orderCount">Orders</twig:SortLink>
                                </div>
                            </th>
                            <th scope="col" class="px-6 py-3">
                                <div class="flex justify-end">
                                    <twig:SortLink sortValue="orderValue">Revenue</twig:SortLink>
                                </div>
                            </th>
                            <th scope="col" class="px-6 py-3">
                                <div class="flex justify-end">
                                    <twig:SortLink sortValue="averageOrderValue">AOV</twig:SortLink>
                                </div>
                            </th>
                            <th scope="col" class="px-6 py-3">
                                <div class="flex justify-center">Avg Items/Order</div>
                            </th>
                        </tr>
                        </thead>
                        <tbody>
                        {% for seg in report.segmentData %}
                            <tr class="border-b odd:bg-white even:bg-gray-50 transition-colors hover:bg-gray-100 dark:border-gray-700 dark:odd:bg-gray-900 dark:even:bg-gray-800 dark:hover:bg-gray-700/50">
                                <th scope="row"
                                    class="whitespace-nowrap px-6 py-4 font-medium text-gray-900 dark:text-gray-300">
                                    <twig:StatusBadge :status="seg.segment.value"/>
                                </th>
                                <td class="px-6 py-4 text-center">
                                    {{ seg.customerCount }}
                                </td>
                                <td class="px-6 py-4 text-center">
                                    {{ seg.orderCount }}
                                </td>
                                <td class="px-6 py-4 text-right">
                                    {{ seg.orderValue|default(0)|price_rounded }}
                                </td>
                                <td class="px-6 py-4 text-right">
                                    {{ seg.averageOrderValue|default(0)|price_rounded }}
                                </td>
                                <td class="px-6 py-4 text-center">
                                    {{ '%0.1f'|format(seg.averageItemsPerOrder|default(0)) }}
                                </td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}
        </twig:Card>
    </turbo-frame>
    </div>

{% endblock %}
