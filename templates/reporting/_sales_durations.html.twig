<div class="flex items-center gap-0.5 rounded-lg bg-gray-100 p-0.5 text-xs font-medium dark:bg-gray-700">
    {% set durations = { 'today': 'Today', 'last7': '7 days', 'last30': '30 days', 'mtd': 'MTD' } %}
    {% for key, label in durations %}
        {% set isActive = app.request.query.get('duration') == key or (key == 'last30' and not app.request.query.get('duration')) %}
        <a href="{{ path(app.current_route, app.request.query.all|merge({'duration': key})) }}"
           class="rounded-md px-3 py-1.5 transition-colors {{ isActive ? 'bg-white text-gray-900 shadow-sm dark:bg-gray-600 dark:text-gray-100' : 'text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200' }}"
        >
            {{ label }}
        </a>
    {% endfor %}
</div>
