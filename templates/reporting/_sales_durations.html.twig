<div class="flex w-fit self-center sm:self-auto items-center gap-0.5 rounded-lg bg-gray-100 p-0.5 text-xs font-medium dark:bg-white/[0.06] dark:ring-1 dark:ring-white/[0.06]">
    {% set durations = { 'today': 'Today', 'last7': '7 days', 'last30': '30 days', 'mtd': 'MTD' } %}
    {% for key, label in durations %}
        {% set isActive = app.request.query.get('duration') == key or (key == 'last30' and not app.request.query.get('duration')) %}
        <a href="{{ path(app.current_route, app.request.query.all|merge({'duration': key})) }}"
           class="whitespace-nowrap rounded-md px-3 py-1.5 transition-all duration-150 active:scale-[0.97] {{ isActive ? 'bg-white text-gray-900 shadow-sm dark:bg-white/[0.12] dark:text-white dark:shadow-none' : 'text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-white dark:hover:bg-white/[0.06]' }}"
        >
            {{ label }}
        </a>
    {% endfor %}
</div>
