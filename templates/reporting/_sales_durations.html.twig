<div class="flex justify-end text-xs uppercase text-gray-700 gap-1 dark:text-gray-400">
    {% set durations = { 'today': 'TODAY', 'last7': 'LAST 7', 'last30': 'LAST 30', 'mtd': 'MTD' } %}
    {% for key, label in durations %}
        {% set isActive = app.request.query.get('duration') == key or (key == 'last30' and not app.request.query.get('duration')) %}
        <a href="{{ path(app.current_route, app.request.query.all|merge({'duration': key})) }}"
           class="rounded-lg px-2.5 py-1 transition-colors {{ isActive ? 'bg-gray-200 text-gray-900 dark:bg-gray-600 dark:text-gray-100' : 'text-gray-500 hover:bg-gray-100 dark:text-gray-400 dark:hover:bg-gray-700' }}"
        >
            {{ label }}
        </a>
    {% endfor %}
</div>
