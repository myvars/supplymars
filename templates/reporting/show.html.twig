{% extends 'base.html.twig' %}

{% block title %}Dashboard{% endblock %}

{% block body %}

    <div class="m-3">
    <turbo-frame id="reports" refresh="morph">
        <twig:Card>
            {{ include('reporting/_reports_header.html.twig', {title: 'Dashboard', isDashboard: true}) }}

            <div class="space-y-6">
                {# Order Overview Section #}
                <div>
                    <div class="mb-3 font-semibold text-gray-700 dark:text-gray-500">Order Overview</div>
                    <div class="space-y-3">
                        <div class="grid grid-cols-1 gap-px overflow-hidden rounded-lg bg-gray-900/5 dark:bg-white/5 sm:grid-cols-3">
                            <twig:KpiCard
                                title="Order Count"
                                value="{{ report.orderSalesSummary.orderCount|default(0) }}"
                                compare="{{ report.orderSalesCompareSummary.orderCount|default(null) }}"
                                valueType="count"
                                href="{{ path('app_reporting_dashboard_order_summary', {'duration': 'today'}) }}"
                                turboFrame="body"
                            />
                            <twig:KpiCard
                                title="Order Value"
                                value="{{ report.orderSalesSummary.orderValue|default(0) }}"
                                compare="{{ report.orderSalesCompareSummary.orderValue|default(null) }}"
                                valueType="currency"
                                href="{{ path('app_reporting_dashboard_order_summary', {'duration': 'today'}) }}"
                                turboFrame="body"
                            />
                            <twig:KpiCard
                                title="AOV"
                                value="{{ report.orderSalesSummary.averageOrderValue|default(0) }}"
                                compare="{{ report.orderSalesCompareSummary.averageOrderValue|default(null) }}"
                                valueType="currency"
                                href="{{ path('app_reporting_dashboard_order_summary', {'duration': 'today'}) }}"
                                turboFrame="body"
                            />
                        </div>

                        <twig:DataTable title="Today's Latest Orders">
                            {% block head %}
                                <tr>
                                    <th scope="col" class="px-6 py-3">Customer</th>
                                    <th scope="col" class="px-6 py-3">
                                        <div class="flex justify-end">Total</div>
                                    </th>
                                </tr>
                            {% endblock %}
                            {% block body %}
                                {% for order in report.latestOrders %}
                                    <tr>
                                        <th scope="row" class="whitespace-nowrap px-6 py-3 font-medium text-gray-900 dark:text-white">
                                            <a href="{{ path('app_order_show', {'id': order.publicId.value }) }}"
                                               class="dark:hover:text-white"
                                               data-turbo-frame="body"
                                            >
                                                {{ order.customer.fullName }}
                                            </a>
                                        </th>
                                        <td class="px-6 py-3 text-right">
                                            {{ order.totalPrice|default(0)|price_rounded }}
                                        </td>
                                    </tr>
                                {% endfor %}
                            {% endblock %}
                        </twig:DataTable>
                    </div>
                </div>

                {# Sales Overview Section #}
                <div>
                    <div class="mb-3 font-semibold text-gray-700 dark:text-gray-500">Sales Overview</div>
                    <div class="space-y-3">
                        <div class="grid grid-cols-1 gap-px overflow-hidden rounded-lg bg-gray-900/5 dark:bg-white/5 sm:grid-cols-3">
                            <twig:KpiCard
                                title="Sales Cost"
                                value="{{ report.productSalesSummary.salesCost|default(0) }}"
                                compare="{{ report.productSalesCompareSummary.salesCost|default(null) }}"
                                valueType="currency"
                                href="{{ path('app_reporting_dashboard_product_sales', {'duration': 'today'}) }}"
                                turboFrame="body"
                            />
                            <twig:KpiCard
                                title="Sales Profit"
                                value="{{ report.productSalesSummary.salesProfit|default(0) }}"
                                compare="{{ report.productSalesCompareSummary.salesProfit|default(null) }}"
                                valueType="currency"
                                href="{{ path('app_reporting_dashboard_product_sales', {'duration': 'today'}) }}"
                                turboFrame="body"
                            />
                            <twig:KpiCard
                                title="Gross Margin"
                                value="{{ report.productSalesSummary.salesMargin|default(0) }}"
                                compare="{{ report.productSalesCompareSummary.salesMargin|default(null) }}"
                                valueType="percentage"
                                maxFractionDigits="2"
                                href="{{ path('app_reporting_dashboard_product_sales', {'duration': 'today'}) }}"
                                turboFrame="body"
                            />
                        </div>

                        <twig:DataTable title="Today's Top Products">
                            {% block head %}
                                <tr>
                                    <th scope="col" class="px-6 py-3">Product name</th>
                                    <th scope="col" class="px-6 py-3">
                                        <div class="flex justify-end">Qty</div>
                                    </th>
                                </tr>
                            {% endblock %}
                            {% block body %}
                                {% for sale in report.latestProductSales %}
                                    <tr>
                                        <th scope="row" class="whitespace-nowrap px-6 py-3 font-medium text-gray-900 dark:text-white">
                                            <a href="{{ path('app_catalog_product_show', {'id': sale.publicId }) }}"
                                               class="dark:hover:text-white"
                                               data-turbo-frame="body"
                                            >
                                                {{ sale.name|slug.truncate(27, '...') }}
                                            </a>
                                        </th>
                                        <td class="px-6 py-3 text-right">
                                            {{ sale.salesQty }}
                                        </td>
                                    </tr>
                                {% endfor %}
                            {% endblock %}
                        </twig:DataTable>
                    </div>
                </div>

                {# Action Required Section #}
                <div>
                    <div class="mb-3 font-semibold text-gray-700 dark:text-gray-500">Action Required</div>
                    <div class="grid grid-cols-1 gap-px overflow-hidden rounded-lg bg-gray-900/5 dark:bg-white/5 sm:grid-cols-2">
                        <twig:KpiCard
                            title="Overdue Orders"
                            value="{{ report.overdueOrderSummary.orderCount|default(0) }}"
                            valueType="count"
                            href="{{ path('app_reporting_dashboard_overdue_orders', {'duration': 'last30'}) }}"
                            turboFrame="body"
                        />
                        <twig:KpiCard
                            title="Rejected POs"
                            value="{{ report.rejectedPoSummary.poCount|default(0) }}"
                            valueType="count"
                            href="{{ path('app_purchasing_purchase_order_index', {'purchaseOrderStatus': 'rejected'}) }}"
                            turboFrame="body"
                        />
                    </div>
                </div>

            </div>

        </twig:Card>
    </turbo-frame>
    </div>

{% endblock %}
