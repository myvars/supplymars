{#
    Shared header for reporting pages.

    Parameters:
    - title: The page title (required)
    - isDashboard: If true, shows title only without breadcrumb or duration filters (default: false)
    - showDurations: If true, shows duration filter buttons (default: true, ignored if isDashboard)
#}
<div class="mb-4 flex items-center justify-between">
    <div class="flex items-center gap-2">
        <twig:ux:icon name="bi:bar-chart-line-fill" class="h-4.5 w-4.5 text-gray-400 dark:text-gray-500"/>
        <span class="text-sm font-semibold text-gray-900 dark:text-white">{{ title }}</span>
    </div>
    {% if showDurations|default(true) %}
        {{ include('reporting/_sales_durations.html.twig') }}
    {% endif %}
</div>
