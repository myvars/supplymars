{% extends 'base.html.twig' %}

{% block title %}Order Dashboard{% endblock %}

{% block body %}

        <div class="m-3">
        <turbo-frame id="reports" refresh="morph">

            <twig:Card>
            {% if report.summary is not null %}
                {{ include('reporting/_reports_header.html.twig', {title: 'Order Summary'}) }}

                {{ include('reporting/_order_sales_summary.html.twig', {summary: report.summary}) }}

                {% if report.orderSalesChart %}
                    <div
                        class="mt-3 flex h-80 md:h-96 flex-wrap justify-around rounded-lg border border-gray-200/80 bg-white text-center font-light dark:border-white/[0.06] dark:bg-gray-800">
                        {{ render_chart(report.orderSalesChart, {
                            'data-controller': 'bar_chart',
                            'data-bar-chart-link-url-value': path('app_order_index'),
                            'class': 'w-full h-full'
                        }) }}
                    </div>
                {% endif %}

                {% if report.orderProgressChart %}
                    <div class="my-3 flex items-center justify-start">
                        <p class="font-medium text-gray-600 dark:text-gray-500">Order Progress</p>
                    </div>
                    <div
                        class="flex h-60 md:h-72 flex-wrap justify-around rounded-lg border border-gray-200/80 bg-white text-center font-light dark:border-white/[0.06] dark:bg-gray-800">
                        {{ render_chart(report.orderProgressChart, {
                            'data-controller': 'doughnut_chart',
                            'data-doughnut-chart-link-url-value': path('app_order_index') ~ '?orderStatus={label}&startDate=' ~ report.startDate ~ '&endDate=' ~ report.endDate,
                            'class': ''
                        }) }}
                    </div>
                {% endif %}

            {% endif %}
            </twig:Card>

        </turbo-frame>
        </div>

{% endblock %}
