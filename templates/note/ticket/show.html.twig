{% extends 'base.html.twig' %}

{% block title %}Ticket: {{ result.subject }}{% endblock %}

{% block body %}

    <div class="m-3 space-y-4">
        {{ include('note/ticket/_ticket_card.html.twig', {ticket: result}) }}

        <twig:Card>
            <div class="mb-3 flex items-center gap-2">
                <p class="text-xs font-medium uppercase tracking-wide text-gray-400 dark:text-gray-500">Conversation</p>
                <span class="ms-auto inline-flex h-5 min-w-5 items-center justify-center rounded-full bg-gray-200 px-1.5 text-xs font-medium text-gray-700 dark:bg-gray-500 dark:text-gray-200">
                    {{ result.messages|length }}
                </span>
            </div>
            {% if result.messages is empty %}
                <twig:EmptyState message="No messages yet"/>
            {% else %}
                <ol class="relative ms-4 border-s-2 border-gray-200 dark:border-gray-600">
                    {% for message in result.messages %}
                        {% if message.isSystem %}
                            {{ include('note/ticket/_feed_event.html.twig', {message: message}) }}
                        {% else %}
                            {{ include('note/ticket/_feed_comment.html.twig', {message: message, is_original: loop.first}) }}
                        {% endif %}
                    {% endfor %}
                </ol>
            {% endif %}
            {% if replyForm %}
                <div class="mt-4 border-t border-gray-200 pt-4 dark:border-gray-600">
                    <turbo-frame id="ticket-reply">
                        <p class="mb-3 text-xs font-medium uppercase tracking-wide text-gray-400 dark:text-gray-500">Reply</p>
                        {{ include('shared/form_flow/_form.html.twig', {
                            'form': replyForm,
                            'button_label': 'Send Reply',
                            'formFrame': 'ticket-reply'
                        }) }}
                    </turbo-frame>
                </div>
            {% endif %}
        </twig:Card>

        <div class="flex">
            <a href="{{ path('app_note_ticket_index') }}"
               class="inline-flex items-center gap-1 text-sm font-medium text-primary-600 hover:text-primary-700 dark:text-primary-400 dark:hover:text-primary-300"
               data-turbo-frame="body">
                <twig:ux:icon name="bi:arrow-left" class="h-3.5 w-3.5"/>
                View all tickets
            </a>
        </div>
    </div>

{% endblock %}
