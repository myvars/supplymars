{# Ticket detail card with subject, status, pool, priority, and snooze toggle.
   Used on: ticket show page. Variable: ticket (Ticket) #}
<twig:Card title="Ticket" statusHighlight="{{ ticket.status.value }}">
    <div class="space-y-3">
        <div class="flex items-start justify-between gap-3">
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white">{{ ticket.subject }}</h3>
            <div class="flex shrink-0 items-center gap-1.5">
                {% if ticket.snoozed %}
                    <span class="inline-flex items-center gap-1 rounded-md bg-amber-50 px-2 py-1 text-xs font-medium text-amber-700 inset-ring inset-ring-amber-600/20 dark:bg-amber-400/10 dark:text-amber-400 dark:inset-ring-amber-400/20">
                        <twig:ux:icon name="bi:bell-slash" class="h-3 w-3"/>
                        Snoozed
                    </span>
                {% endif %}
                <twig:StatusBadge status="{{ ticket.status.value }}"/>
                {% if not ticket.status.isClosed or ticket.snoozed %}
                    <a href="{{ path('app_note_ticket_toggle_snooze', {'id': ticket.publicId.value}) }}"
                       class="inline-flex items-center rounded p-1 text-gray-400 hover:bg-gray-100 hover:text-gray-700 dark:hover:bg-gray-700 dark:hover:text-gray-300"
                       data-turbo-frame="body"
                       data-turbo-prefetch="false"
                       title="{{ ticket.snoozed ? 'Unsnooze' : 'Snooze' }}">
                        <twig:ux:icon name="{{ ticket.snoozed ? 'bi:bell-slash' : 'bi:bell' }}" class="h-3.5 w-3.5"/>
                    </a>
                {% endif %}
                {% if not ticket.status.isClosed %}
                    <a href="{{ path('app_note_ticket_close', {'id': ticket.publicId.value}) }}"
                       class="inline-flex items-center rounded p-1 text-gray-400 hover:bg-gray-100 hover:text-gray-700 dark:hover:bg-gray-700 dark:hover:text-gray-300"
                       data-turbo-frame="body"
                       data-turbo-prefetch="false"
                       title="Close">
                        <twig:ux:icon name="bi:x-circle" class="h-3.5 w-3.5"/>
                    </a>
                {% else %}
                    <a href="{{ path('app_note_ticket_reopen', {'id': ticket.publicId.value}) }}"
                       class="inline-flex items-center rounded p-1 text-gray-400 hover:bg-gray-100 hover:text-gray-700 dark:hover:bg-gray-700 dark:hover:text-gray-300"
                       data-turbo-frame="body"
                       data-turbo-prefetch="false"
                       title="Reopen">
                        <twig:ux:icon name="bi:arrow-counterclockwise" class="h-3.5 w-3.5"/>
                    </a>
                {% endif %}
            </div>
        </div>

        <div class="border-t border-gray-200 pt-3 dark:border-gray-700">
            <dl class="grid grid-cols-[auto_1fr] gap-x-6 gap-y-2.5 text-sm">
                <dt class="text-gray-500 dark:text-gray-400">Customer</dt>
                <dd class="text-gray-900 dark:text-white">{{ ticket.customer.fullName }}</dd>
                <dt class="text-gray-500 dark:text-gray-400">Pool</dt>
                <dd class="flex items-center gap-2">
                    <a href="{{ path('app_note_pool_show', {'id': ticket.pool.publicId.value }) }}"
                       class="font-medium text-primary-600 hover:text-primary-700 dark:text-primary-400 dark:hover:text-primary-300"
                       data-turbo-frame="body">
                        {{ ticket.pool.name }}
                    </a>
                    <a href="{{ path('app_note_ticket_reassign', {'id': ticket.publicId.value}) }}"
                       class="inline-flex items-center gap-0.5 rounded px-1.5 py-0.5 text-xs text-gray-500 hover:bg-gray-100 hover:text-gray-700 dark:text-gray-400 dark:hover:bg-gray-700 dark:hover:text-gray-300"
                       data-turbo-frame="modal"
                       data-turbo-prefetch="false">
                        <twig:ux:icon name="bi:arrow-left-right" class="h-3 w-3"/>
                        Reassign
                    </a>
                </dd>
                <dt class="text-gray-500 dark:text-gray-400">Created</dt>
                <dd class="text-gray-900 dark:text-white">{{ ticket.createdAt|ago }}</dd>
            </dl>
        </div>
    </div>
</twig:Card>
