{# Pool detail page — composes _pool_card and subscription toggle.
   Variable: result (Pool), is_subscribed (bool) #}
{% extends 'base.html.twig' %}

{% block title %}Pool Details{% endblock %}

{% block body %}

    <div class="m-3 space-y-4">
        <twig:Breadcrumb :href="path('app_note_pool_index')" label="Pools" :current="result.name"/>
        {{ include('note/pool/_pool_card.html.twig', {pool: result}) }}

        <twig:Card title="Subscription">
            <div class="flex items-center justify-between">
                <p class="text-sm text-gray-600 dark:text-gray-400">
                    {{ is_subscribed ? 'You are subscribed to this pool.' : 'You are not subscribed to this pool.' }}
                </p>
                <a href="{{ path('app_note_pool_toggle_subscription', {'id': result.publicId.value}) }}"
                   class="inline-flex items-center gap-1 rounded-md px-3 py-1.5 text-sm font-medium {{ is_subscribed ? 'bg-gray-100 text-gray-700 hover:bg-gray-200 dark:bg-gray-700 dark:text-gray-300 dark:hover:bg-gray-600' : 'bg-primary-600 text-white hover:bg-primary-500 dark:bg-primary-500 dark:hover:bg-primary-400' }}"
                   data-turbo-frame="body"
                   data-turbo-prefetch="false">
                    <twig:ux:icon name="{{ is_subscribed ? 'bi:bell-slash' : 'bi:bell' }}" class="h-4 w-4"/>
                    {{ is_subscribed ? 'Unsubscribe' : 'Subscribe' }}
                </a>
            </div>
        </twig:Card>

    </div>

{% endblock %}
