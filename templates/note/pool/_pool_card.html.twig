{# Pool detail card with name, description, and active status.
   Used on: pool show page. Variable: pool (Pool) #}
<twig:Card editLink="{{ path('app_note_pool_edit', {'id': pool.publicId.value }) }}" title="Pool" statusHighlight="{{ pool.isActive ? 'ACTIVE' : 'INACTIVE' }}">
    <p class="mb-1 text-lg font-semibold text-gray-900 dark:text-white">{{ pool.name }}</p>
    {% if pool.description %}
        <p class="mb-2 text-sm text-gray-500 dark:text-gray-400">{{ pool.description }}</p>
    {% endif %}
    <div class="mb-2 flex items-center gap-2">
        {% if pool.customerVisible %}
            <span class="inline-flex items-center rounded-md bg-blue-50 px-2 py-1 text-xs font-medium text-blue-700 inset-ring inset-ring-blue-700/10 dark:bg-blue-400/10 dark:text-blue-400 dark:inset-ring-blue-400/20">Customer Visible</span>
        {% else %}
            <span class="inline-flex items-center rounded-md bg-gray-50 px-2 py-1 text-xs font-medium text-gray-600 inset-ring inset-ring-gray-500/10 dark:bg-gray-400/10 dark:text-gray-400 dark:inset-ring-gray-400/20">Internal Only</span>
        {% endif %}
    </div>
    <twig:CardFooter :updatedAt="pool.updatedAt">
        <twig:StatusBadge status="{{ pool.isActive ? 'ACTIVE' : 'INACTIVE' }}"/>
    </twig:CardFooter>
</twig:Card>
