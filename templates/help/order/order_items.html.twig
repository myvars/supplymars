{% extends 'help/_layout.html.twig' %}

{% block title %}Order Items{% endblock %}

{% block content %}
    <p class="text-gray-500 dark:text-gray-400">
        Order items are the individual products within an order. They track quantity, price, and allocation to supplier purchase orders.
    </p>

    <h3 class="text-xs font-semibold uppercase tracking-wide text-gray-400 dark:text-gray-500">What You Can Do</h3>
    <ul class="list-disc pl-5 space-y-1">
        <li>Edit quantity and price</li>
        <li>Cancel unallocated items</li>
        <li>Manually allocate to specific suppliers</li>
        <li>View supplier options and costs</li>
    </ul>

    <h3 class="text-xs font-semibold uppercase tracking-wide text-gray-400 dark:text-gray-500">Outstanding Quantity</h3>
    <p>Tracks how many units still need to be allocated to a supplier. Calculated as total quantity minus allocated quantity.</p>

    <twig:Alert type="warning">
        You cannot reduce an item's quantity below the amount already allocated to purchase orders.
    </twig:Alert>

    <h3 class="text-xs font-semibold uppercase tracking-wide text-gray-400 dark:text-gray-500">Related</h3>
    <div class="flex flex-wrap gap-2">
        <a href="{{ path('app_help_direct', { key: 'order/orders', from: 'order/order_items' }) }}" data-turbo-frame="help" class="rounded-full bg-gray-100 px-3 py-1 text-xs font-medium text-gray-600 transition-colors hover:bg-gray-200 dark:bg-gray-800 dark:text-gray-300 dark:hover:bg-gray-700">Orders</a>
        <a href="{{ path('app_help_direct', { key: 'purchasing/purchase_orders', from: 'order/order_items' }) }}" data-turbo-frame="help" class="rounded-full bg-gray-100 px-3 py-1 text-xs font-medium text-gray-600 transition-colors hover:bg-gray-200 dark:bg-gray-800 dark:text-gray-300 dark:hover:bg-gray-700">Purchase Orders</a>
    </div>
{% endblock %}
