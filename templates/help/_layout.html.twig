<turbo-frame id="help" class="flex flex-1 flex-col overflow-hidden">
    <div class="flex shrink-0 items-center justify-between border-b border-gray-200 px-5 py-4 dark:border-white/[0.06]">
        <div class="flex items-center gap-2">
            {% if from is defined and from %}
                <a href="{{ path('app_help_direct', { key: from }) }}"
                   data-turbo-frame="help"
                   class="inline-flex items-center justify-center rounded-md p-1 text-gray-400 transition-colors hover:bg-gray-100 hover:text-gray-600 dark:hover:bg-gray-700 dark:hover:text-white"
                   aria-label="Back"
                >
                    <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
                </a>
            {% endif %}
            <h2 class="text-base font-semibold text-gray-900 dark:text-gray-100">{% block title %}Help{% endblock %}</h2>
        </div>
        <button type="button"
                class="inline-flex items-center rounded-lg p-1.5 text-sm text-gray-400 transition-colors hover:bg-gray-200 hover:text-gray-900 dark:hover:bg-gray-700 dark:hover:text-white"
                data-action="help-drawer#close"
                aria-label="Close help"
        >
            <svg aria-hidden="true" class="h-5 w-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
        </button>
    </div>
    <div class="flex-1 overflow-y-auto px-5 py-4 space-y-4 text-sm text-gray-600 dark:text-gray-300">
        {% block content %}{% endblock %}
    </div>
</turbo-frame>
