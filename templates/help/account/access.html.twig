{% extends 'help/_layout.html.twig' %}

{% block title %}Account & Access{% endblock %}

{% block content %}
    <p class="text-gray-500 dark:text-gray-400">
        How to log in, create an account, and recover access to SupplyMars.
    </p>

    <h3 class="text-xs font-semibold uppercase tracking-wide text-gray-400 dark:text-gray-500">Logging In</h3>
    <ul class="list-disc pl-5 space-y-1">
        <li>Enter your email address and password</li>
        <li>Your session lasts 7 days — you won't need to log in each visit</li>
        <li>Your email must be verified before you can log in</li>
    </ul>

    <h3 class="text-xs font-semibold uppercase tracking-wide text-gray-400 dark:text-gray-500">Creating an Account</h3>
    <ul class="list-disc pl-5 space-y-1">
        <li>Enter your name, email, and a password (minimum 6 characters)</li>
        <li>Accept the Terms & Conditions</li>
        <li>A verification email is sent — click the link to activate your account</li>
    </ul>

    <h3 class="text-xs font-semibold uppercase tracking-wide text-gray-400 dark:text-gray-500">Forgot Your Password?</h3>
    <ol class="list-decimal pl-5 space-y-1">
        <li>Click "Forgot your password?" on the login page</li>
        <li>Enter your email address</li>
        <li>Check your inbox (and spam folder) for a reset link</li>
        <li>Click the link and set a new password</li>
    </ol>

    <h3 class="text-xs font-semibold uppercase tracking-wide text-gray-400 dark:text-gray-500">Email Verification</h3>
    <p>If your account is unverified, check your email for the verification link. You can request a new one from the login page. If problems persist, contact your administrator.</p>

    <twig:Alert type="info">
        For security, the system does not reveal whether an account exists when requesting a password reset.
    </twig:Alert>
{% endblock %}
