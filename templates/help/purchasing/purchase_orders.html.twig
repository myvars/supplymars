{% extends 'help/_layout.html.twig' %}

{% block title %}Purchase Orders{% endblock %}

{% block content %}
    <p class="text-gray-500 dark:text-gray-400">
        Purchase orders (POs) are placed with suppliers to fulfil customer orders. Each PO tracks items through an 8-stage status lifecycle.
    </p>

    <h3 class="text-xs font-semibold uppercase tracking-wide text-gray-400 dark:text-gray-500">What You Can Do</h3>
    <ul class="list-disc pl-5 space-y-1">
        <li>View POs with status, supplier, and date filters</li>
        <li>Edit item quantities (Pending status only)</li>
        <li>Advance item status through the fulfilment workflow</li>
        <li>Rewind a PO back to Pending for error recovery</li>
    </ul>

    <h3 class="text-xs font-semibold uppercase tracking-wide text-gray-400 dark:text-gray-500">Typical Workflow</h3>
    <p>Pending → Processing → Accepted → Shipped → Delivered</p>

    <h3 class="text-xs font-semibold uppercase tracking-wide text-gray-400 dark:text-gray-500">Rejection Flow</h3>
    <p>If a supplier rejects, the item moves to Rejected → Refunded, and the system re-allocates to an alternative supplier.</p>

    <twig:Alert type="warning">
        Delivered and Cancelled are terminal states. Rewind clears the status history permanently.
    </twig:Alert>

    <twig:Alert type="info">
        Item quantities can only be edited when the PO is in Pending status. Setting quantity to 0 removes the item.
    </twig:Alert>

    <h3 class="text-xs font-semibold uppercase tracking-wide text-gray-400 dark:text-gray-500">Related</h3>
    <div class="flex flex-wrap gap-2">
        <a href="{{ path('app_help_direct', { key: 'order/orders', from: 'purchasing/purchase_orders' }) }}" data-turbo-frame="help" class="rounded-full bg-gray-100 px-3 py-1 text-xs font-medium text-gray-600 transition-colors hover:bg-gray-200 dark:bg-gray-800 dark:text-gray-300 dark:hover:bg-gray-700">Orders</a>
        <a href="{{ path('app_help_direct', { key: 'purchasing/suppliers', from: 'purchasing/purchase_orders' }) }}" data-turbo-frame="help" class="rounded-full bg-gray-100 px-3 py-1 text-xs font-medium text-gray-600 transition-colors hover:bg-gray-200 dark:bg-gray-800 dark:text-gray-300 dark:hover:bg-gray-700">Suppliers</a>
    </div>
{% endblock %}
