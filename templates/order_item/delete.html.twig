{% extends 'modalBase.html.twig' %}

{% block title %}Delete {{ section|title }}{% endblock %}

{% block body %}
    <div class="relative p-3 bg-white rounded-lg shadow dark:bg-gray-800">
        <div class="flex justify-between items-center pb-3 mb-3 rounded-t border-b dark:border-gray-600">
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white">
                Delete {{ section }}
            </h3>
        </div>
        <div class="space-y-3 md:space-y-3">

            <div class="flex items-center">
                <p class="me-5 text-xs">
                    {% if result.product.productImages|length > 0 %}
                        {% set firstImage = result.product.productImages|first %}
                        <img class="w-auto rounded-lg"
                             src="{{ asset(product_uploads~firstImage.imageName) | imagine_filter('my_thumbnail') }}"
                             alt=""
                        >
                    {% else %}
                        <span class="flex text-center">no image</span>
                    {% endif %}
                </p>
                <p class="text-base text-gray-500 dark:text-white">
                    {{ result.product.name }}
                </p>
            </div>
            <p class="text-sm font-light text-gray-500 dark:text-gray-400">
                Are you sure you want to delete this {{ section }}?
            </p>
            <form method="post" action="{{ path('app_order_item_delete', {'id': result.id}) }}">
                <input type="hidden" name="_token" value="{{ csrf_token('delete'~result.id) }}">
                <twig:Button type="submit" variant="danger" class="w-full">Delete</twig:Button>
            </form>
            <p class="text-sm font-light text-gray-500 dark:text-gray-400">
                <a href="{{ path('app_order_show', {'id': result.customerOrder.id}) }}" class="hover:underline">Back to order</a>
            </p>
        </div>
    </div>
{% endblock %}