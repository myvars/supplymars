<twig:Card editLink="{{ path('app_subcategory_edit', { id: subcategory.id }) }}" title="Subcategory">
    <p class="mb-1 text-xl text-gray-900 dark:text-white">{{ subcategory.name|u.truncate(30, '...') }}</p>
    <nav class="flex mb-2" aria-label="Breadcrumb">
        <ol class="inline-flex items-center space-x-1 md:space-x-2">
            <li>
                <div class="flex items-center">
                    <a href="{{ path('app_category_show', {id: subcategory.category.id}) }}"
                       data-turbo-frame="body"
                       class="text-gray-700 hover:text-blue-600 dark:text-gray-400 dark:hover:text-white">
                        {{ subcategory.category.name|u.truncate(30, '...') }}
                    </a>
                </div>
            </li>
            <li aria-current="page">
                <div class="flex items-center">
                    >>
                    <p class="ms-1 md:ms-2 text-sm text-gray-700 dark:text-gray-400">
                        {{ subcategory.name|u.truncate(30, '...') }}
                    </p>
                </div>
            </li>
        </ol>
    </nav>
    {% if subcategory.hasDefaultMarkup %}
    <p class="text-lg font-extralight">
        {{ subcategory.defaultMarkup|number_format(3) }}%
        <span class="text-sm font-normal"> mark-up</span>
    </p>
{% else %}
    <p class="font-extralight">No subcategory mark-up
        {% endif %}
        {% if subcategory.hasPriceModel %}
    <p class="mb-3 font-extralight">{{ subcategory.priceModel.getName }} price model</p>
{% else %}
    <p class="mb-3 font-extralight">No price model</p>
    {% endif %}
    {% if subcategory.hasOwner %}
        <p>Managed by {{ subcategory.owner.fullName }}</p>
    {% else %}
        <p>No subcategory manager</p>
    {% endif %}
    <div class="mt-3 flex items-center justify-between">
        <p class="me-10 text-xs text-gray-600 dark:text-gray-500">Updated {{ subcategory.updatedAt|ago }}</p>
        {% if subcategory.isActive %}
            <p class="text-green-500">Active</p>
        {% else %}
            <p class="text-red-500">InActive</p>
        {% endif %}
    </div>
</twig:Card>