{% extends 'base.html.twig' %}

{% block title %}About Us{% endblock %}

{% block body %}
    <div data-controller="aos">
        <section class="mx-auto flex items-center justify-center bg-white dark:bg-orange-400/10 h-screen" style="background: url({{ asset('images/martian_landscape.webp') }}) center center no-repeat; background-size: cover;">
            <div class="mx-auto max-w-(--breakpoint-xl) px-4 py-8 sm:py-12 lg:px-6">
                <div class="mb-10 max-w-(--breakpoint-md) dark:text-white" data-aos="fade-up" data-aos-duration="800">
                    <h2 class="mb-8 text-3xl tracking-tight">Contact Us</h2>
                    <p class="mb-4 text-base">
                        Have questions or want to know more about {{ domain }}? Feel free to reach out. Whether you’re curious about the technologies behind the project, want to explore potential collaborations, or simply want to say hi, we’d love to hear from you!
                    </p>
                    <p class="mb-4 text-base">
                        Use the contact link below, and we’ll get back to you as soon as possible.
                    </p>
                </div>
                <div class="mt-8 flex items-center justify-center" data-aos="fade-up" data-aos-delay="200" data-aos-duration="800">
                    <twig:Button
                        tag="a"
                        href="mailto:adamashmore@me.com"
                        class="flex items-center font-bold space-x-1"
                        variant="secondary"
                    >
                        <span>Contact Us</span>
                    </twig:Button>
                </div>
            </div>
        </section>
    </div>
{% endblock %}
