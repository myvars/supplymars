{% extends 'base.html.twig' %}

{% block title %}Contact Us{% endblock %}

{% block body %}
    <div data-controller="aos">
        <section class="mx-auto flex items-center justify-center min-h-[60vh]" style="background: url({{ asset('images/martian_landscape.webp') }}) center center no-repeat; background-size: cover;">
            <div class="mx-auto max-w-(--breakpoint-xl) px-4 py-8 sm:py-12 lg:px-6">
                <div class="max-w-(--breakpoint-md) rounded-2xl bg-white/90 p-8 backdrop-blur-sm dark:bg-gray-900/80 lg:p-10" data-aos="fade-up" data-aos-duration="800">
                    <div class="mb-4 flex justify-center">
                        <twig:ux:icon name="bi:envelope-fill" class="h-10 w-10 text-orange-500" />
                    </div>
                    <h2 class="mb-8 text-center text-3xl tracking-tight text-gray-900 dark:text-white">Contact Us</h2>
                    <p class="mb-4 text-gray-700 dark:text-gray-300">
                        {{ domain|title }} is built and maintained by Adam Ashmore. Whether you're curious about the technologies behind the project, want to explore potential collaborations, or simply want to say hi, feel free to reach out.
                    </p>
                    <p class="mb-4 text-gray-700 dark:text-gray-300">
                        You can also find the full source code, documentation, and issue tracker on GitHub.
                    </p>
                    <div class="mt-8 flex flex-wrap items-center justify-center gap-4" data-aos="fade-up" data-aos-delay="200" data-aos-duration="800">
                        <twig:Button
                            tag="a"
                            href="mailto:adamashmore@me.com"
                            class="flex items-center font-bold space-x-1"
                            variant="secondary"
                        >
                            <twig:ux:icon name="bi:envelope-fill" class="h-5 w-5" />
                            <span>Email</span>
                        </twig:Button>
                        <twig:Button
                            tag="a"
                            href="https://github.com/myvars/supplymars"
                            target="_blank"
                            class="flex items-center font-bold space-x-1"
                            variant="secondary"
                        >
                            <twig:ux:icon name="bi:github" class="h-5 w-5" />
                            <span>GitHub</span>
                        </twig:Button>
                    </div>
                </div>
            </div>
        </section>
    </div>
{% endblock %}
