{% extends 'base.html.twig' %}

{% block title %}Welcome{% endblock %}

{% block main_class %}grow bg-gray-950{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="preload" as="image" href="{{ asset('images/martian_landscape.webp') }}" fetchpriority="high">
{% endblock %}

{% block body %}
    <div data-controller="aos">

    {# ── Hero ────────────────────────────────────────────────────────────── #}
    <section class="relative overflow-hidden">
        <div class="absolute inset-0"
             style="background: url({{ asset('images/martian_landscape.webp') }}) center center no-repeat; background-size: cover;">
        </div>
        <div class="absolute inset-0 bg-gradient-to-b from-gray-950/70 via-gray-950/40 to-gray-950"></div>
        <div class="absolute inset-0 bg-[radial-gradient(ellipse_60%_40%_at_50%_35%,rgba(249,115,22,0.06),transparent)]"></div>

        {# Copy #}
        <div class="relative text-center px-6 pt-28 sm:pt-36 lg:pt-44 pb-16 sm:pb-20 lg:pb-24 max-w-3xl mx-auto">
            <p class="text-sm font-semibold uppercase tracking-widest text-orange-500 mb-6 lg:mb-8 hero-fade-down">
                E-commerce Demo Platform
            </p>
            <h1 class="text-4xl sm:text-5xl lg:text-7xl font-bold tracking-tight text-white mb-6 lg:mb-8 hero-fade-down"
                style="animation-delay: 0.1s">
                Commerce, built for
                <span class="text-transparent bg-clip-text bg-gradient-to-r from-orange-400 to-amber-500">Mars</span>
            </h1>
            <p class="text-base sm:text-lg lg:text-xl text-gray-400 max-w-2xl mx-auto mb-10 lg:mb-12 hero-fade-up"
               style="animation-delay: 0.3s">
                Multi-supplier sourcing. Dynamic pricing. Full order lifecycle.<br class="hidden sm:inline">
                All operational.
            </p>
            <div class="flex flex-col sm:flex-row items-center justify-center gap-3 sm:gap-4 w-full sm:w-auto hero-fade-up" style="animation-delay: 0.5s">
                <a href="{{ path('app_catalog_product_index') }}"
                   class="inline-flex items-center justify-center gap-2 w-full sm:w-auto px-7 py-3 text-sm sm:text-base font-semibold text-white bg-orange-500 hover:bg-orange-400 rounded-lg shadow-lg shadow-orange-500/25 transition-all duration-200 active:scale-[0.98]"
                   data-turbo-prefetch="false">
                    Explore the Platform
                </a>
                <a href="https://github.com/myvars/supplymars"
                   target="_blank"
                   class="inline-flex items-center justify-center gap-2 w-full sm:w-auto px-7 py-3 text-sm sm:text-base font-semibold text-gray-300 bg-white/[0.06] hover:bg-white/[0.1] rounded-lg ring-1 ring-white/[0.1] hover:ring-white/[0.18] backdrop-blur-sm transition-all duration-200 active:scale-[0.98]">
                    <twig:ux:icon name="bi:github" class="h-5 w-5" />
                    View on GitHub
                </a>
            </div>
        </div>

        {# Floating UI Preview #}
        <div class="relative w-full max-w-5xl mx-auto px-6 sm:px-10 pb-16 sm:pb-20 hero-fade-up" style="animation-delay: 0.7s; perspective: 1200px">
            <div class="absolute -inset-12 bg-gradient-to-t from-orange-500/[0.12] via-amber-500/[0.06] to-transparent rounded-[2.5rem] blur-3xl pointer-events-none"></div>
            <a href="{{ path('app_catalog_product_index') }}"
               class="group relative block rounded-2xl overflow-hidden shadow-2xl shadow-black/60 ring-1 ring-white/[0.08] transition-all duration-500 hover:shadow-orange-500/[0.08] hover:ring-white/[0.14]"
               style="transform: rotateX(2deg); transform-origin: bottom center"
               data-turbo-prefetch="false">
                <div class="bg-[#1a1d23] px-3 sm:px-4 py-2.5 sm:py-3 flex items-center gap-2 sm:gap-3 border-b border-white/[0.06]">
                    <div class="flex gap-1.5 sm:gap-2">
                        <div class="w-2.5 h-2.5 sm:w-3 sm:h-3 rounded-full bg-[#ff5f57]"></div>
                        <div class="w-2.5 h-2.5 sm:w-3 sm:h-3 rounded-full bg-[#febc2e]"></div>
                        <div class="w-2.5 h-2.5 sm:w-3 sm:h-3 rounded-full bg-[#28c840]"></div>
                    </div>
                    <div class="flex-1 mx-2 sm:mx-4">
                        <div class="bg-black/30 rounded-md px-3 py-1 text-center text-xs text-gray-500 font-mono">{{ domain }}/products</div>
                    </div>
                </div>
                <div class="relative overflow-hidden max-h-[220px] sm:max-h-[320px] lg:max-h-[420px]">
                    <img src="{{ asset('images/Product-Catalog.webp') }}"
                         alt="Product catalog showing product details, pricing, and sales analytics"
                         class="w-full object-cover object-top transition-transform duration-700 group-hover:scale-[1.02]"
                         loading="eager">
                    <div class="absolute inset-x-0 bottom-0 h-32 bg-gradient-to-t from-gray-950 to-transparent pointer-events-none"></div>
                </div>
            </a>
        </div>
    </section>

    {# ── The Pitch ───────────────────────────────────────────────────────── #}
    <section id="the-pitch" class="relative bg-gray-950 py-24 lg:py-32 scroll-mt-6 overflow-hidden">
        <div class="absolute inset-0 bg-[radial-gradient(ellipse_60%_40%_at_50%_50%,rgba(249,115,22,0.04),transparent)]"></div>

        <div class="relative mx-auto max-w-3xl px-6 text-center">
            <p class="text-sm font-semibold uppercase tracking-widest text-orange-500 mb-4" data-aos="fade-up">The Vision</p>
            <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight text-white mb-8"
                data-aos="fade-up" data-aos-delay="50" data-aos-duration="600">
                Pioneering Commerce Beyond Earth
            </h2>
            <p class="text-lg sm:text-xl text-gray-400 leading-relaxed mb-6" data-aos="fade-up" data-aos-delay="100">
                Whether you're managing a Martian colony or stocking up for your next extravehicular adventure,
                {{ domain|title }} is your destination for everything from habitat maintenance to cutting-edge scientific equipment.
            </p>
            <p class="text-lg sm:text-xl text-gray-400 leading-relaxed" data-aos="fade-up" data-aos-delay="200">
                It's also a fully functional demo built to show what modern PHP e-commerce actually looks like
                &mdash; real operational complexity, not just add-to-cart basics.
            </p>
        </div>
    </section>

    {# ── Core Platform ────────────────────────────────────────────────────── #}
    <section class="relative bg-gray-900 py-24 lg:py-32 overflow-hidden">
        <div class="absolute inset-0 bg-[radial-gradient(ellipse_80%_50%_at_50%_0%,rgba(120,119,198,0.04),transparent)]"></div>

        <div class="relative mx-auto max-w-(--breakpoint-xl) px-6">
            <div class="mb-16 lg:mb-20 text-center" data-aos="fade-up">
                <p class="text-sm font-semibold uppercase tracking-widest text-orange-500 mb-4">The Platform</p>
                <h2 class="text-3xl sm:text-4xl font-bold tracking-tight text-white">
                    Built for Modern E-commerce
                </h2>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
                <div class="group rounded-xl bg-gray-800/40 ring-1 ring-white/[0.06] p-8 text-center transition-all duration-300 hover:bg-gray-800/60 hover:ring-white/[0.1]" data-aos="fade-up" data-aos-delay="0">
                    <div class="mx-auto mb-5 flex h-14 w-14 items-center justify-center rounded-xl bg-orange-500/10">
                        <twig:ux:icon name="bi:box-seam-fill" class="h-7 w-7 text-orange-400" />
                    </div>
                    <h3 class="text-lg font-semibold text-white mb-2">Product Catalog</h3>
                    <p class="text-sm text-gray-400 leading-relaxed">
                        Structured catalogue with hierarchical categories, rich product pages, image galleries, and manufacturer tracking across the full inventory.
                    </p>
                </div>

                <div class="group rounded-xl bg-gray-800/40 ring-1 ring-white/[0.06] p-8 text-center transition-all duration-300 hover:bg-gray-800/60 hover:ring-white/[0.1]" data-aos="fade-up" data-aos-delay="50">
                    <div class="mx-auto mb-5 flex h-14 w-14 items-center justify-center rounded-xl bg-violet-500/10">
                        <twig:ux:icon name="bi:truck" class="h-7 w-7 text-violet-400" />
                    </div>
                    <h3 class="text-lg font-semibold text-white mb-2">Supplier Network</h3>
                    <p class="text-sm text-gray-400 leading-relaxed">
                        Multi-supplier sourcing per product with cost comparison, real-time stock visibility, and automated best-source selection.
                    </p>
                </div>

                <div class="group rounded-xl bg-gray-800/40 ring-1 ring-white/[0.06] p-8 text-center transition-all duration-300 hover:bg-gray-800/60 hover:ring-white/[0.1]" data-aos="fade-up" data-aos-delay="100">
                    <div class="mx-auto mb-5 flex h-14 w-14 items-center justify-center rounded-xl bg-blue-500/10">
                        <twig:ux:icon name="bi:bag-check-fill" class="h-7 w-7 text-blue-400" />
                    </div>
                    <h3 class="text-lg font-semibold text-white mb-2">Order Management</h3>
                    <p class="text-sm text-gray-400 leading-relaxed">
                        End-to-end order lifecycle with line-item tracking, automatic supplier allocation, and order splitting across multiple sources.
                    </p>
                </div>

                <div class="group rounded-xl bg-gray-800/40 ring-1 ring-white/[0.06] p-8 text-center transition-all duration-300 hover:bg-gray-800/60 hover:ring-white/[0.1]" data-aos="fade-up" data-aos-delay="150">
                    <div class="mx-auto mb-5 flex h-14 w-14 items-center justify-center rounded-xl bg-cyan-500/10">
                        <twig:ux:icon name="bi:clipboard2-data-fill" class="h-7 w-7 text-cyan-400" />
                    </div>
                    <h3 class="text-lg font-semibold text-white mb-2">Purchase Orders</h3>
                    <p class="text-sm text-gray-400 leading-relaxed">
                        Demand-driven purchase orders with full state-machine lifecycle — from allocation through acceptance, shipping, and delivery.
                    </p>
                </div>

                <div class="group rounded-xl bg-gray-800/40 ring-1 ring-white/[0.06] p-8 text-center transition-all duration-300 hover:bg-gray-800/60 hover:ring-white/[0.1]" data-aos="fade-up" data-aos-delay="200">
                    <div class="mx-auto mb-5 flex h-14 w-14 items-center justify-center rounded-xl bg-emerald-500/10">
                        <twig:ux:icon name="bi:currency-pound" class="h-7 w-7 text-emerald-400" />
                    </div>
                    <h3 class="text-lg font-semibold text-white mb-2">Pricing Engine</h3>
                    <p class="text-sm text-gray-400 leading-relaxed">
                        Three-level markup cascades across product, subcategory, and category with multiple pricing models, VAT management, and event-driven recalculation.
                    </p>
                </div>

                <div class="group rounded-xl bg-gray-800/40 ring-1 ring-white/[0.06] p-8 text-center transition-all duration-300 hover:bg-gray-800/60 hover:ring-white/[0.1]" data-aos="fade-up" data-aos-delay="250">
                    <div class="mx-auto mb-5 flex h-14 w-14 items-center justify-center rounded-xl bg-amber-500/10">
                        <twig:ux:icon name="bi:bar-chart-line-fill" class="h-7 w-7 text-amber-400" />
                    </div>
                    <h3 class="text-lg font-semibold text-white mb-2">Reporting &amp; Analytics</h3>
                    <p class="text-sm text-gray-400 leading-relaxed">
                        Revenue, margin, and operational dashboards powered by two-layer aggregation — daily granular records rolled into pre-computed summaries.
                    </p>
                </div>
            </div>
        </div>
    </section>

    {# ── Operational Complexity ──────────────────────────────────────────── #}
    <section class="relative bg-gray-950 py-24 lg:py-32 overflow-hidden">
        <div class="absolute inset-0 bg-[radial-gradient(ellipse_70%_50%_at_0%_50%,rgba(249,115,22,0.03),transparent)]"></div>

        <div class="relative mx-auto max-w-(--breakpoint-xl) px-6">
            <div class="mb-16 lg:mb-20" data-aos="fade-up">
                <p class="text-sm font-semibold uppercase tracking-widest text-orange-500 mb-4">What's Under the Hood</p>
                <h2 class="text-3xl sm:text-4xl font-bold tracking-tight text-white max-w-xl">
                    Real Operational Complexity
                </h2>
            </div>

            <div class="divide-y divide-white/[0.06]">
                <div class="flex flex-col sm:flex-row items-start gap-6 sm:gap-10 pb-12 lg:pb-16" data-aos="fade-up" data-aos-delay="0">
                    <span class="text-6xl sm:text-7xl font-bold text-gray-800/80 leading-none shrink-0 tabular-nums">01</span>
                    <div>
                        <h3 class="text-xl sm:text-2xl font-semibold text-white mb-3">Multi-supplier Sourcing</h3>
                        <p class="text-gray-400 max-w-xl leading-relaxed">
                            Each product aggregates multiple suppliers. A best-source algorithm selects the lowest-cost option with available stock, keeping allocation optimal as prices and inventory shift.
                        </p>
                    </div>
                </div>

                <div class="flex flex-col sm:flex-row items-start gap-6 sm:gap-10 py-12 lg:py-16" data-aos="fade-up" data-aos-delay="100">
                    <span class="text-6xl sm:text-7xl font-bold text-gray-800/80 leading-none shrink-0 tabular-nums">02</span>
                    <div>
                        <h3 class="text-xl sm:text-2xl font-semibold text-white mb-3">Dynamic Pricing Cascades</h3>
                        <p class="text-gray-400 max-w-xl leading-relaxed">
                            Markup rules cascade from category down to individual product, with six pricing strategies. When supplier costs change, sell prices recalculate automatically via domain events.
                        </p>
                    </div>
                </div>

                <div class="flex flex-col sm:flex-row items-start gap-6 sm:gap-10 py-12 lg:py-16" data-aos="fade-up" data-aos-delay="200">
                    <span class="text-6xl sm:text-7xl font-bold text-gray-800/80 leading-none shrink-0 tabular-nums">03</span>
                    <div>
                        <h3 class="text-xl sm:text-2xl font-semibold text-white mb-3">Order Line Splitting</h3>
                        <p class="text-gray-400 max-w-xl leading-relaxed">
                            When no single supplier can fulfil the required quantity, order lines split across multiple sources automatically. Overall order status derives from the lifecycle of each resulting purchase order.
                        </p>
                    </div>
                </div>

                <div class="flex flex-col sm:flex-row items-start gap-6 sm:gap-10 py-12 lg:py-16" data-aos="fade-up" data-aos-delay="300">
                    <span class="text-6xl sm:text-7xl font-bold text-gray-800/80 leading-none shrink-0 tabular-nums">04</span>
                    <div>
                        <h3 class="text-xl sm:text-2xl font-semibold text-white mb-3">Purchase Order Lifecycle</h3>
                        <p class="text-gray-400 max-w-xl leading-relaxed">
                            Purchase orders follow a state-machine lifecycle — allocated, accepted, shipped, delivered. Each transition propagates domain events that update order statuses, stock levels, and reporting.
                        </p>
                    </div>
                </div>

                <div class="flex flex-col sm:flex-row items-start gap-6 sm:gap-10 pt-12 lg:pt-16" data-aos="fade-up" data-aos-delay="400">
                    <span class="text-6xl sm:text-7xl font-bold text-gray-800/80 leading-none shrink-0 tabular-nums">05</span>
                    <div>
                        <h3 class="text-xl sm:text-2xl font-semibold text-white mb-3">Simulation Engine</h3>
                        <p class="text-gray-400 max-w-xl leading-relaxed">
                            Console commands simulate the full business cycle — orders, supplier fulfilment, stock fluctuation, and reporting aggregation — producing realistic data without manual setup.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    {# ── Tech Stack ──────────────────────────────────────────────────────── #}
    <section class="relative bg-gray-900 py-24 lg:py-32 overflow-hidden">
        <div class="absolute inset-0 bg-[radial-gradient(ellipse_80%_50%_at_50%_100%,rgba(120,119,198,0.04),transparent)]"></div>

        <div class="relative mx-auto max-w-(--breakpoint-xl) px-6">
            <div class="mb-16 lg:mb-20 text-center" data-aos="fade-up">
                <p class="text-sm font-semibold uppercase tracking-widest text-orange-500 mb-4">Built With</p>
                <h2 class="text-3xl sm:text-4xl font-bold tracking-tight text-white">
                    Modern Stack, Proven Patterns
                </h2>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8">
                <div class="group rounded-xl border-l-4 border-orange-500 bg-gray-800/50 p-8 ring-1 ring-white/[0.04] transition-all duration-300 hover:bg-gray-800/70 hover:ring-white/[0.08] hover:shadow-lg hover:shadow-black/20"
                     data-aos="fade-up" data-aos-delay="0" data-aos-duration="400">
                    <div class="mb-4 flex h-14 w-14 items-center justify-center rounded-xl bg-orange-500/10">
                        <twig:ux:icon name="bi:diagram-3-fill" class="h-7 w-7 text-orange-500" />
                    </div>
                    <h3 class="mb-3 text-xl font-semibold text-white">DDD Architecture</h3>
                    <p class="text-gray-400 leading-relaxed">
                        A modular monolith where each area of the business owns its own logic. Commands and queries stay separate. Contexts communicate through domain events, not tangled dependencies.
                    </p>
                </div>

                <div class="group rounded-xl border-l-4 border-violet-500 bg-gray-800/50 p-8 ring-1 ring-white/[0.04] transition-all duration-300 hover:bg-gray-800/70 hover:ring-white/[0.08] hover:shadow-lg hover:shadow-black/20"
                     data-aos="fade-up" data-aos-delay="100" data-aos-duration="400">
                    <div class="mb-4 flex h-14 w-14 items-center justify-center rounded-xl bg-violet-500/10">
                        <twig:ux:icon name="simple-icons:php" class="h-8 w-8 text-violet-500" />
                    </div>
                    <h3 class="mb-3 text-xl font-semibold text-white">PHP 8.5 + Symfony 8</h3>
                    <p class="text-gray-400 leading-relaxed">
                        Symfony handles everything from forms and security to async messaging via RabbitMQ. Console commands drive a full simulation engine. A REST API with OpenAPI docs sits alongside the web UI.
                    </p>
                </div>

                <div class="group rounded-xl border-l-4 border-cyan-500 bg-gray-800/50 p-8 ring-1 ring-white/[0.04] transition-all duration-300 hover:bg-gray-800/70 hover:ring-white/[0.08] hover:shadow-lg hover:shadow-black/20"
                     data-aos="fade-up" data-aos-delay="200" data-aos-duration="400">
                    <div class="mb-4 flex h-14 w-14 items-center justify-center rounded-xl bg-cyan-500/10">
                        <twig:ux:icon name="bi:lightning-fill" class="h-7 w-7 text-cyan-500" />
                    </div>
                    <h3 class="mb-3 text-xl font-semibold text-white">Hotwire + Tailwind</h3>
                    <p class="text-gray-400 leading-relaxed">
                        SPA-like speed without a JavaScript framework. Turbo Frames handle navigation, Stimulus adds interactivity where needed, and Asset Mapper eliminates the build step entirely.
                    </p>
                </div>

                <div class="group rounded-xl border-l-4 border-emerald-500 bg-gray-800/50 p-8 ring-1 ring-white/[0.04] transition-all duration-300 hover:bg-gray-800/70 hover:ring-white/[0.08] hover:shadow-lg hover:shadow-black/20"
                     data-aos="fade-up" data-aos-delay="300" data-aos-duration="400">
                    <div class="mb-4 flex h-14 w-14 items-center justify-center rounded-xl bg-emerald-500/10">
                        <twig:ux:icon name="bi:server" class="h-7 w-7 text-emerald-500" />
                    </div>
                    <h3 class="mb-3 text-xl font-semibold text-white">Infrastructure</h3>
                    <p class="text-gray-400 leading-relaxed">
                        MySQL 8.4 for persistence, RabbitMQ for async domain event processing, Redis for caching and sessions, and S3 for file storage. Containerised and deployed on AWS.
                    </p>
                </div>
            </div>
        </div>
    </section>

    {# ── Demo Showcase ───────────────────────────────────────────────────── #}
    <section class="relative bg-gray-950 py-32 lg:py-40 overflow-hidden">
        <div class="absolute inset-0 bg-[radial-gradient(ellipse_80%_50%_at_50%_-10%,rgba(120,119,198,0.06),transparent)]"></div>

        <div class="relative mx-auto max-w-(--breakpoint-xl) px-6">
            <div class="mb-20 lg:mb-28 text-center" data-aos="fade-up">
                <p class="text-sm font-semibold uppercase tracking-widest text-orange-500 mb-4">The Demo</p>
                <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight text-white mb-6">
                    See It in Action
                </h2>
                <p class="text-lg text-gray-500 max-w-2xl mx-auto">
                    A fully operational platform, not a prototype. Explore the real interface.
                </p>
            </div>

            {# ─ Feature 1: Product Catalog ─ #}
            <div class="mb-24 lg:mb-36" data-aos="fade-up">
                <div class="flex flex-col lg:flex-row items-center gap-10 lg:gap-16">
                    <div class="relative lg:w-[60%] shrink-0">
                        <div class="absolute -inset-12 bg-gradient-to-br from-orange-500/[0.12] via-amber-500/[0.06] to-transparent rounded-[2.5rem] blur-3xl"></div>
                        <a href="{{ path('app_catalog_product_index') }}" class="group relative block rounded-2xl overflow-hidden shadow-2xl shadow-black/50 ring-1 ring-white/[0.08] transition-all duration-500 hover:shadow-orange-500/[0.1] hover:ring-white/[0.14]" data-turbo-prefetch="false">
                            <div class="bg-[#1a1d23] px-4 py-3 flex items-center gap-3 border-b border-white/[0.06]">
                                <div class="flex gap-2">
                                    <div class="w-3 h-3 rounded-full bg-[#ff5f57]"></div>
                                    <div class="w-3 h-3 rounded-full bg-[#febc2e]"></div>
                                    <div class="w-3 h-3 rounded-full bg-[#28c840]"></div>
                                </div>
                                <div class="flex-1 mx-4">
                                    <div class="bg-black/30 rounded-md px-3 py-1 text-center text-xs text-gray-500 font-mono">{{ domain }}/products</div>
                                </div>
                            </div>
                            <div class="relative aspect-square overflow-hidden">
                                <img src="{{ asset('images/Product-Catalog.webp') }}"
                                     alt="Product Catalog interface showing product details, pricing, and sales analytics"
                                     class="absolute inset-0 w-full h-full object-cover object-top transition-transform duration-700 group-hover:scale-[1.02]"
                                     loading="lazy">
                                <div class="absolute inset-x-0 bottom-0 h-28 bg-gradient-to-t from-gray-950 to-transparent pointer-events-none"></div>
                            </div>
                        </a>
                    </div>
                    <div class="lg:w-[40%]">
                        <p class="text-sm font-semibold uppercase tracking-widest text-orange-400/80 mb-3">Product Catalog</p>
                        <h3 class="text-2xl lg:text-3xl font-bold tracking-tight text-white mb-5">
                            Every product, beautifully organised
                        </h3>
                        <p class="text-gray-400 leading-relaxed text-base lg:text-lg">
                            Rich product pages with images, live pricing, multi-supplier stock levels, and 30-day sales trends — everything operational staff would need at a glance.
                        </p>
                    </div>
                </div>
            </div>

            {# ─ Feature 2: Order Management ─ #}
            <div class="mb-24 lg:mb-36" data-aos="fade-up">
                <div class="flex flex-col lg:flex-row-reverse items-center gap-10 lg:gap-16">
                    <div class="relative lg:w-[60%] shrink-0">
                        <div class="absolute -inset-12 bg-gradient-to-br from-blue-500/[0.12] via-cyan-500/[0.06] to-transparent rounded-[2.5rem] blur-3xl"></div>
                        <a href="{{ path('app_order_index') }}" class="group relative block rounded-2xl overflow-hidden shadow-2xl shadow-black/50 ring-1 ring-white/[0.08] transition-all duration-500 hover:shadow-blue-500/[0.1] hover:ring-white/[0.14]" data-turbo-prefetch="false">
                            <div class="bg-[#1a1d23] px-4 py-3 flex items-center gap-3 border-b border-white/[0.06]">
