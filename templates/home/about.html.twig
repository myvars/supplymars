{% extends 'base.html.twig' %}

{% block title %}About Us{% endblock %}

{% block body %}
    <div data-controller="aos">
        <section class="flex justify-center bg-white dark:bg-orange-400/10" style="background: url({{ asset('images/martian_landscape.webp') }}) center center no-repeat; background-size: cover;">
            <div class="mx-auto max-w-screen-xl px-4 py-8 sm:py-12 lg:px-6">
                <div class="mb-10 max-w-screen-md dark:text-white sm:text-base" data-aos="fade-up" data-aos-duration="800">
                    <h2 class="mb-4 text-3xl tracking-tight">About Us</h2>
                    <p class="mb-4">
                        Our mission is to provide everything humanity needs to thrive on Mars - while showcasing modern web technologies through a streamlined e-commerce backend.
                    </p>
                    <p class="mb-4">
                        This project demonstrates the power of modern PHP in the right hands, no real products are for sale!
                    </p>
                    <p class="mb-4">
                        PHP has evolved, transforming into a type-safe, efficient, and robust language that simplifies development and reduces maintenance costs.
                        Our platform highlights PHP's reliable management of complex e-commerce operations and advanced features, free from the risks and refactoring demands of constantly shifting JavaScript frameworks.
                     </p>
                    </p>
                    <p class="mb-4">
                        With over twenty years of experience in e-commerce, the creator of this project offers deep expertise in development, database design, and end-to-end solutions.
                        {{ domain|title }} reflects the application of a career dedicated to technological innovation — collaborating with customers, leading development teams, and scaling businesses from agile startups to booming enterprises.
                    </p>
                </div>

                <div class="mb-10 max-w-screen-md dark:text-white" data-aos="fade-up" data-aos-duration="800" data-aos-delay="200">
                    <h3 class="mb-4 text-2xl">Built on Modern, Reliable Technologies</h3>
                    <ul class="list-inside list-disc space-y-1">
                        <li>PHP 8 and Symfony for a robust, reliable back-end architecture</li>
                        <li>Hotwire Turbo for seamless server-side rendering and fast navigation</li>
                        <li>Tailwind CSS for fast, responsive design</li>
                        <li>Amazon EC2/RDS/S3 for scalable hosting and storage</li>
                        <li>AI-Generated Content: Unique products and images created by AI</li>
                    </ul>
                </div>

                <div class="mb-10 max-w-screen-md dark:text-white sm:text-base" data-aos="fade-up" data-aos-duration="800" data-aos-delay="400">
                    <h3 class="mb-4 text-2xl">A Feature-Rich, Fun E-Commerce Demo</h3>
                    <p>
                        {{ domain|title }} provides a comprehensive suite of e-commerce back-end tools, with product management, supplier integration, dynamic pricing models, order processing, all powered by real-time simulations of customer orders and supplier interactions.
                        With built-in sales reporting and data visualizations, this project explores the future of e-commerce - on Earth or Mars!
                    </p>
                </div>
                <div class="mt-4 flex items-center justify-center" data-aos="fade-up" data-aos-delay="400" data-aos-duration="800">
                    <twig:Button
                        tag="a"
                        href="mailto:adamashmore@me.com"
                        class="flex items-center font-bold space-x-1"
                        variant="secondary"
                    >
                        <span>Contact Us</span>
                    </twig:Button>
                </div>
            </div>
        </section>
    </div>
{% endblock %}