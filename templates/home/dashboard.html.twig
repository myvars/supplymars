{% extends 'base.html.twig' %}

{% block title %}Home{% endblock %}

{% block body %}
<div class="m-3 space-y-5">

    {# ── Welcome ──────────────────────────────────────────────────────── #}
    <div>
        <h1 class="text-lg font-semibold text-gray-900 dark:text-white">
            {{ greeting }}, {{ app.user.fullName }}
        </h1>
        <p class="mt-0.5 text-sm text-gray-500 dark:text-gray-400">
            {{ 'now'|date('l, j F') }}{% if totalActions > 0 %} · <span class="text-amber-500 dark:text-amber-400">{{ totalActions }} {{ totalActions == 1 ? 'item needs' : 'items need' }} attention</span>{% endif %}
        </p>
        {% set explorePills = [
            { count: totalOrders, label: 'Orders', icon: 'bi:bag-check', href: path('app_order_index') },
            { count: totalCustomers, label: 'Customers', icon: 'flowbite:users-solid', href: path('app_customer_index') },
            { count: totalProducts, label: 'Products', icon: 'bi:box-seam-fill', href: path('app_catalog_product_index') },
            { count: totalCategories, label: 'Categories', icon: 'bi:grid-fill', href: path('app_catalog_category_index') },
        ] %}
        <div class="mt-3 flex flex-wrap gap-2">
            {% for pill in explorePills %}
            <a href="{{ pill.href }}"
               class="group inline-flex items-center gap-1.5 rounded-full bg-gray-100 py-1.5 pl-2.5 pr-3 text-xs font-medium text-gray-500 ring-1 ring-gray-200/60 transition-all duration-200 hover:bg-primary-50 hover:text-primary-700 hover:ring-primary-200 dark:bg-gray-800/80 dark:text-gray-400 dark:ring-white/[0.06] dark:hover:bg-primary-900/30 dark:hover:text-primary-300 dark:hover:ring-primary-500/30"
               data-turbo-frame="body"
               style="animation: fadeIn 0.4s ease-out both; animation-delay: {{ loop.index0 * 75 }}ms"
            >
                <twig:ux:icon name="{{ pill.icon }}" class="h-3.5 w-3.5 text-gray-400 transition-colors group-hover:text-primary-500 dark:text-gray-500 dark:group-hover:text-primary-400"/>
                <span class="tabular-nums font-semibold text-gray-700 dark:text-gray-300">{{ pill.count|number_format }}</span>
                {{ pill.label }}
                <twig:ux:icon name="bi:chevron-right" class="h-3 w-3 text-gray-300 transition-transform duration-200 group-hover:translate-x-0.5 group-hover:text-primary-400 dark:text-gray-600"/>
            </a>
            {% endfor %}
        </div>
    </div>

    {# ── Today at a Glance ────────────────────────────────────────────── #}
    <div>
        <h2 class="mb-3 text-sm font-medium uppercase tracking-wide text-gray-500 dark:text-gray-400">Today</h2>
        <div class="grid grid-cols-2 gap-px overflow-hidden rounded-lg bg-gray-900/5 dark:bg-white/5 sm:grid-cols-4">
            <twig:KpiCard
                title="Orders"
                value="{{ orderSummary.orderCount|default(0) }}"
                compare="{{ orderCompare.orderCount|default(null) }}"
                valueType="count"
                subtitle="vs. last {{ 'now'|date('l') }}"
                href="{{ path('app_reports_order_summary', {'duration': 'today'}) }}"
                turboFrame="body"
            />
            <twig:KpiCard
                title="Revenue"
                value="{{ orderSummary.orderValue|default(0) }}"
                compare="{{ orderCompare.orderValue|default(null) }}"
                valueType="currency"
                subtitle="vs. last {{ 'now'|date('l') }}"
                href="{{ path('app_reports_order_summary', {'duration': 'today', 'sort': 'orderValue'}) }}"
                turboFrame="body"
            />
            <twig:KpiCard
                title="Profit"
                value="{{ productSummary.salesProfit|default(0) }}"
                compare="{{ productCompare.salesProfit|default(null) }}"
                valueType="currency"
                subtitle="vs. last {{ 'now'|date('l') }}"
                href="{{ path('app_reports_product_sales', {'duration': 'today', 'sort': 'salesProfit'}) }}"
                turboFrame="body"
            />
            <twig:KpiCard
                title="Margin"
                value="{{ productSummary.salesMargin|default(0) }}"
                compare="{{ productCompare.salesMargin|default(null) }}"
                valueType="percentage"
                maxFractionDigits="2"
                subtitle="vs. last {{ 'now'|date('l') }}"
                href="{{ path('app_reports_product_sales', {'duration': 'today', 'sort': 'salesMargin'}) }}"
                turboFrame="body"
            />
        </div>
    </div>

    {# ── Needs Attention ──────────────────────────────────────────────── #}
    {% if totalActions > 0 %}
    <div>
        <h2 class="mb-3 text-sm font-medium uppercase tracking-wide text-gray-500 dark:text-gray-400">Needs Attention</h2>
        {% set actionItems = [
                {
                    label: 'Pending Orders',
                    count: badges.pendingOrders,
                    icon: 'bi:clock-fill',
                    color: 'amber',
                    href: path('app_order_index', {orderStatus: 'PENDING'})
                },
                {
                    label: 'Overdue Orders',
                    count: badges.overdueOrders,
                    icon: 'bi:exclamation-triangle-fill',
                    color: 'rose',
                    href: path('app_reports_overdue_orders', {duration: 'last30'})
                },
                {
                    label: 'Rejected POs',
                    count: badges.rejectedPos,
                    icon: 'bi:x-circle-fill',
                    color: 'orange',
                    href: path('app_purchasing_purchase_order_index', {purchaseOrderStatus: 'REJECTED'})
                },
                {
                    label: 'Pending Reviews',
                    count: badges.pendingReviews,
                    icon: 'bi:star-half',
                    color: 'blue',
                    href: path('app_review_index', {reviewStatus: 'PENDING'})
                }
            ] %}
            {% set visibleItems = actionItems|filter(item => item.count > 0) %}

        <div class="grid grid-cols-2 gap-3 {{ visibleItems|length <= 2 ? 'sm:grid-cols-2' : (visibleItems|length == 3 ? 'sm:grid-cols-3' : 'sm:grid-cols-4') }}">
            {% for item in visibleItems %}
                <a href="{{ item.href }}"
                   class="group flex items-center gap-3 overflow-hidden rounded-lg border-l-4 bg-white py-3.5 pl-3 pr-3.5 shadow-sm transition-all duration-150 hover:-translate-y-px hover:shadow-md active:scale-[0.98] dark:bg-gray-800/40 dark:shadow-md dark:shadow-black/20 dark:ring-1 dark:ring-white/[0.06] dark:hover:brightness-125 sm:py-4 sm:pl-3.5 sm:pr-4
                       {% if item.color == 'amber' %}border-amber-400 dark:border-amber-500{% endif %}
                       {% if item.color == 'rose' %}border-rose-400 dark:border-rose-500{% endif %}
                       {% if item.color == 'orange' %}border-orange-400 dark:border-orange-500{% endif %}
                       {% if item.color == 'blue' %}border-blue-400 dark:border-blue-500{% endif %}
                   "
                   data-turbo-frame="body"
                >
                    <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg
                        {% if item.color == 'amber' %}bg-amber-50 dark:bg-amber-900/20{% endif %}
                        {% if item.color == 'rose' %}bg-rose-50 dark:bg-rose-900/20{% endif %}
                        {% if item.color == 'orange' %}bg-orange-50 dark:bg-orange-900/20{% endif %}
                        {% if item.color == 'blue' %}bg-blue-50 dark:bg-blue-900/20{% endif %}
                    ">
                        <twig:ux:icon name="{{ item.icon }}" class="h-5 w-5
                            {% if item.color == 'amber' %}text-amber-500{% endif %}
                            {% if item.color == 'rose' %}text-rose-500{% endif %}
                            {% if item.color == 'orange' %}text-orange-500{% endif %}
                            {% if item.color == 'blue' %}text-blue-500{% endif %}
                        "/>
                    </div>
                    <div class="min-w-0">
                        <p class="text-xl font-semibold tabular-nums text-gray-900 dark:text-white sm:text-2xl">{{ item.count }}</p>
                        <p class="truncate text-xs font-medium text-gray-500 dark:text-gray-400">{{ item.label }}</p>
                    </div>
                </a>
            {% endfor %}
        </div>
    </div>
    {% endif %}

    {# ── Recent Activity ──────────────────────────────────────────────── #}
    <div>
        <h2 class="mb-3 text-sm font-medium uppercase tracking-wide text-gray-500 dark:text-gray-400">Recent Activity</h2>
        <div class="grid grid-cols-1 gap-3 lg:grid-cols-2">

            {# Latest Orders #}
            <twig:DataTable title="Latest Orders">
                {% block head %}
                    <tr>
                        <th scope="col" class="px-4 py-3 sm:px-6">Customer</th>
                        <th scope="col" class="px-4 py-3 sm:px-6">
                            <div class="flex justify-end">Status</div>
                        </th>
                        <th scope="col" class="px-4 py-3 sm:px-6">
                            <div class="flex justify-end">Total</div>
                        </th>
                    </tr>
                {% endblock %}
                {% block body %}
                    {% for order in latestOrders %}
                        <tr>
                            <th scope="row" class="whitespace-nowrap px-4 py-3 font-medium text-gray-900 dark:text-white sm:px-6">
                                <a href="{{ path('app_order_show', {'id': order.publicId.value}) }}"
                                   class="hover:underline dark:hover:text-white"
                                   data-turbo-frame="body"
                                >
                                    {{ order.customer.fullName }}
                                </a>
                            </th>
                            <td class="px-4 py-3 sm:px-6">
                                <div class="flex justify-end">
                                    {% component 'StatusBadge' with { status: order.status.value } %}{% endcomponent %}
                                </div>
                            </td>
                            <td class="whitespace-nowrap px-4 py-3 text-right tabular-nums sm:px-6">
                                {{ order.totalPrice|default(0)|price_rounded }}
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="3" class="px-4 py-8 text-center sm:px-6">
                                <twig:ux:icon name="bi:inbox" class="mx-auto mb-2 h-8 w-8 text-gray-300 dark:text-gray-600"/>
                                <p class="text-sm text-gray-400 dark:text-gray-500">No orders yet today</p>
                                <a href="{{ path('app_order_index') }}" class="mt-1 inline-block text-xs text-primary-500 hover:text-primary-400" data-turbo-frame="body">View all orders &rarr;</a>
                            </td>
                        </tr>
                    {% endfor %}
                {% endblock %}
            </twig:DataTable>

            {# Top Products #}
            <twig:DataTable title="Top Products Today">
                {% block head %}
                    <tr>
                        <th scope="col" class="px-4 py-3 sm:px-6">Product</th>
                        <th scope="col" class="px-4 py-3 sm:px-6">
                            <div class="flex justify-end">Qty Sold</div>
                        </th>
                    </tr>
                {% endblock %}
                {% block body %}
                    {% for sale in topProducts %}
                        <tr>
                            <th scope="row" class="whitespace-nowrap px-4 py-3 font-medium text-gray-900 dark:text-white sm:px-6">
                                <a href="{{ path('app_catalog_product_show', {'id': sale.publicId}) }}"
                                   class="hover:underline dark:hover:text-white"
                                   data-turbo-frame="body"
                                >
                                    {{ sale.name|u.truncate(30, '...') }}
                                </a>
                            </th>
                            <td class="whitespace-nowrap px-4 py-3 text-right tabular-nums sm:px-6">
                                {{ sale.salesQty }}
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="2" class="px-4 py-8 text-center sm:px-6">
                                <twig:ux:icon name="bi:box-seam" class="mx-auto mb-2 h-8 w-8 text-gray-300 dark:text-gray-600"/>
                                <p class="text-sm text-gray-400 dark:text-gray-500">No product sales yet today</p>
                                <a href="{{ path('app_catalog_product_index') }}" class="mt-1 inline-block text-xs text-primary-500 hover:text-primary-400" data-turbo-frame="body">View all products &rarr;</a>
                            </td>
                        </tr>
                    {% endfor %}
                {% endblock %}
            </twig:DataTable>

        </div>
    </div>


</div>
{% endblock %}
