{% extends 'email/emailBase.html.twig' %}

{% block content %}
    <spacer size="10"></spacer>
    <row>
        <columns>
            <p>
                Hi {{ email.toName }}, it looks like you've forgotten your password. No problem!

            </p>
            <p>
                To reset your password, please visit the link below.
            </p>
        </columns>
    </row>
    <row>
        <columns>
            <p>
                <a href="{{ url('app_reset_password', {token: resetToken.token}) }}">
                    Reset my password
                </a>

            </p>
        </columns>
    </row>
    <row>
        <columns>
            <p>
                This link will expire
                in {{ resetToken.expirationMessageKey|trans(resetToken.expirationMessageData, 'ResetPasswordBundle') }}.
            </p>
        </columns>
    </row>
{% endblock %}