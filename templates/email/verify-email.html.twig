{% extends 'email/emailBase.html.twig' %}

{% block content %}
    <row class="welcome">
        <columns>
            <spacer size="35"></spacer>
            <h1>
                <center>
                    Nice to meet you {{ email.toName }}!
                </center>
            </h1>
            <spacer size="10"></spacer>
        </columns>
    </row>
    <spacer size="30"></spacer>
    <row>
        <columns>
            <p>
                Welcome to <strong>{{ domain|title }}</strong>, thank you for signing up!
            </p>
        </columns>
    </row>
    <row>
        <columns>
            <p>
                <a href="{{ signedUrl|raw }}">
                    Please confirm your email address by clicking this link
                </a>
            </p>
        </columns>
    </row>
    <row>
        <columns>
            <p>
                This link will expire in {{ expiresAtMessageKey|trans(expiresAtMessageData, 'VerifyEmailBundle') }}.
            </p>
        </columns>
    </row>
{% endblock %}