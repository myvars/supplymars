{% extends 'base.html.twig' %}

{% block title %}{{ section }} index{% endblock %}

{% block body %}
    <twig:DataList
        section="{{ section }}"
        results="{{ results }}"
    >
        <twig:block name="list_sort">
            <twig:SortLink sortValue="id">PO</twig:SortLink>
            <twig:SortLink sortValue="createdAt">Created</twig:SortLink>
            <twig:SortLink sortValue="customerOrder.id">Order</twig:SortLink>
            <twig:SortLink sortValue="totalPriceIncVat">Total</twig:SortLink>
            <twig:SortLink sortValue="status">Status</twig:SortLink>
        </twig:block>

        <twig:block name="list_item">
            <div class="flex justify-between items-center">
                <p class="mb-1 items-center text-xl text-gray-900 dark:text-white">PO #{{ '%06d'|format(result.id) }}</p>
                <p class="text-lg font-extralight"> £{{ result.totalPriceIncVat|number_format(2) }}</p>
            </div>
            <p class="mb-1 text-sm">
                {{ result.createdAt|date() }}
                | Order #{{ '%06d'|format(result.customerOrder.id) }}
            </p>
            <div class="flex justify-between items-center text-gray-600 dark:text-gray-500">
                <p>{{ result.customerOrder.customer.fullName }}</p>
                <p>{{ result.status.value|title }}</p>
            </div>
            <twig:block name="list_item_edit"></twig:block>
        </twig:block>

        <twig:block name="list_add"></twig:block>

        <twig:block name="filter"></twig:block>
    </twig:DataList>

{% endblock %}