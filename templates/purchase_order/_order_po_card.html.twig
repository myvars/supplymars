<div class="relative p-3 h-full bg-white border border-supplier-200 rounded-lg shadow dark:bg-supplier-800 dark:border-supplier-700">
    <div class="w-full flex justify-between">
        <h1 class="text-base text-gray-500 dark:text-gray-400">
            <a href="{{ path('app_purchase_order_show', {id: purchaseOrder.id}) }}"
               data-turbo-frame="_top"
               data-turbo-prefetch="false"
               class="hover:text-gray-700 dark:hover:text-white"
            >PO #{{ '%06d'|format(purchaseOrder.id) }}</a>
            <span class="ms-2 text-sm text-gray-500 dark:text-gray-400">{{ purchaseOrder.supplier.name }}</span>
        </h1>
        <a href="{{ path('app_purchase_order_status_log', {'id':purchaseOrder.id }) }}"
           class="flex justify-between items-center text-grey-500 dark:hover:text-gray-800"
           data-turbo-prefetch="false"
           data-turbo-frame="modal"
        >
            <twig:StatusIcon type="{{ purchaseOrder.status.value|lower }}" class="me-1"/>
            {{ purchaseOrder.status.value|title }}
        </a>
    </div>
    <ul class="w-full space-y-3">
        {% for purchaseOrderItem in purchaseOrder.purchaseOrderItems %}
            {{ include('purchase_order_item/_order_po_item_card.html.twig', {purchaseOrderItem: purchaseOrderItem}) }}
        {% else %}
            <li class="flex justify-between">No items found</li>
        {% endfor %}
    </ul>
</div>