{# CSRF-protected confirmation dialog. Used for delete confirmations and destructive actions.
   - title: Dialog heading
   - formAction: POST URL for the form submission
   - csrfId: CSRF token identifier (e.g., 'delete' ~ entity.publicId.value)
   - confirmLabel: Text on the confirm button
   - confirmVariant: Button variant for confirm (default: danger)
   - cancelLabel: Text on the cancel button (default: Cancel)
   Block: message (confirmation text shown above buttons) #}
{% props
    title,
    formAction,
    csrfId,
    confirmLabel,
    confirmVariant = 'danger',
    cancelLabel = 'Cancel'
%}

<div class="relative" data-modal-size="sm">
    <div class="flex items-center justify-between border-b border-gray-200 px-4 py-3 dark:border-gray-600">
        <h3 class="text-base font-semibold text-gray-900 dark:text-gray-100">
            {{ title }}
        </h3>
    </div>

    <div class="p-3 text-sm text-gray-600 dark:text-gray-400">
        <div class="flex justify-center pb-3">
            <twig:ux:icon name="bi:exclamation-triangle-fill" class="h-12 w-12 text-red-400 dark:text-red-500"/>
        </div>
        {% block message %}{% endblock %}
        <form method="post" action="{{ formAction }}">
            <input type="hidden" name="_token" value="{{ csrf_token(csrfId) }}">
            <div class="flex gap-3">
                <twig:Button type="button" variant="alternative" class="w-full" data-action="basic-modal#close">
                    {{ cancelLabel }}
                </twig:Button>
                <twig:Button type="submit" variant="{{ confirmVariant }}" class="w-full">{{ confirmLabel }}</twig:Button>
            </div>
        </form>
    </div>
</div>
