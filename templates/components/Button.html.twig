{# Polymorphic button or link styled as a button.
   Props (PHP): tag (button|a, default: button), variant (primary|secondary|alternative|success|danger|warning|link) #}
<{{ tag }}{{ attributes.defaults({
    class: 'inline-flex items-center justify-center gap-1.5 font-semibold rounded-lg text-sm py-2 text-center transition-all duration-150 ease-in-out active:scale-[0.98] disabled:opacity-50 disabled:pointer-events-none cursor-pointer '~this.variantClasses,
}) }}>
    {% block content %}{% endblock %}
</{{ tag }}>
