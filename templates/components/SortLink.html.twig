{# Sortable column header link. Toggles ASC/DESC on click, highlights active sort.
   - sortValue: The sort field name matching SearchCriteria SORT_OPTIONS #}
{% props sortValue='' %}

{% set isActive = sortValue == app.request.query.get('sort') %}
{% set isAsc = isActive and app.request.query.get('sortDirection') == 'ASC' %}

<a {{ attributes.defaults({
    class: 'group inline-flex items-center gap-1 text-sm transition-colors ' ~ (isActive ? 'font-medium text-gray-900 dark:text-white' : 'text-gray-500 hover:text-gray-900 dark:text-gray-400 dark:hover:text-white'),
}) }}
    href="{{ path(app.current_route, {
        ...app.request.query.all(),
        sort: sortValue,
        sortDirection: isAsc ? 'DESC' : 'ASC',
    }) }}"
>
    {% block content %}{% endblock %}
    {% if isActive %}
        <twig:ux:icon name="{{ isAsc ? 'flowbite:caret-up-solid' : 'flowbite:caret-down-solid' }}" class="h-3.5 w-3.5" />
    {% else %}
        <twig:ux:icon name="bi:arrow-down-up" class="h-3.5 w-3.5 opacity-0 group-hover:opacity-50" />
    {% endif %}
</a>
