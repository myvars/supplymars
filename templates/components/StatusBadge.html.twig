{# Coloured status pill. Colour resolved via StatusColor utility.
   Props (PHP): status (string, e.g., "ACTIVE"), showIcon (bool, default: false), interactive (bool, default: false — adds hover opacity) #}
<span {{ attributes.defaults({
    'class': 'inline-flex items-center rounded-md px-1.5 py-0.5 text-xs font-medium '~this.getColorClasses~(interactive ? ' transition-opacity hover:opacity-75' : ''),
}) }}>
    {% if showIcon %}
        <twig:StatusIcon type="{{ status|lower }}" class="me-1"/>
    {% endif %}
    {{ status|replace({'_': ' '})|title }}
</span>
