{% props
    title,
    value,
    compare = null,
    valueType = 'count',
    format = 'GBP',
    maxFractionDigits = 0,
    href = null,
    turboFrame = null
    %}

{% macro formatValue(value, valueType, format, maxFractionDigits) %}
    {% if valueType == 'currency' %}
        {{ value|price_rounded(maxFractionDigits) }}
    {% elseif valueType == 'percentage' %}
        {{ value|number_format(2) ~ '%' }}
    {% elseif valueType == 'text' %}
        {{ value }}
    {% else %}
        {{ value|number_format(0) }}
    {% endif %}
{% endmacro %}

{% set baseClasses = 'flex flex-col items-center justify-center gap-1 overflow-hidden rounded-lg border border-gray-200 bg-white px-3 py-4 dark:border-gray-700/50 dark:bg-gray-800/50 sm:px-5' %}
{% set hoverClasses = href ? ' transition-colors hover:border-primary-300 hover:bg-primary-50/50 dark:hover:border-primary-700 dark:hover:bg-primary-900/20' : '' %}

{% if href %}
<a href="{{ href }}" class="{{ baseClasses }}{{ hoverClasses }}"{{ turboFrame ? ' data-turbo-frame="' ~ turboFrame ~ '"' : '' }}>
{% else %}
<div class="{{ baseClasses }}">
{% endif %}

    <p class="text-xs font-medium uppercase tracking-wide text-gray-500 dark:text-gray-400">{{ title }}</p>

    <div class="flex max-w-full items-baseline gap-1.5">
        <span class="truncate text-xl font-semibold tabular-nums text-gray-900 dark:text-gray-100 sm:text-2xl">
            {{ _self.formatValue(value, valueType, format, maxFractionDigits) }}
        </span>
        {% if compare is not null %}
            {% set difference = value - compare %}
            {% if difference > 0 %}
                <twig:ux:icon name="bxs:up-arrow" class="h-4 w-4 self-center text-green-500" />
            {% elseif difference < 0 %}
                <twig:ux:icon name="bxs:down-arrow" class="h-4 w-4 self-center text-red-500" />
            {% endif %}
        {% endif %}
    </div>

    {% if compare is not null %}
        {% set difference = value - compare %}
        {% set percentage = (compare != 0) ? ((difference / compare) * 100)|round(2) : 0 %}
        {% if difference != 0 %}
            {% set positive = difference > 0 %}
            <div class="flex items-center gap-3 text-xs">
                <span class="text-gray-500 dark:text-gray-400">
                    {{ positive ? '+' : '' }}{{ difference|number_format(valueType != 'percentage' ? 0 : 2) }}
                </span>
                <span class="font-medium {{ positive ? 'text-green-600 dark:text-green-400' : 'text-red-600 dark:text-red-400' }}">
                    {{ positive ? '+' : '' }}{{ percentage|number_format(2) }}%
                </span>
            </div>
        {% else %}
            <span class="inline-flex rounded-full bg-gray-100 px-2 py-0.5 text-xs font-medium text-gray-500 dark:bg-gray-700 dark:text-gray-400">
                0%
            </span>
        {% endif %}
    {% endif %}
{% if href %}
</a>
{% else %}
</div>
{% endif %}
