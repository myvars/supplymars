{# Auto-closing toast notification. Rendered in _flashes.html.twig for flash messages.
   Props (PHP): type (success|danger|warning, default: success) #}
<div  {{ attributes.defaults({
    'class': 'pointer-events-auto relative flex items-center w-full max-w-sm overflow-hidden rounded-lg border border-gray-200 bg-white p-4 shadow-lg dark:border-gray-700 dark:bg-gray-800',
    'data-turbo-temporary': true,
    'data-controller': 'closeable',
    'data-closeable-auto-close-value': this.duration,
}) }}
>
    <div class="inline-flex items-center justify-center shrink-0 w-8 h-8 rounded-lg {{ this.typeClasses }}">
        <twig:ux:icon name="{{ this.iconName }}" class="h-5 w-5"/>
        <span class="sr-only">Toast icon</span>
    </div>
    <div class="text-sm font-medium text-gray-700 dark:text-gray-300 ms-3">{% block content %}{% endblock %}</div>
    <button
        type="button"
        class="inline-flex h-7 w-7 shrink-0 items-center justify-center rounded-md text-gray-400 ms-auto ml-3 p-1 transition-colors hover:bg-gray-100 hover:text-gray-600 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-gray-500 dark:text-gray-500 dark:hover:bg-gray-700 dark:hover:text-white"
        aria-label="Close"
        data-action="closeable#close"
    >
        <span class="sr-only">Close</span>
        <twig:ux:icon name="flowbite:close-outline" class="h-3 w-3"/>
    </button>
    <div
        class="absolute bottom-0 left-0 h-0.5 {{ this.timerbarColor }} w-full transition-all ease-linear"
        style="transition-duration: {{ this.duration }}ms"
        data-closeable-target="timerbar"
    ></div>
</div>
