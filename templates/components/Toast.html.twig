{# Auto-closing toast notification. Rendered in _flashes.html.twig for flash messages.
   Props (PHP): type (success|danger|warning, default: success) #}
<div  {{ attributes.defaults({
    'class': 'relative flex items-center w-full max-w-xs p-4 text-gray-500 bg-white rounded-lg shadow-sm dark:text-gray-400 dark:bg-gray-800',
    'data-turbo-temporary': true,
    'data-controller': 'closeable',
    'data-closeable-auto-close-value': this.duration,
}) }}
>
    <div class="inline-flex items-center justify-center shrink-0 w-8 h-8 rounded-lg {{ this.typeClasses }}">
        <twig:ux:icon name="{{ this.iconName }}" class="h-5 w-5"/>
        <span class="sr-only">Toast icon</span>
    </div>
    <div class="text-sm font-normal ms-3">{% block content %}{% endblock %}</div>
    <button
        type="button"
        class="inline-flex h-8 w-8 items-center justify-center rounded-lg bg-white text-gray-400 ms-auto -mx-1.5 -my-1.5 p-1.5 hover:bg-gray-100 hover:text-gray-900 focus:ring-2 focus:ring-gray-300 dark:bg-gray-800 dark:text-gray-500 dark:hover:bg-gray-700 dark:hover:text-white"
        aria-label="Close"
        data-action="closeable#close"
    >
        <span class="sr-only">Close</span>
        <twig:ux:icon name="flowbite:close-outline" class="h-3 w-3"/>
    </button>
    <div
        class="absolute bottom-0 right-0 h-1 {{ this.timerbarColor }} w-full transition-all ease-linear"
        style="transition-duration: {{ this.duration }}ms"
        data-closeable-target="timerbar"
    ></div>
</div>
