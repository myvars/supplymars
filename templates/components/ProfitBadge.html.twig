{# Profit/loss currency badge. Green for positive, red for negative.
   Props (PHP): value (string|float, default: 0) #}
<span {{ attributes.defaults({'class': 'rounded-full px-2 py-0.5 text-xs tabular-nums ' ~ this.colorClasses}) }}>{{ this.isPositive ? '+' : '-' }}{{ this.formattedValue|format_currency('GBP') }}</span>
