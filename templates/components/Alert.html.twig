{# Inline alert box with contextual icon and colour.
   Props (PHP): type (info|danger|warning|success, default: info) #}
<div {{ attributes.defaults({
    'class': 'flex items-start gap-3 rounded-lg border px-4 py-3 text-sm ' ~ this.colorClasses,
    'role': 'alert',
}) }}>
    <twig:ux:icon name="{{ this.iconName }}" class="mt-0.5 h-4 w-4 shrink-0"/>
    <span class="font-medium">{% block content %}{% endblock %}</span>
</div>
