{% props pager %}

<nav
    class="flex flex-col items-start justify-between gap-3 border-t border-gray-200 pt-4 pb-2 md:flex-row md:items-center dark:border-gray-700"
    aria-label="Table pagination"
>
    <p class="text-sm text-gray-500 dark:text-gray-400">
        Showing
        <span class="tabular-nums font-medium text-gray-700 dark:text-gray-200">
            {{ pager.currentPageOffsetStart }}&ndash;{{ pager.currentPageOffsetEnd }}
        </span>
        of
        <span class="tabular-nums font-medium text-gray-700 dark:text-gray-200">
            {{ pager.count }}
        </span>
    </p>
    {{ pagerfanta(pager) }}
</nav>
