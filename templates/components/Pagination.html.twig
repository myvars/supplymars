{% props pager %}

<nav
    class="flex flex-col items-start justify-between py-3 space-y-3 md:space-y-0 md:flex-row md:items-center"
    aria-label="Table pagination"
>
    <span class="text-sm font-normal text-gray-500 dark:text-gray-400">
        Showing
        <span class="font-semibold text-gray-900 dark:text-white">
            {{ pager.currentPageOffsetStart }}-{{ pager.currentPageOffsetEnd }}
        </span>
        of
        <span class="font-semibold text-gray-900 dark:text-white">
            {{ pager.count }}
        </span>
    </span>
    {{ pagerfanta(pager) }}
</nav>