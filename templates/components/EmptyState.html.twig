{# Placeholder shown when a list or section has no content.
   Props (PHP): icon (UX icon name), message (main text), subtitle (?string) #}
<div class="flex flex-col items-center justify-center rounded-xl border border-dashed border-gray-300 py-12 dark:border-gray-600">
    <twig:ux:icon name="{{ icon }}" class="mb-3 h-12 w-12 text-gray-400 dark:text-gray-600"/>
    <p class="text-sm font-medium text-gray-500 dark:text-gray-400">{{ message }}</p>
    {% if subtitle %}
        <p class="mt-1 text-xs text-gray-400 dark:text-gray-500">{{ subtitle }}</p>
    {% endif %}
    {% block action %}{% endblock %}
</div>
