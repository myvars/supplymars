{% props
    title = null,
    padding = 'p-3'
%}

<div {{ attributes.defaults({
    'class': 'p-3 relative bg-white rounded shadow dark:bg-gray-800',
}) }}
>
    <div class="mb-3 flex items-center justify-between rounded-t border-b pb-3 dark:border-gray-600">
        <h3 class="text-lg font-semibold text-gray-900 dark:text-white">
            {{ title }}
        </h3>
    </div>

    <div class="{{ padding }} text-sm text-gray-500 dark:text-gray-400">
        {% block content %}{% endblock %}
    </div>
</div>