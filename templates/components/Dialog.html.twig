{% props
    colour = 'gray',
    title = null,
    padding = 'p-3', %}

<div {{ attributes.defaults({
    'class': 'p-3 relative bg-white rounded-lg shadow dark:bg-'~colour~'-800 dark:border-'~colour~'-700',
}) }}
>
    <div class="flex justify-between items-center pb-3 mb-3 rounded-t border-b dark:border-gray-600">
        <h3 class="text-lg font-semibold text-gray-900 dark:text-white">
            {{ title }}
        </h3>
    </div>

    <div class="{{ padding }} text-sm text-gray-500 dark:text-gray-400">
        {% block content %}{% endblock %}
    </div>
</div>