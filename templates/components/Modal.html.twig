{% props
    allowSmallWidth=false,
    closeButton=false,
    padding='p-5',
    fixedTop=false
%}

<div {{ attributes.defaults({
    'data-controller': 'basic-modal',
    'data-action': 'turbo:before-cache@window->basic-modal#close',
}) }}
>
    {% block trigger %}{% endblock %}
    <dialog
        data-basic-modal-target="dialog"
        class="open:flex m-auto bg-gray-800 border border-gray-700 rounded-sm shadow-xl inset-0 w-full md:w-fit md:max-w-[50%] {{ allowSmallWidth ? '' : 'md:min-w-[50%] ' }}
        max-h-full animate-fade-in backdrop:bg-slate-700/80 {{ fixedTop ? ' mt-14' : '' }}"
        data-action="close->basic-modal#close mousedown->basic-modal#onMouseDown click->basic-modal#clickOutside"
    >
        <div class="grow overflow-auto p-1">
            {% block content %}{% endblock %}
        </div>
        {% if closeButton %}
            <button
                class="absolute top-7 right-6 flex items-center text-white opacity-70 transition-opacity hover:opacity-100"
                data-action="basic-modal#close"
                type="button"
            >
                <svg aria-hidden="true" class="h-5 w-5" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"></path></svg>
                <span class="sr-only">Close modal</span>
            </button>
        {% endif %}
    </dialog>

    {% if block('loading_template') %}
        <template data-basic-modal-target="loadingTemplate">
            {% block loading_template %}{% endblock %}
        </template>
    {% endif %}
</div>