{# Native <dialog> modal managed by the basic-modal Stimulus controller.
   Placed once in base.html.twig. Turbo loads content into the modal frame.
   - closeButton: Show an X close button in the top-right corner (default: false)
   - padding: Tailwind padding for content area (default: p-5)
   - fixedTop: Position dialog near the top of viewport (default: false)
   Size is controlled by the loaded content's data-modal-size attribute (sm|md|lg|xl).
   Dialog.html.twig exposes a `size` prop; ConfirmDialog defaults to sm.
   The Stimulus controller reads this attribute and applies it to the <dialog>.
   Blocks: trigger, content, loading_template #}
{% props
    closeButton=false,
    padding='p-5',
    fixedTop=false
%}

<div {{ attributes.defaults({
    'data-controller': 'basic-modal',
    'data-action': 'turbo:before-cache@window->basic-modal#close turbo:submit-end->basic-modal#submitEnd turbo:frame-load->basic-modal#frameLoaded',
}) }}
>
    {% block trigger %}{% endblock %}
    <dialog
        data-basic-modal-target="dialog"
        data-modal-size="md"
        class="open:flex m-auto rounded-lg border border-gray-200 bg-white shadow-2xl inset-0 w-full md:w-fit
        data-[modal-size=sm]:md:max-w-md
        data-[modal-size=md]:md:min-w-[50%] data-[modal-size=md]:md:max-w-[50%]
        data-[modal-size=lg]:md:max-w-2xl
        data-[modal-size=xl]:md:max-w-5xl
        max-h-full animate-fade-in backdrop:bg-gray-900/60 dark:border-gray-600 dark:bg-gray-800 dark:backdrop:bg-gray-900/80{{ fixedTop ? ' mt-14' : '' }}"
        data-action="close->basic-modal#close mousedown->basic-modal#onMouseDown click->basic-modal#clickOutside"
    >
        <div class="grow overflow-auto p-1">
            {% block content %}{% endblock %}
        </div>
        {% if closeButton %}
            <button
                class="absolute top-5 right-5 flex h-8 w-8 items-center justify-center rounded-lg text-gray-400 transition-colors hover:bg-gray-100 hover:text-gray-900 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-gray-500 dark:hover:bg-gray-700 dark:hover:text-white"
                data-action="basic-modal#close"
                type="button"
            >
                <svg aria-hidden="true" class="h-4 w-4" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"></path></svg>
                <span class="sr-only">Close modal</span>
            </button>
        {% endif %}
    </dialog>

    {% if block('loading_template') %}
        <template data-basic-modal-target="loadingTemplate">
            {% block loading_template %}{% endblock %}
        </template>
    {% endif %}
</div>