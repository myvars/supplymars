{# Standard form wrapper for FormFlow. Renders form fields with a submit button.
   - form: Symfony FormView
   - buttonLabel: Submit button text (default: Save)
   - formFrame: Turbo frame target for submit (defaults to current request's turbo-frame header)
   Block: before_submit (content between form fields and submit button, e.g., delete link) #}
{% props
    form,
    buttonLabel = 'Save',
    formFrame = null
%}

{{ form_start(form, {
    'attr': {
        'class': 'space-y-4 md:space-y-6',
        'novalidate': 'novalidate',
        'data-controller': 'submit-form',
    }
}) }}
    {{ form_widget(form) }}
    {% block before_submit %}{% endblock %}
    <twig:Button
        type="submit"
        class="w-full"
        data-turbo-frame="{{ formFrame ?? app.request.headers.get('turbo-frame') ?: '_top' }}"
    >{{ buttonLabel }}</twig:Button>
{{ form_end(form) }}
