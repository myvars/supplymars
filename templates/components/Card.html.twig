{# Reusable card container with optional edit/show links and status highlight.
   Props (PHP):
   - title: Optional heading above content
   - editLink: URL for floating edit button (opens modal)
   - showLink: URL wrapping entire card content as a clickable link
   - statusHighlight: Status string for coloured left border (via StatusColor)
   - colour: Background scheme (gray|green|supplier1-4)
   - borderColour: Border scheme override (gray|green|red|supplier1-4)
   - layout: vertical (default) or horizontal (side-by-side with cardImage block)
   - padding: Tailwind padding class (default: p-3)
   - editIcon: Icon name for edit button (default: mynaui:edit-one)
   Blocks: content (implicit), cardImage (for horizontal layout) #}
<div {{ attributes.defaults({
    'class': width~' relative h-full rounded-xl shadow-sm dark:shadow-none '~this.getBackgroundClasses~' '~this.getBorderClasses~' '~this.getHighlightClasses,
}) }}
>
    {% if editLink %}
        <a href="{{ editLink }}"
           class="absolute z-10 -top-2 -right-2 p-1.5 text-yellow-500 rounded-full shadow-md transition-all duration-200 hover:scale-110 hover:shadow-lg {{ this.getEditLinkClasses }}"
           data-turbo-frame="modal"
           data-turbo-prefetch="false"
        >
            <twig:ux:icon name="{{ editIcon }}" class="h-6 w-6 p-0.5"/>
        </a>
    {% endif %}
    <div class="{{ layout == 'horizontal' ? 'flex flex-col md:flex-row' : '' }}">
        {% block cardImage %}{% endblock %}

        {% if showLink %}
        <a href="{{ showLink }}" data-turbo-frame="body" class="block rounded-xl transition-all duration-200 hover:shadow-md hover:brightness-95 dark:hover:brightness-125 dark:hover:shadow-none {{ layout == 'horizontal' ? 'flex-1 min-w-0' : '' }}">
        {% endif %}
                <div class="{{ padding }} text-sm text-gray-600 dark:text-gray-400 {{ layout == 'horizontal' and not showLink ? 'flex-1 min-w-0' : '' }}">
                    {% if title %}
                        <p class="mb-1 text-xs font-medium uppercase tracking-wide text-gray-500 dark:text-gray-500">{{ title }}</p>
                    {% endif %}
                    {% block content %}{% endblock %}
                </div>
        {% if showLink %}
        </a>
        {% endif %}
    </div>
</div>