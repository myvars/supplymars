{% extends 'base.html.twig' %}

{% block title %}500 Server Error{% endblock %}

{% block body %}
        <section class="relative mx-auto flex items-center justify-center bg-white dark:bg-orange-400/10 md:h-screen" style="background: url({{ asset('images/martian_landscape.webp') }}) center center no-repeat; background-size: cover;">
            <div class="absolute inset-0 bg-gradient-to-b from-gray-950/60 via-gray-950/30 to-gray-950/80 pointer-events-none"></div>
            <div data-turbo-temporary class="relative mx-auto max-w-(--breakpoint-xl) px-4 py-8 sm:py-12 lg:px-6">
                <div class="mb-10 max-w-(--breakpoint-md)">
                    <p class="mb-4 text-7xl font-extrabold tracking-tight text-transparent bg-clip-text bg-gradient-to-r from-orange-400 to-amber-500 lg:text-9xl">500</p>
                    <h2 class="mb-4 text-3xl font-bold tracking-tight text-white md:text-4xl">System Malfunction in the Mars Colony</h2>
                    <p class="mb-4 text-lg font-light text-gray-300">
                        Yikes! It looks like something went wrong with the colony's systems.
                        Our Martian engineers are already on the case, working hard to fix the issue before it affects life support!
                    </p>
                    <p class="mb-8 text-sm text-gray-400">
                        Rest assured, we're fixing the glitch. Mars isn't perfect yet — but we're getting there!
                    </p>
                    <twig:Button tag="a" href="{{ path('app_homepage') }}" data-turbo-frame="body">Back to Colony HQ</twig:Button>
                </div>
            </div>
        </section>
{% endblock %}
