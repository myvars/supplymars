{% extends 'base.html.twig' %}

{% block title %}About Us{% endblock %}

{% block body %}
        <section class="flex items-center justify-center mx-auto md:h-screen bg-white dark:bg-orange-400/10" style="background: url({{ asset('images/martian_landscape.webp') }}) center center no-repeat; background-size: cover;">
            <div data-turbo-temporary class="py-8 px-4 mx-auto max-w-screen-xl sm:py-12 lg:px-6">
                <div class="max-w-screen-md mb-10 dark:text-white">
                    <h2 class="mb-8 text-3xl tracking-tight">500: System Malfunction in the Mars Colony</h2>
                    <p class="mb-4 sm:text-base">
                        Yikes! It looks like something went wrong with the colony’s systems.
                        Our Martian engineers are already on the case, working hard to fix the issue before it affects life support!
                    </p>
                    <p>
                        Rest assured, we’re fixing the glitch. Mars isn’t perfect yet - but we’re getting there!
                    </p>
                </div>
            </div>
        </section>
{% endblock %}