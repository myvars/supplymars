<!DOCTYPE html>
<html lang="en" class="dark">
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="theme-color" content="#cccccc">
    {% if app.environment != 'test' %}
        <meta name="view-transition">
        <meta name="turbo-refresh-method" content="replace">
        <meta name="turbo-refresh-scroll" content="preserve">
    {% endif %}
        <title>{% block title %}Butterfly{% endblock %}</title>
    {% block stylesheets %}{% endblock %}

    {% block javascripts %}
        {% block importmap %}{{ importmap('app') }}{% endblock %}
    {% endblock %}
</head>

<body class="bg-black text-white">
<div class="md:px-3 container mx-auto min-h-screen flex flex-col">
    <header class="mt-3">
        <nav class="bg-white rounded-t-lg border-gray-200 dark:bg-gray-900"
             data-controller="basic-drawer"
             data-basic-drawer-drawer-id-value="side-menu"
        >
            <div class="mx-auto px-3 py-2 max-w-screen-xl flex flex-wrap items-center justify-between">

                <div class="flex items-center justify-end">
                    <button id="navigationButton"
                            type="button"
                            class="inline-flex items-center p-2 w-10 h-10 justify-center text-sm text-gray-500 rounded-lg hover:bg-gray-100 focus:outline-none focus:ring-2 focus:ring-gray-200 dark:text-gray-400 dark:hover:bg-gray-700 dark:focus:ring-gray-600"
                            data-action="click->basic-drawer#open"
                    >
                        <span class="sr-only">Open side menu</span>
                        <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 17 14"><path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M1 1h15M1 7h15M1 13h15"/></svg>
                    </button>
                    <a href="{{ path('app_homepage') }}" class="flex space-x-3 rtl:space-x-reverse mx-4">
                        {{ include('logo/_logo.html.twig', { 'logoHeight': 40 }) }}
                    </a>
                </div>
                <div class="flex items-center md:order-2 space-x-3 md:space-x-0 rtl:space-x-reverse">
                    {% if is_granted('IS_AUTHENTICATED_REMEMBERED') %}
                        <button type="button"
                                class="flex text-sm bg-gray-800 rounded-full md:me-0 focus:ring-4 focus:ring-gray-300 dark:focus:ring-gray-600"
                                id="user-menu-button" aria-expanded="false" data-dropdown-toggle="user-dropdown"
                                data-dropdown-placement="bottom">
                            <span class="sr-only">Open user menu</span>
                            <img class="w-8 h-8 rounded-full" src="{{ asset('images/avatar.png') }}" alt="user photo">
                        </button>
                        <!-- Dropdown menu -->
                        <div
                            class="z-50 hidden my-3 text-base list-none bg-white divide-y divide-gray-100 rounded-lg shadow dark:bg-gray-700 dark:divide-gray-600"
                            id="user-dropdown">
                            <div class="px-3 py-3">
                                <span
                                    class="block text-sm text-gray-900 dark:text-white">{{ app.user.fullName }}</span>
                                <span
                                    class="block text-sm text-gray-500 truncate dark:text-gray-400">{{ app.user.userIdentifier }}</span>
                            </div>
                            <ul class="py-2" aria-labelledby="user-menu-button">
                                <li>
                                    <a href="#"
                                       class="block px-3 py-2 text-sm text-gray-700 hover:bg-gray-100 dark:hover:bg-gray-600 dark:text-gray-200 dark:hover:text-white">
                                        Settings
                                    </a>
                                </li>
                                <li>
                                    <a href="{{ path('app_logout') }}"
                                       data-turbo-prefetch="false"
                                       class="block px-3 py-2 text-sm text-gray-700 hover:bg-gray-100 dark:hover:bg-gray-600 dark:text-gray-200 dark:hover:text-white">
                                        Sign Out</a>
                                </li>
                            </ul>
                        </div>
                    {% else %}
                        <a
                            href="{{ path('app_login') }}"
                            class="block py-2 px-3 text-base text-gray-900 rounded hover:bg-gray-100 md:hover:bg-transparent md:hover:text-blue-700 md:p-0 dark:text-white md:dark:hover:text-blue-500 dark:hover:bg-gray-700 dark:hover:text-white md:dark:hover:bg-transparent dark:border-gray-700">
                            Sign In
                        </a>
                    {% endif %}
                </div>
                <div class="items-center justify-between hidden w-full md:flex md:w-auto md:order-1" id="navbar-user">
                    <ul class="flex flex-col font-medium p-3 md:p-0 mt-3 border border-gray-100 rounded-lg bg-gray-50 md:space-x-8 rtl:space-x-reverse md:flex-row md:mt-0 md:border-0 md:bg-white dark:bg-gray-800 md:dark:bg-gray-900 dark:border-gray-700">
                        {#
                        <li>
                            <a href="{{ path('app_product_index') }}" class="block py-2 px-3 text-sm text-gray-900 rounded hover:bg-gray-100 md:hover:bg-transparent md:hover:text-blue-700 md:p-0 dark:text-white md:dark:hover:text-blue-500 dark:hover:bg-gray-700 dark:hover:text-white md:dark:hover:bg-transparent dark:border-gray-700">Product</a>
                        </li>
                        <li>
                            <a href="{{ path('app_vat_rate_index') }}" class="block py-2 px-3 text-sm text-gray-900 rounded hover:bg-gray-100 md:hover:bg-transparent md:hover:text-blue-700 md:p-0 dark:text-white md:dark:hover:text-blue-500 dark:hover:bg-gray-700 dark:hover:text-white md:dark:hover:bg-transparent dark:border-gray-700">VAT</a>
                        </li>
                        #}
                    </ul>
                </div>
            </div>
            {{ include('_side_menu.html.twig') }}
        </nav>
    </header>

    <!-- Make sure the main tag takes up the remaining height -->
    <main class="flex-grow bg-gray-50 dark:bg-gray-900">
        <turbo-frame id="body" data-turbo-action="advance" refresh="morph">
        {% block body %}{% endblock %}
        </turbo-frame>
    </main>

    <!-- Footer -->


    <footer class="bg-white rounded-b-lg shadow dark:bg-gray-900">
        <div class="w-full max-w-screen-xl mx-auto p-3 mt-4">
            <div class="sm:flex sm:items-center sm:justify-between">
                <a href="{{ path('app_homepage') }}" class="flex items-center mb-4 sm:mb-0 space-x-3 rtl:space-x-reverse">
                    {{ include('logo/_logo.html.twig', { 'logoHeight': 40 }) }}
                </a>
                <ul class="flex flex-wrap items-center mb-6 text-sm font-medium text-gray-500 sm:mb-0 dark:text-gray-400">
                    <li>
                        <a href="{{ path('app_about_page') }}" data-turbo-frame="body" class="hover:underline me-4 md:me-6">About</a>
                    </li>
                    <li>
                        <a href="{{ path('app_terms_page') }}" data-turbo-frame="body" class="hover:underline me-4 md:me-6">T&Cs</a>
                    </li>
                    <li>
                        <a href="{{ path('app_privacy_page') }}" data-turbo-frame="body" class="hover:underline me-4 md:me-6">Privacy Policy</a>
                    </li>
                    <li>
                        <a href="{{ path('app_contact_page') }}" data-turbo-frame="body" class="hover:underline">Contact</a>
                    </li>
                </ul>
            </div>
            <hr class="my-6 border-gray-200 sm:mx-auto dark:border-gray-700 lg:my-8" />
            <span class="block text-sm text-gray-500 sm:text-center dark:text-gray-400">© 2024 <a href="{{ path('app_homepage') }}" class="hover:underline">{{ domain }}</a>. All Rights Reserved.</span>
        </div>
    </footer>
</div>

<!-- Modal -->
<twig:Modal closeButton="true">
    <turbo-frame
        id="modal"
        data-basic-modal-target="dynamicContent"
{#        data-action="turbo:before-fetch-request->basic-modal#showLoading"#}
        class="aria-busy:opacity-50 transition-opacity aria-busy:delay-700"
        refresh="morph"
    >
        {{ include ('_frameSuccessStream.html.twig', { frame: 'modal' }) }}
    </turbo-frame>
    <twig:block name="loading_template">
{#        <div class="flex justify-center items-center bg-space-pattern bg-cover rounded-lg p-20">
            <twig:ux:icon name="icomoon-free:spinner9" class="w-10 h-10 text-gray-400/40"/>
        </div>#}
    </twig:block>
</twig:Modal>

<!-- Flash Container -->
<div id="flash-container">
    {{ include('_flashes.html.twig') }}
</div>

<turbo-frame id="url-refresh"></turbo-frame>

</body>
</html>