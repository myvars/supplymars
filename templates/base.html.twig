<!DOCTYPE html>
<html lang="en">
    <head>
        <script>
            (function(){
                if ((localStorage.getItem('theme') || 'dark') === 'dark')
                    document.documentElement.classList.add('dark');
            })();
        </script>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <meta name="theme-color" content="#cccccc">
        <link rel="icon" type="image/png" href="{{ asset('images/icons/favicon-96x96.png') }}" sizes="96x96"/>
        <link rel="icon" type="image/svg+xml" href="{{ asset('images/icons/favicon.svg') }}"/>
        <link rel="shortcut icon" href="{{ asset('images/icons/favicon.ico') }}"/>
        <link rel="apple-touch-icon" sizes="180x180" href="{{ asset('images/icons/apple-touch-icon.png') }}"/>
        <meta name="apple-mobile-web-app-title" content="{{ domain|split('.')|first }}"/>
        <link rel="manifest" href="{{ asset('images/icons/site.webmanifest') }}"/>
        {% if app.environment != 'test' %}
            <meta name="turbo-view-transition" content="true">
            <meta name="turbo-refresh-method" content="replace">
            <meta name="turbo-refresh-scroll" content="preserve">
        {% endif %}
        <title>{% block title %}SupplyMars{% endblock %}</title>
        {% block stylesheets %}{% endblock %}
        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>

    <body class="antialiased bg-gray-100 text-gray-900 dark:bg-gray-950 dark:text-gray-100">
        <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:z-50 focus:rounded focus:bg-white focus:px-4 focus:py-2 focus:text-sm focus:font-medium focus:text-gray-900 focus:shadow-lg dark:focus:bg-gray-800 dark:focus:text-white">Skip to main content</a>
        {% if not playground_mode %}
            <div class="bg-amber-500 px-4 py-1.5 text-center text-xs font-medium tracking-wide text-amber-950">
                This is the live site.
            </div>
        {% endif %}
        <div class="container mx-auto flex min-h-screen flex-col md:px-3">

            <!-- Header -->
            {{ include('_header.html.twig') }}

            <!-- Main -->
            <main id="main-content" class="{% block main_class %}grow bg-gray-100 dark:bg-gray-900{% endblock %}">
                <turbo-frame id="body" data-turbo-action="advance" refresh="morph">
                    {% block body %}{% endblock %}
                </turbo-frame>
            </main>

            <!-- Footer -->
            {{ include('_footer.html.twig') }}

        </div>

        <!-- Modal -->
        {{ include('shared/turbo/_modal.html.twig') }}

        <!-- Flash Container -->
        <div id="flash-container" class="pointer-events-none fixed top-5 right-5 z-50 flex flex-col gap-3" aria-live="polite">
            {% if not app.request.headers.has('Turbo-Frame') %}
                {{ include('_flashes.html.twig') }}
            {% endif %}
        </div>

        <!-- Turbo Refresh -->
        <turbo-frame id="url-refresh"></turbo-frame>

    </body>
</html>
