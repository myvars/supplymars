<!DOCTYPE html>
<html lang="en" class="dark">
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="theme-color" content="#cccccc">
    {% if app.environment != 'test' %}
        <meta name="view-transition">
        <meta name="turbo-refresh-method" content="replace">
        <meta name="turbo-refresh-scroll" content="preserve">
    {% endif %}
    <title>{% block title %}Butterfly{% endblock %}</title>
    {% block stylesheets %}{% endblock %}

    {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% block importmap %}{{ importmap('app') }}{% endblock %}
    {% endblock %}
</head>

<body class="bg-black text-white">
<div class="container mx-auto flex min-h-screen flex-col md:px-3">
    <header class="mt-3">
        <nav class="rounded-t-lg border-gray-200 bg-white dark:bg-gray-900"
             data-controller="basic-drawer"
             data-basic-drawer-drawer-id-value="side-menu"
        >
            <div class="mx-auto flex max-w-screen-xl flex-wrap items-center justify-between px-3 py-2">

                <div class="flex items-center justify-end">
                    <button id="navigationButton"
                            type="button"
                            class="inline-flex h-10 w-10 items-center justify-center rounded p-2 text-sm text-gray-500 hover:bg-gray-100 focus:outline-none focus:ring-2 focus:ring-gray-200 dark:text-gray-400 dark:hover:bg-gray-700 dark:focus:ring-gray-600"
                            data-action="click->basic-drawer#open"
                    >
                        <span class="sr-only">Open side menu</span>
                        <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 17 14"><path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M1 1h15M1 7h15M1 13h15"/></svg>
                    </button>
                    <a href="{{ path('app_homepage') }}" class="mx-4 flex space-x-3 rtl:space-x-reverse"
                       data-turbo-frame="body">
                        {{ include('logo/_logo.html.twig', { 'logoHeight': 40 }) }}
                    </a>
                </div>
                <div class="flex items-center space-x-3 rtl:space-x-reverse md:space-x-0 md:order-2">
                    {% if is_granted('IS_AUTHENTICATED_REMEMBERED') %}
                        <button type="button"
                                class="flex rounded-full text-sm md:me-0"
                                id="user-menu-button" aria-expanded="false" data-dropdown-toggle="user-dropdown"
                                data-dropdown-placement="bottom">
                            <span class="sr-only">Open user menu</span>
                            <img class="h-6 w-6" src="{{ asset('images/avatar.png') }}" alt="user photo">
                        </button>
                        <!-- Dropdown menu -->
                        <div
                            class="z-50 my-3 hidden list-none rounded bg-white text-base shadow divide-y divide-gray-100 dark:divide-gray-600 dark:bg-gray-700"
                            id="user-dropdown">
                            <div class="px-3 py-3">
                                <span
                                    class="block text-sm text-gray-900 dark:text-white">{{ app.user.fullName }}</span>
                                <span
                                    class="block truncate text-sm text-gray-500 dark:text-gray-400">{{ app.user.userIdentifier }}</span>
                            </div>
                            <ul class="py-2" aria-labelledby="user-menu-button">
                                <li>
                                    <a href="{{ path('app_customer_show', { id: app.user.id  }) }}" class="block px-3 py-2 text-sm text-gray-700 hover:bg-gray-100 dark:text-gray-200 dark:hover:bg-gray-600 dark:hover:text-white"
                                       data-turbo-frame="body"
                                    >Settings</a>
                                </li>
                                <li>
                                    <a href="{{ path('app_logout') }}"
                                       class="block px-3 py-2 text-sm text-gray-700 hover:bg-gray-100 dark:text-gray-200 dark:hover:bg-gray-600 dark:hover:text-white"
                                       data-turbo-prefetch="false"
                                       data-turbo-frame="_top"
                                    >Sign Out</a>
                                </li>
                            </ul>
                        </div>
                    {% else %}
                        <a
                            href="{{ path('app_login') }}"
                            class="block rounded px-3 py-2 text-base text-gray-900 hover:bg-gray-100 dark:border-gray-700 dark:text-white md:p-0 dark:hover:bg-gray-700 dark:hover:text-white md:hover:bg-transparent md:hover:text-blue-700 md:dark:hover:bg-transparent md:dark:hover:text-blue-500"
                            data-turbo-frame="_top"
                        >Sign In</a>
                    {% endif %}
                </div>
            </div>
            {{ include('_side_menu.html.twig') }}
        </nav>
    </header>

    <!-- Make sure the main tag takes up the remaining height -->
    <main class="flex-grow bg-gray-50 dark:bg-gray-900">
        <turbo-frame id="body" data-turbo-action="advance" refresh="morph">
            {% block body %}{% endblock %}
        </turbo-frame>
    </main>

    <!-- Footer -->
    <footer class="rounded-b-lg bg-white shadow dark:bg-gray-900">
        <div class="mx-auto mt-4 w-full max-w-screen-xl p-3">
            <div class="sm:flex sm:items-center sm:justify-between">
                <a href="{{ path('app_homepage') }}"
                   class="mb-4 flex items-center space-x-3 rtl:space-x-reverse sm:mb-0">
                    {{ include('logo/_logo.html.twig', { 'logoHeight': 40 }) }}
                </a>
                <ul class="mb-6 flex flex-wrap items-center text-sm font-medium text-gray-500 dark:text-gray-400 sm:mb-0">
                    <li>
                        <a href="{{ path('app_about_page') }}" data-turbo-frame="body"
                           class="me-4 hover:underline md:me-6">About</a>
                    </li>
                    <li>
                        <a href="{{ path('app_terms_page') }}" data-turbo-frame="body"
                           class="me-4 hover:underline md:me-6">T&Cs</a>
                    </li>
                    <li>
                        <a href="{{ path('app_privacy_page') }}" data-turbo-frame="body"
                           class="me-4 hover:underline md:me-6">Privacy Policy</a>
                    </li>
                    <li>
                        <a href="{{ path('app_contact_page') }}" data-turbo-frame="body"
                           class="hover:underline">Contact</a>
                    </li>
                </ul>
            </div>
            <hr class="my-6 border-gray-200 dark:border-gray-700 sm:mx-auto lg:my-8"/>
            <span class="block text-sm text-gray-500 dark:text-gray-400 sm:text-center">© 2024
                <a href="{{ path('app_homepage') }}" class="hover:underline">{{ domain }}</a>
                . All Rights Reserved.
            </span>
        </div>
    </footer>
</div>

<!-- Modal -->
<twig:Modal closeButton="true">
    <turbo-frame
        id="modal"
        data-basic-modal-target="dynamicContent"
        {#        data-action="turbo:before-fetch-request->basic-modal#showLoading" #}
        class="aria-busy:opacity-50 transition-opacity aria-busy:delay-700"
        refresh="morph"
    >
        {{ include ('_frameSuccessStream.html.twig', { frame: 'modal' }) }}
    </turbo-frame>
    <twig:block name="loading_template">
        {#        <div class="flex items-center justify-center rounded bg-cover p-20 bg-space-pattern">
            <twig:ux:icon name="icomoon-free:spinner9" class="h-10 w-10 text-gray-400/40"/>
        </div> #}
    </twig:block>
</twig:Modal>

<!-- Flash Container -->
<div id="flash-container">
    {% if not app.request.headers.has('Turbo-Frame') %}
        {{ include('_flashes.html.twig') }}
    {% endif %}
</div>

<turbo-frame id="url-refresh"></turbo-frame>

</body>
</html>