{% extends 'base.html.twig' %}

{% block title %}Forgot password{% endblock %}

{% block body %}
    <section class="rounded-lg bg-gray-50 dark:bg-gray-900 md:h-screen" style="background: url({{ asset('images/martian_landscape.webp') }}) center center no-repeat; background-size: cover;">
        <div class="mx-auto flex flex-col items-center px-6 py-8 lg:py-0">
            <div
                class="w-full rounded-lg bg-white shadow dark:border dark:border-gray-700 dark:bg-gray-800 sm:max-w-md md:m-10 xl:p-0">
                <div class="p-6 space-y-4 sm:p-8 md:space-y-6">
                    <h1 class="text-xl font-bold leading-tight tracking-tight text-gray-900 dark:text-white md:text-2xl">
                        Forgot Password
                    </h1>
                    {% for flash_error in app.flashes('reset_password_error') %}
                        <div
                            class="mb-4 flex items-center rounded-lg border border-red-300 bg-red-50 p-4 text-sm text-red-800 dark:border-red-800 dark:bg-gray-800 dark:text-red-400"
                            role="alert">
                            <svg class="inline h-4 w-4 flex-shrink-0 me-3" aria-hidden="true"
                                 xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 20 20">
                                <path
                                    d="M10 .5a9.5 9.5 0 1 0 9.5 9.5A9.51 9.51 0 0 0 10 .5ZM9.5 4a1.5 1.5 0 1 1 0 3 1.5 1.5 0 0 1 0-3ZM12 15H8a1 1 0 0 1 0-2h1v-3H8a1 1 0 0 1 0-2h2a1 1 0 0 1 1 1v4h1a1 1 0 0 1 0 2Z"/>
                            </svg>
                            <span class="sr-only">Info</span>
                            <div>
                                <span class="font-medium">{{ flash_error }}</span>
                            </div>
                        </div>
                    {% endfor %}
                    {{ form_start(requestForm, {
                        'attr': {
                            'class': 'space-y-4 md:space-y-6',
                            'novalidate': 'novalidate',
                        }
                    }) }}
                    {{ form_row(requestForm.email) }}

                    <div class="mb-3">
                        <small>
                            Enter your email address and we will send you a
                            link to reset your password.
                        </small>
                    </div>

                    <twig:Button type="submit" class="w-full">Send Email</twig:Button>
                    <p class="text-sm font-light text-gray-500 dark:text-gray-400">
                        Remembered your details?
                        <a
                            href="{{ path('app_login') }}"
                            class="font-medium text-primary-600 hover:underline dark:text-primary-500"
                        >
                            Login here
                        </a>
                    </p>
                    {{ form_end(requestForm) }}
                </div>
            </div>
        </div>
    </section>
{% endblock %}
