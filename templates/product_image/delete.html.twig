{% extends 'modalBase.html.twig' %}

{% block title %}Delete Product Image{% endblock %}

{% block body %}
    <div class="relative p-6 bg-white rounded-lg shadow dark:bg-gray-800 sm:p-5">
        <div class="flex justify-between items-center pb-4 mb-4 rounded-t border-b sm:mb-5 dark:border-gray-600">
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white">
                Delete product Image
            </h3>
        </div>
        <div class="space-y-4 md:space-y-6">
            <p class="text-base text-gray-500 dark:text-white">
                {{ result.Imagename }}
            </p>
            <p><img src="{{ asset(product_uploads~result.imageName) | imagine_filter('my_thumbnail') }}"  alt=""/></p>
            <p class="text-sm font-light text-gray-500 dark:text-gray-400">
                Are you sure you want to delete this Product Image?
            </p>
            <form method="post" action="{{ path('app_product_image_delete', {'id': result.id}) }}">
                <input type="hidden" name="_token" value="{{ csrf_token('delete'~result.id) }}">
                <twig:Button type="submit" variant="danger" class="w-full">Delete</twig:Button>
            </form>
            <p class="text-sm font-light text-gray-500 dark:text-gray-400">
                <a href="{{ path('app_product_show', {'id': result.product.id}) }}" class="hover:underline">Back to list</a>
            </p>
        </div>
    </div>
{% endblock %}