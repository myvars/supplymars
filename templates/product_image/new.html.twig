{% extends 'modalBase.html.twig' %}

{% block title %}New Product Image{% endblock %}

{% block body %}
    <div class="relative p-6 bg-white rounded-lg shadow dark:bg-gray-800 sm:p-5">
        <div class="flex justify-between items-center pb-4 mb-4 rounded-t border-b sm:mb-5 dark:border-gray-600">
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white">
                Create new Product Image
            </h3>
        </div>
        {{ form_start(form, {
            'attr': {
                'class': 'space-y-4 md:space-y-6',
                'novalidate': 'novalidate',
            }
        }) }}
        {{ form_widget(form) }}
        <twig:Button type="submit" class="w-full" name="btnSubmit" value="submit">Add Product Image</twig:Button>
        {{ form_end(form) }}
    </div>
{% endblock %}