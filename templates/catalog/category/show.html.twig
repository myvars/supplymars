{# Category detail page — composes _category_card, _category_products_card,
   _subcategories_card, and embedded sales dashboard. Variable: result (Category) #}
{% extends 'base.html.twig' %}

{% block title %}Category Details{% endblock %}

{% block body %}

    <div class="m-3 space-y-4">
        <twig:Breadcrumb :href="path('app_catalog_category_index')" label="Categories" :current="result.name"/>
        {{ include('catalog/category/_category_card.html.twig', {category: result}) }}
        {% if result.subcategories.count > 0 %}
            {{ include('catalog/category/_subcategories_card.html.twig', {subcategories: result.subcategories}) }}
        {% endif %}
        {{ include('reporting/_dashboard_card.html.twig', {
            dashboardSrc: path('app_reports_product_sales', {categoryId: result.id})
        }) }}
    </div>

{% endblock %}
