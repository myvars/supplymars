{# Category detail card with inline-editable name, VAT rate, and markup info.
   Used on: category show page. Variable: category (Category) #}
<twig:Card editLink="{{ path('app_catalog_category_edit', {id: category.publicId.value}) }}" title="Category" statusHighlight="{{ category.isActive ? 'ACTIVE' : 'INACTIVE' }}">
    <p class="mb-3">{{ include('catalog/category/_inline_name.html.twig', {category: category}) }}</p>
    <div class="space-y-2 text-sm text-gray-600 dark:text-gray-400">
        <p class="flex items-center gap-2">
            <twig:ux:icon name="mdi:percent-outline" class="h-4 w-4 text-gray-400 dark:text-gray-500"/>
            {{ category.defaultMarkup|number_format(3) }}% mark-up
        </p>
        <p class="flex items-center gap-2">
            <twig:ux:icon name="mdi:tag-outline" class="h-4 w-4 text-gray-400 dark:text-gray-500"/>
            {{ category.priceModel.getName }} price model
        </p>
        <p class="flex items-center gap-2">
            <twig:ux:icon name="bi:receipt" class="h-4 w-4 text-gray-400 dark:text-gray-500"/>
            {{ category.vatRate.name }} VAT
        </p>
        <p class="flex items-center gap-2">
            <twig:ux:icon name="bi:person" class="h-4 w-4 text-gray-400 dark:text-gray-500"/>
            {{ category.owner.fullName }}
        </p>
    </div>
    <twig:CardFooter :updatedAt="category.updatedAt">
        <twig:StatusBadge status="{{ category.isActive ? 'ACTIVE' : 'INACTIVE' }}"/>
    </twig:CardFooter>
    {% if category.products.count > 0 %}
        <div class="-mx-3 -mb-3 mt-3 border-t border-gray-200 dark:border-white/10">
            <a href="{{ path('app_catalog_product_index', {categoryId: category.id}) }}"
               class="group flex items-center justify-between rounded-b-xl px-3 py-2.5 text-sm text-gray-600 hover:bg-gray-50 hover:text-gray-900 dark:text-gray-400 dark:hover:bg-white/5 dark:hover:text-gray-200"
               data-turbo-frame="body"
            >
                <span class="flex items-center gap-2">
                    <twig:ux:icon name="bi:box-seam" class="h-4 w-4 text-gray-400 dark:text-gray-500"/>
                    {{ category.products.count }}
                    {{ category.products.count == 1 ? 'product': 'products' }} in this category
                </span>
                <twig:ux:icon name="bi:arrow-right" class="h-4 w-4 text-gray-400 transition-transform duration-150 group-hover:translate-x-0.5 group-hover:text-primary-500 dark:text-gray-500"/>
            </a>
        </div>
    {% endif %}
</twig:Card>
