{# Subcategories list for a category — links to each subcategory show page.
   Used on: category show page. Variable: subcategories (Collection of Subcategory) #}
<twig:Card title="Subcategories">
    <ul class="-mx-3 -mb-3 divide-y divide-gray-200 dark:divide-white/10">
        {% for subcategory in subcategories %}
            <li>
                <a href="{{ path('app_catalog_subcategory_show', {'id': subcategory.publicId.value }) }}"
                   class="group flex items-center justify-between px-3 py-2.5 text-sm text-gray-600 hover:bg-gray-50 hover:text-gray-900 dark:text-gray-400 dark:hover:bg-white/5 dark:hover:text-gray-200 {{ loop.last ? 'rounded-b-xl' }}"
                   data-turbo-frame="body"
                >
                    <span class="flex items-center gap-2">
                        <twig:ux:icon name="bi:folder" class="h-4 w-4 text-gray-400 dark:text-gray-500"/>
                        <span class="line-clamp-1">{{ subcategory.name }}</span>
                    </span>
                    <div class="ml-4 shrink-0">
                        <twig:StatusBadge status="{{ subcategory.isActive ? 'ACTIVE' : 'INACTIVE' }}"/>
                    </div>
                </a>
            </li>
        {% endfor %}
    </ul>
</twig:Card>
