<twig:Card title="Subcategories">
    <ul class="-mx-3 -mb-1 divide-y divide-gray-100 dark:divide-gray-700/50">
        {% for subcategory in subcategories %}
            <li>
                <a href="{{ path('app_catalog_subcategory_show', {'id': subcategory.publicId.value }) }}"
                   class="group flex items-center justify-between px-3 py-2.5 text-sm transition-colors duration-150 hover:bg-gray-50 dark:hover:bg-gray-700/30"
                   data-turbo-frame="body"
                >
                    <span class="flex items-center gap-2 text-gray-700 group-hover:text-gray-900 dark:text-gray-300 dark:group-hover:text-white">
                        <twig:ux:icon name="bi:folder" class="h-4 w-4 text-gray-400 dark:text-gray-500"/>
                        <span class="line-clamp-1">{{ subcategory.name }}</span>
                    </span>
                    <div class="ml-4 shrink-0">
                        <twig:StatusBadge status="{{ subcategory.isActive ? 'ACTIVE' : 'INACTIVE' }}"/>
                    </div>
                </a>
            </li>
        {% endfor %}
    </ul>
</twig:Card>
