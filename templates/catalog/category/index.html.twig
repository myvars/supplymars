{% extends 'base.html.twig' %}

{% block title %}Category Search{% endblock %}

{% block body %}
    <twig:Search
        flowModel="{{ flowModel }}"
        routes="{{ routes }}"
        results="{{ results }}"
    >
        <twig:block name="sort">
            <twig:Card>
                <div class="flex justify-between overflow-auto">
                    <twig:SortLink sortValue="id">Id</twig:SortLink>
                    <twig:SortLink sortValue="name">Category</twig:SortLink>
                    <twig:SortLink sortValue="defaultMarkup">Markup</twig:SortLink>
                    <twig:SortLink sortValue="isActive">Status</twig:SortLink>
                </div>
            </twig:Card>
        </twig:block>

        <twig:block name="list_item">
            <twig:Card
                editLink="{{ path('app_catalog_category_edit', {'id': result.publicId.value }) }}"
                showLink="{{ path('app_catalog_category_show', {'id': result.publicId.value }) }}"
                statusHighlight="{{ result.isActive ? 'ACTIVE' : 'INACTIVE' }}"
            >
                <div class="flex items-center justify-between pe-6">
                    <p class="text-lg font-semibold text-gray-900 line-clamp-1 dark:text-white">{{ result.name }}</p>
                    <twig:StatusBadge status="{{ result.isActive ? 'ACTIVE' : 'INACTIVE' }}"/>
                </div>
                <div class="mt-2 flex items-center justify-between">
                    <div class="flex items-center gap-3">
                        <p class="text-xs text-gray-500 dark:text-gray-500">Managed by {{ result.owner.fullName }}</p>
                    </div>
                    <p class="text-sm text-gray-700 dark:text-gray-300">{{ result.defaultMarkup|number_format(3) }}% mark-up</p>
                </div>
            </twig:Card>
        </twig:block>
    </twig:Search>

{% endblock %}
