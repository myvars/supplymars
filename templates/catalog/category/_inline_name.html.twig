{#
    Inline editable category name.

    Include this partial in place of a static category name display.
    The InlineEdit component handles the edit/save flow via Turbo Frames.

    Variables:
    - category: The Category entity
#}
<twig:InlineEdit
    editUrl="{{ path('app_catalog_category_inline_name', {id: category.publicId}) }}"
    frameId="inline-edit-category-{{ category.publicId }}-name"
    displayClass="text-lg font-semibold text-gray-900 line-clamp-1 dark:text-white"
>
    {{ category.name }}
</twig:InlineEdit>
