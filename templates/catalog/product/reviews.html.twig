{% extends 'base.html.twig' %}

{% block title %}Product Reviews{% endblock %}

{% block body %}
    {{ include('catalog/product/_navigation.html.twig', {result: result}) }}
    <div class="m-3 space-y-4">
        {{ include('review/_review_summary_card.html.twig', {summary: summary}) }}
        {% for review in reviews %}
            {{ include('review/_review_preview_card.html.twig', {review: review}) }}
        {% else %}
            <twig:EmptyState icon="flowbite:star-solid" message="No published reviews yet"/>
        {% endfor %}
        {% if reviews is not empty %}
            <div class="flex justify-end">
                <a href="{{ path('app_review_index', {productId: result.id}) }}"
                   class="inline-flex items-center gap-1 text-sm font-medium text-primary-600 hover:text-primary-700 dark:text-primary-400 dark:hover:text-primary-300"
                   data-turbo-frame="body">
                    View all reviews
                    <twig:ux:icon name="bi:arrow-right" class="h-3.5 w-3.5"/>
                </a>
            </div>
        {% endif %}
    </div>
{% endblock %}
