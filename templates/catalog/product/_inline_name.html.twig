{#
    Inline editable product name.

    Variables:
    - product: The Product entity
#}
<twig:InlineEdit
    editUrl="{{ path('app_catalog_product_inline_name', {id: product.publicId}) }}"
    frameId="inline-edit-product-{{ product.publicId }}-name"
    displayClass="text-lg font-semibold text-gray-900 dark:text-white"
>
    {{ product.name }}
</twig:InlineEdit>
