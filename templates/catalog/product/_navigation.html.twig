{% set current_route = app.request.attributes.get('_route') %}
{% set pid = result.publicId.value %}

{% set tabs = [
    { route: 'app_catalog_product_show', label: 'Details', icon: 'mdi:text-box-outline' },
    { route: 'app_pricing_stock', label: 'Stock', icon: 'mdi:package-variant-closed' },
    { route: 'app_pricing_cost', label: 'Cost', icon: 'mdi:tag-outline' },
    { route: 'app_catalog_product_image_show', label: 'Images', icon: 'mdi:image-multiple-outline' },
    { route: 'app_catalog_product_sales', label: 'Sales', icon: 'mdi:chart-line' },
    { route: 'app_catalog_product_history', label: 'History', icon: 'mdi:chart-timeline-variant' },
    { route: 'app_catalog_product_reviews', label: 'Reviews', icon: 'mdi:star-outline' },
] %}

<div class="mb-5 border-b border-gray-200 dark:border-gray-700">
    <nav class="-mb-px flex justify-center gap-x-1" aria-label="Product tabs">
        {% for tab in tabs %}
            {% set is_active = current_route == tab.route %}
            <a href="{{ path(tab.route, { id: pid }) }}"
               class="group inline-flex items-center gap-1.5 border-b-2 px-3 py-3 text-sm font-medium whitespace-nowrap transition-colors duration-150
                   {{ is_active
                       ? 'border-primary-500 text-primary-600 dark:border-primary-400 dark:text-primary-400'
                       : 'border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700 dark:text-gray-400 dark:hover:border-gray-600 dark:hover:text-gray-300'
                   }}"
               {% if is_active %}aria-current="page"{% endif %}
               title="{{ tab.label }}"
            >
                <twig:ux:icon :name="tab.icon" class="h-4 w-4 shrink-0
                    {{ is_active
                        ? 'text-primary-500 dark:text-primary-400'
                        : 'text-gray-400 group-hover:text-gray-500 dark:text-gray-500 dark:group-hover:text-gray-400'
                    }}"
                />
                <span class="inline-flex max-md:hidden">{{ tab.label }}</span>
            </a>
        {% endfor %}
    </nav>
</div>
