{% extends 'base.html.twig' %}

{% block title %}Product Search{% endblock %}

{% block body %}
    <twig:Search
        flowModel="{{ flowModel }}"
        flowRoute="{{ flowRoute }}"
        results="{{ results }}"
    >
        <twig:block name="sort">
            <twig:Card>
                <div class="flex justify-between overflow-auto">
                    <twig:SortLink sortValue="id">Id</twig:SortLink>
                    <twig:SortLink sortValue="name">Product</twig:SortLink>
                    <twig:SortLink sortValue="stock">Stock</twig:SortLink>
                    <twig:SortLink sortValue="sellPriceIncVat">Price</twig:SortLink>
                    <twig:SortLink sortValue="isActive">Status</twig:SortLink>
                </div>
            </twig:Card>
        </twig:block>
        <twig:block name="list_item">
            <twig:Card
                editLink="{{ path('app_catalog_product_edit', {'id': result.publicId.value }) }}"
                showLink="{{ path('app_catalog_product_show', {'id': result.publicId.value }) }}"
                padding="p-0"
            >
                <div class="flex items-center justify-between">
                    <twig:ProductImage
                        imageName="{{ result.hasProductImage ? result.getFirstImage.imageName : null }}"
                        filter="medium_thumbnail"
                        alt="{{ result.name }}"
                    ></twig:ProductImage>
                    <div class="m-3 w-full">
                        <p class="text-lg text-gray-900 dark:text-white line-clamp-1">{{ result.name }}</p>
                        <p class="mb-2 text-sm">Product {{ '%06d'|format(result.id) }}</p>
                        <div class="flex items-center justify-between">
                            <p class="text-base md:text-lg font-extralight me-1">{{ result.sellPriceIncVat|format_currency('GBP') }}
                                <span class="hidden md:inline text-sm text-gray-500 me-1 text-nowrap dark:text-gray-400"> inc VAT</span>
                            </p>
                            <p class="font-extralight me-1">{{ result.stock }} stock</p>
                            {% if result.isActive %}
                                <p class="text-green-500">Active</p>
                            {% else %}
                                <p class="text-red-500">InActive</p>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </twig:Card>
        </twig:block>

        <twig:block name="add">
            <twig:Button
                tag="a"
                href="{{ path('app_catalog_product_new') }}"
                class="flex items-center font-bold space-x-1"
                data-turbo-frame="modal"
            >
                <twig:ux:icon name="flowbite:circle-plus-outline" class="w-5"/>
                <span>Create Product</span>
            </twig:Button>
        </twig:block>

    </twig:Search>

{% endblock %}
