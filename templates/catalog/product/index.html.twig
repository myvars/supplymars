{% extends 'base.html.twig' %}

{% block title %}Product Search{% endblock %}

{% block body %}
    <twig:Search
        flowModel="{{ flowModel }}"
        routes="{{ routes }}"
        results="{{ results }}"
    >
        <twig:block name="sort">
            <twig:Card>
                <div class="flex justify-between overflow-auto">
                    <twig:SortLink sortValue="id">Id</twig:SortLink>
                    <twig:SortLink sortValue="name">Product</twig:SortLink>
                    <twig:SortLink sortValue="stock">Stock</twig:SortLink>
                    <twig:SortLink sortValue="sellPriceIncVat">Price</twig:SortLink>
                    <twig:SortLink sortValue="isActive">Status</twig:SortLink>
                </div>
            </twig:Card>
        </twig:block>
        <twig:block name="list_item">
            <twig:Card
                editLink="{{ path('app_catalog_product_edit', {'id': result.publicId.value }) }}"
                showLink="{{ path('app_catalog_product_show', {'id': result.publicId.value }) }}"
                padding="p-0"
            >
                <div class="flex">
                    <twig:ProductImage
                        imageName="{{ result.hasProductImage ? result.getFirstImage.imageName : null }}"
                        filter="medium_thumbnail"
                        alt="{{ result.name }}"
                    ></twig:ProductImage>
                    <div class="flex flex-1 min-w-0 flex-col justify-center py-3 ps-3 pe-8">
                        <div class="flex items-center justify-between">
                            <p class="text-lg font-semibold text-gray-900 dark:text-white line-clamp-1">{{ result.name }}</p>
                            <twig:StatusBadge status="{{ result.isActive ? 'ACTIVE' : 'INACTIVE' }}"/>
                        </div>
                        <p class="mt-0.5 flex items-center gap-1.5 -ms-0.5 text-xs text-gray-500 dark:text-gray-400">
                            <twig:ux:icon name="mdi:pound" class="h-3.5 w-3.5 text-gray-400 dark:text-gray-500"/>
                            {{ '%06d'|format(result.id) }}
                        </p>
                        {% set stockClasses = result.stock > 0
                            ? 'bg-green-50 text-green-700 dark:bg-green-900/30 dark:text-green-400'
                            : 'bg-red-50 text-red-700 dark:bg-red-900/30 dark:text-red-400' %}
                        <div class="mt-2 flex items-baseline justify-between">
                            <span class="inline-block rounded-full -ms-2 px-2 py-0.5 text-xs font-medium {{ stockClasses }}">
                                {{ result.stock > 0 ? result.stock ~ ' in stock' : 'Out of stock' }}
                            </span>
                            <p class="text-xl font-semibold shrink-0 ms-3 text-gray-900 dark:text-white">
                                {{ result.sellPriceIncVat|format_currency('GBP') }}
                                <span class="hidden md:inline text-xs font-normal text-gray-500 dark:text-gray-400">inc VAT</span>
                            </p>
                        </div>
                    </div>
                </div>
            </twig:Card>
        </twig:block>
    </twig:Search>

{% endblock %}
