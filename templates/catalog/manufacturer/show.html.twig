{% extends 'base.html.twig' %}

{% block title %}Manufacturer Details{% endblock %}

{% block body %}

    <div class="m-3 space-y-4">
        {{ include('catalog/manufacturer/_manufacturer_card.html.twig', {manufacturer: result}) }}
        {% if result.products.count > 0 %}
            {{ include('catalog/manufacturer/_manufacturer_products_card.html.twig', {manufacturer: result}) }}
        {% endif %}
        {{ include('reporting/_dashboard_card.html.twig', {
            dashboardSrc: path('app_reporting_dashboard_product_sales', {manufacturerId: result.id})
        }) }}
        <div class="flex">
            <a href="{{ path('app_catalog_manufacturer_index') }}"
               class="inline-flex items-center gap-1 text-sm font-medium text-primary-600 hover:text-primary-700 dark:text-primary-400 dark:hover:text-primary-300"
               data-turbo-frame="body">
                <twig:ux:icon name="bi:arrow-left" class="h-3.5 w-3.5"/>
                View all manufacturers
            </a>
        </div>
    </div>

{% endblock %}
