{# Manufacturer detail page — composes _manufacturer_card, _manufacturer_products_card,
   and embedded sales dashboard. Variable: result (Manufacturer) #}
{% extends 'base.html.twig' %}

{% block title %}Manufacturer Details{% endblock %}

{% block body %}

    <div class="m-3 space-y-4">
        {{ include('catalog/manufacturer/_manufacturer_card.html.twig', {manufacturer: result}) }}
        {{ include('reporting/_dashboard_card.html.twig', {
            dashboardSrc: path('app_reporting_dashboard_product_sales', {manufacturerId: result.id})
        }) }}
        <twig:BackLink :href="path('app_catalog_manufacturer_index')" label="View all manufacturers"/>
    </div>

{% endblock %}
