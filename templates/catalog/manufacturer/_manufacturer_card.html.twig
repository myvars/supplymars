{# Manufacturer detail card with inline-editable name and status.
   Used on: manufacturer show page. Variable: manufacturer (Manufacturer) #}
<twig:Card editLink="{{ path('app_catalog_manufacturer_edit', {'id': manufacturer.publicId.value }) }}" title="Manufacturer" statusHighlight="{{ manufacturer.isActive ? 'ACTIVE' : 'INACTIVE' }}">
    <p class="mb-3">{{ include('catalog/manufacturer/_inline_name.html.twig', {manufacturer: manufacturer}) }}</p>
    <twig:CardFooter :updatedAt="manufacturer.updatedAt">
        <twig:StatusBadge status="{{ manufacturer.isActive ? 'ACTIVE' : 'INACTIVE' }}"/>
    </twig:CardFooter>
    {% if manufacturer.products.count > 0 %}
        <div class="-mx-3 -mb-3 mt-3 border-t border-gray-200 dark:border-gray-600">
            <a href="{{ path('app_catalog_product_index', {manufacturerId: manufacturer.id}) }}"
               class="group flex items-center justify-between rounded-b-xl px-3 py-2.5 text-sm text-gray-600 hover:bg-gray-50 hover:text-gray-900 dark:text-gray-400 dark:hover:bg-white/5 dark:hover:text-gray-200"
               data-turbo-frame="body"
            >
                <span class="flex items-center gap-2">
                    <twig:ux:icon name="bi:box-seam" class="h-4 w-4 text-gray-400 dark:text-gray-500"/>
                    {{ manufacturer.products.count }}
                    {{ manufacturer.products.count == 1 ? 'product': 'products' }} from this manufacturer
                </span>
                <twig:ux:icon name="bi:arrow-right" class="h-4 w-4 text-gray-400 transition-transform duration-150 group-hover:translate-x-0.5 group-hover:text-primary-500 dark:text-gray-500"/>
            </a>
        </div>
    {% endif %}
</twig:Card>
