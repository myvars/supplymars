<twig:Card editLink="{{ path('app_catalog_subcategory_edit', { id: subcategory.publicId.value }) }}" title="Subcategory">
    <p class="text-xl text-gray-900 line-clamp-1 dark:text-white">{{ subcategory.name }}</p>
    <p class="mb-2 line-clamp-1">
        Found in
        <a href="{{ path('app_catalog_category_show', {id: subcategory.category.publicId}) }}"
           data-turbo-frame="body"
           class="text-gray-700 hover:text-blue-600 dark:text-gray-400 dark:hover:text-white">
            {{ subcategory.category.name }}
        </a>
    </p>
    <ul class="list-inside list-disc">
        <li>
            {% if subcategory.hasDefaultMarkup %}
                {{ subcategory.defaultMarkup|number_format(3) }}% mark-up
            {% else %}
                No subcategory mark-up
            {% endif %}
        </li>
        <li>
            {% if subcategory.hasPriceModel %}
                {{ subcategory.priceModel.getName }} price model
            {% else %}
                No subcategory price model
            {% endif %}
        </li>
        <li>
            {% if subcategory.hasOwner %}
                Managed by {{ subcategory.owner.fullName }}
            {% else %}
                No subcategory manager
            {% endif %}
        </li>
    </ul>
    <div class="mt-2 flex items-center justify-between">
        <p class="text-xs text-gray-600 me-10 dark:text-gray-500">Updated {{ subcategory.updatedAt|ago }}</p>
        {% if subcategory.isActive %}
            <p class="text-green-500">Active</p>
        {% else %}
            <p class="text-red-500">InActive</p>
        {% endif %}
    </div>
</twig:Card>
