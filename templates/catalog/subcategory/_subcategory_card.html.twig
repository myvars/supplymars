{# Subcategory detail card with inline-editable name, parent category, and markup.
   Used on: subcategory show page. Variable: subcategory (Subcategory) #}
<twig:Card editLink="{{ path('app_catalog_subcategory_edit', { id: subcategory.publicId.value }) }}" title="Subcategory" statusHighlight="{{ subcategory.isActive ? 'ACTIVE' : 'INACTIVE' }}">
    <p class="mb-1">{{ include('catalog/subcategory/_inline_name.html.twig', {subcategory: subcategory}) }}</p>
    <p class="mb-3 text-sm text-gray-500 line-clamp-1 dark:text-gray-400">
        in
        <a href="{{ path('app_catalog_category_show', {id: subcategory.category.publicId}) }}"
           data-turbo-frame="body"
           class="font-medium text-primary-600 hover:text-primary-700 dark:text-primary-400 dark:hover:text-primary-300">
            {{ subcategory.category.name }}
        </a>
    </p>
    <div class="space-y-2 text-sm text-gray-600 dark:text-gray-400">
        <p class="flex items-center gap-2">
            <twig:ux:icon name="bi:percent" class="h-4 w-4 text-gray-400 dark:text-gray-500"/>
            {% if subcategory.hasDefaultMarkup %}
                {{ subcategory.defaultMarkup|number_format(3) }}% mark-up
            {% else %}
                <span class="italic text-gray-400 dark:text-gray-500">No subcategory mark-up</span>
            {% endif %}
        </p>
        <p class="flex items-center gap-2">
            <twig:ux:icon name="bi:tag" class="h-4 w-4 text-gray-400 dark:text-gray-500"/>
            {% if subcategory.hasPriceModel %}
                {{ subcategory.priceModel.getName }} price model
            {% else %}
                <span class="italic text-gray-400 dark:text-gray-500">No subcategory price model</span>
            {% endif %}
        </p>
        <p class="flex items-center gap-2">
            <twig:ux:icon name="bi:person" class="h-4 w-4 text-gray-400 dark:text-gray-500"/>
            {% if subcategory.hasOwner %}
                {{ subcategory.owner.fullName }}
            {% else %}
                <span class="italic text-gray-400 dark:text-gray-500">No subcategory manager</span>
            {% endif %}
        </p>
    </div>
    <twig:CardFooter :updatedAt="subcategory.updatedAt">
        <twig:StatusBadge status="{{ subcategory.isActive ? 'ACTIVE' : 'INACTIVE' }}"/>
    </twig:CardFooter>
    {% if subcategory.products.count > 0 %}
        <div class="-mx-3 -mb-3 mt-3 border-t border-gray-200 dark:border-gray-600">
            <a href="{{ path('app_catalog_product_index', {subcategoryId: subcategory.id}) }}"
               class="group flex items-center justify-between rounded-b-xl px-3 py-2.5 text-sm text-gray-600 hover:bg-gray-50 hover:text-gray-900 dark:text-gray-400 dark:hover:bg-white/5 dark:hover:text-gray-200"
               data-turbo-frame="body"
            >
                <span class="flex items-center gap-2">
                    <twig:ux:icon name="bi:box-seam" class="h-4 w-4 text-gray-400 dark:text-gray-500"/>
                    {{ subcategory.products.count }}
                    {{ subcategory.products.count == 1 ? 'product': 'products' }} in this subcategory
                </span>
                <twig:ux:icon name="bi:arrow-right" class="h-4 w-4 text-gray-400 transition-transform duration-150 group-hover:translate-x-0.5 group-hover:text-primary-500 dark:text-gray-500"/>
            </a>
        </div>
    {% endif %}
</twig:Card>
