{# Subcategory detail page — composes _subcategory_card, _subcategory_products_card,
   and embedded sales dashboard. Variable: result (Subcategory) #}
{% extends 'base.html.twig' %}

{% block title %}Subcategory Details{% endblock %}

{% block body %}

    <div class="m-3 space-y-4">
        {{ include('catalog/subcategory/_subcategory_card.html.twig', {subcategory: result}) }}
        {% if result.products.count > 0 %}
            {{ include('catalog/subcategory/_subcategory_products_card.html.twig', {subcategory: result}) }}
        {% endif %}
        {{ include('reporting/_dashboard_card.html.twig', {
            dashboardSrc: path('app_reporting_dashboard_product_sales', {subcategoryId: result.id})
        }) }}
        <twig:BackLink :href="path('app_catalog_subcategory_index')" label="View all subcategories"/>
    </div>

{% endblock %}
