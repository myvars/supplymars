{#
    Inline editable subcategory name.

    Include this partial in place of a static subcategory name display.
    The InlineEdit component handles the edit/save flow via Turbo Frames.

    Variables:
    - subcategory: The Subcategory entity
#}
<twig:InlineEdit
    editUrl="{{ path('app_catalog_subcategory_inline_name', {id: subcategory.publicId}) }}"
    frameId="inline-edit-subcategory-{{ subcategory.publicId }}-name"
    displayClass="text-lg font-semibold text-gray-900 line-clamp-1 dark:text-white"
>
    {{ subcategory.name }}
</twig:InlineEdit>
