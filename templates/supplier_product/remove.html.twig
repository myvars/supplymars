{% extends 'modalBase.html.twig' %}

{% block title %}Remove Supplier Product{% endblock %}

{% block body %}

    <twig:Dialog title="Remove Supplier Product">
        <p class="mb-1 text-sm text-gray-500 dark:text-gray-500">
            {{ supplierProduct.supplier.name|u.truncate(30, '...', false) }}
        </p>
        <p class="mb-3 text-xl text-gray-900 dark:text-white">{{ supplierProduct.productCode }}</p>
        <p class="mb-2">{{ supplierProduct.name|u.truncate(30, '...', false) }}</p>
        <p class="mb-4 font-light">
            Are you sure you want to remove this supplier product?
        </p>
        <form method="post" action="{{ path('app_supplier_product_remove', {'id': supplierProduct.id}) }}">
            <input type="hidden" name="_token" value="{{ csrf_token('remove'~supplierProduct.id) }}">
            <twig:Button type="submit" variant="warning" class="w-full">Remove</twig:Button>
        </form>
    </twig:Dialog>

{% endblock %}