{% extends 'modalBase.html.twig' %}

{% block title %}Remove Supplier Product{% endblock %}

{% block body %}
    <div class="relative p-3 bg-white rounded-lg shadow dark:bg-gray-800">
        <div class="flex justify-between items-center pb-3 mb-3 rounded-t border-b dark:border-gray-600">
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white">
                Remove Supplier Product
            </h3>
        </div>
        <div class="space-y-3 md:space-y-3">
            <p class="mb-1 text-sm text-gray-500 dark:text-gray-500">{{ supplierProduct.supplier.name|u.truncate(30, '...', false) }}</p>
            <p class="mb-3 text-xl text-gray-900 dark:text-white">{{ supplierProduct.productCode }}</p>
            <p class="mb-2 text-sm text-gray-500 dark:text-gray-400">{{ supplierProduct.name|u.truncate(30, '...', false) }}</p>
            <p class="text-sm font-light text-gray-500 dark:text-gray-400">
                Are you sure you want to remove this supplier product?
            </p>
            <form method="post" action="{{ path('app_supplier_product_remove', {'id': supplierProduct.id}) }}">
                <input type="hidden" name="_token" value="{{ csrf_token('remove'~supplierProduct.id) }}">
                <twig:Button type="submit" variant="warning" class="w-full">Remove</twig:Button>
            </form>
            <p class="text-sm font-light text-gray-500 dark:text-gray-400">
                <a href="{{ path('app_product_stock', {'id': supplierProduct.product.id}) }}" class="hover:underline">Cancel</a>
            </p>
        </div>
    </div>
{% endblock %}