{# Compact review preview with rating stars and truncated body.
   Used on: product reviews page (list). Variable: review (Review) #}
<twig:Card>
    <div class="space-y-2.5">
        <div class="flex items-center justify-between">
            <div class="flex items-center gap-2">
                <span class="text-sm font-semibold text-gray-900 dark:text-white">{{ review.customer.fullName }}</span>
                <twig:StatusBadge status="VERIFIED" showIcon/>
            </div>
            <span class="text-xs text-gray-400 dark:text-gray-500">{{ review.publishedAt|ago }}</span>
        </div>
        <div class="flex items-center gap-0.5">
            {% for i in 1..5 %}
                {% if i <= review.rating %}
                    <twig:ux:icon name="flowbite:star-solid" class="h-4 w-4 text-amber-400"/>
                {% else %}
                    <twig:ux:icon name="flowbite:star-solid" class="h-4 w-4 text-gray-200 dark:text-gray-600"/>
                {% endif %}
            {% endfor %}
        </div>
        {% if review.title %}
            <p class="text-sm font-medium text-gray-900 dark:text-white">{{ review.title }}</p>
        {% endif %}
        {% if review.body %}
            <p class="text-sm leading-relaxed text-gray-600 line-clamp-3 dark:text-gray-400">{{ review.body }}</p>
        {% endif %}
    </div>
</twig:Card>
