<twig:Card title="Review Summary">
    {% if summary is not null and summary.hasReviews %}
        <div class="space-y-3">
            <div class="flex items-center space-x-3">
                <span class="text-3xl font-bold text-gray-900 dark:text-white">{{ summary.averageRating }}</span>
                <div>
                    <div class="flex items-center space-x-1">
                        {% set rounded = (summary.averageRating * 2)|round / 2 %}
                        {% set fullStars = rounded|round(0, 'floor') %}
                        {% set hasHalf = (rounded - fullStars) >= 0.5 %}

                        {% for i in 1..5 %}
                            {% if i <= fullStars %}
                                <twig:ux:icon name="flowbite:star-solid" class="w-4 h-4 text-yellow-400"/>
                            {% elseif hasHalf and i == fullStars + 1 %}
                                <span class="relative inline-block w-4 h-4">
                                    <twig:ux:icon name="flowbite:star-solid" class="absolute inset-0 w-4 h-4 text-gray-300"/>
                                    <twig:ux:icon name="flowbite:star-half-solid" class="absolute inset-0 w-4 h-4 text-yellow-400"/>
                                </span>
                            {% else %}
                                <twig:ux:icon name="flowbite:star-solid" class="w-4 h-4 text-gray-300"/>
                            {% endif %}
                        {% endfor %}
                    </div>
                    <p class="text-sm text-gray-500 dark:text-gray-400">{{ summary.reviewCount }} {{ summary.reviewCount == 1 ? 'review' : 'reviews' }}</p>
                </div>
            </div>

            <div class="space-y-1">
                {% for rating in 5..1 %}
                    {% set count = summary.ratingDistribution[rating] ?? 0 %}
                    {% set pct = summary.reviewCount > 0 ? (count / summary.reviewCount * 100)|round : 0 %}
                    <div class="flex items-center space-x-2 text-sm">
                        <span class="w-6 text-right text-gray-500">{{ rating }}</span>
                        <twig:ux:icon name="flowbite:star-solid" class="w-3 h-3 text-yellow-400"/>
                        <div class="flex-1 h-2 bg-gray-200 rounded dark:bg-gray-700">
                            <div class="h-2 bg-yellow-400 rounded" style="width: {{ pct }}%"></div>
                        </div>
                        <span class="w-8 text-gray-500">{{ count }}</span>
                    </div>
                {% endfor %}
            </div>

            {% if summary.pendingCount > 0 %}
                <a href="{{ path('app_review_index', {productId: summary.product.id, reviewStatus: 'PENDING'}) }}"
                   class="text-sm text-yellow-600 hover:text-yellow-800 dark:text-yellow-400 dark:hover:text-yellow-300"
                   data-turbo-frame="body">
                    {{ summary.pendingCount }} {{ summary.pendingCount == 1 ? 'review' : 'reviews' }} pending moderation
                </a>
            {% endif %}
        </div>
    {% else %}
        <p class="text-sm text-gray-500 dark:text-gray-400">No reviews yet.</p>
    {% endif %}
</twig:Card>
