{# Review aggregate summary — average rating, star distribution, and pending count.
   Used on: product reviews page. Variable: summary (ReviewSummary) #}
<twig:Card title="Review Summary">
    {% if summary is not null and summary.hasReviews %}
        <div class="space-y-4">
            <div class="flex items-center gap-3">
                <span class="text-3xl font-bold text-gray-900 dark:text-white">{{ summary.averageRating }}</span>
                <div>
                    <div class="flex items-center gap-0.5">
                        {% set rounded = (summary.averageRating * 2)|round / 2 %}
                        {% set fullStars = rounded|round(0, 'floor') %}
                        {% set hasHalf = (rounded - fullStars) >= 0.5 %}

                        {% for i in 1..5 %}
                            {% if i <= fullStars %}
                                <twig:ux:icon name="flowbite:star-solid" class="h-4 w-4 text-amber-400"/>
                            {% elseif hasHalf and i == fullStars + 1 %}
                                <span class="relative inline-block h-4 w-4">
                                    <twig:ux:icon name="flowbite:star-solid" class="absolute inset-0 h-4 w-4 text-gray-200 dark:text-gray-600"/>
                                    <twig:ux:icon name="flowbite:star-half-solid" class="absolute inset-0 h-4 w-4 text-amber-400"/>
                                </span>
                            {% else %}
                                <twig:ux:icon name="flowbite:star-solid" class="h-4 w-4 text-gray-200 dark:text-gray-600"/>
                            {% endif %}
                        {% endfor %}
                    </div>
                    <p class="text-sm text-gray-500 dark:text-gray-400">{{ summary.reviewCount }} {{ summary.reviewCount == 1 ? 'review' : 'reviews' }}</p>
                </div>
            </div>

            <div class="space-y-1.5">
                {% for rating in 5..1 %}
                    {% set count = summary.ratingDistribution[rating] ?? 0 %}
                    {% set pct = summary.reviewCount > 0 ? (count / summary.reviewCount * 100)|round : 0 %}
                    <div class="flex items-center gap-2 text-sm">
                        <span class="w-6 text-right text-gray-500 dark:text-gray-400">{{ rating }}</span>
                        <twig:ux:icon name="flowbite:star-solid" class="h-3 w-3 text-amber-400"/>
                        <div class="h-2 flex-1 overflow-hidden rounded-full bg-gray-200 dark:bg-gray-700">
                            <div class="h-2 rounded-full bg-amber-400 transition-all duration-300" style="width: {{ pct }}%"></div>
                        </div>
                        <span class="w-8 text-right text-gray-500 dark:text-gray-400">{{ count }}</span>
                    </div>
                {% endfor %}
            </div>

            {% if summary.pendingCount > 0 %}
                <div class="border-t border-gray-200 pt-4 dark:border-gray-600">
                    <a href="{{ path('app_review_index', {productId: summary.product.id, reviewStatus: 'PENDING'}) }}"
                       class="inline-flex items-center gap-1.5 text-sm font-medium text-yellow-600 hover:text-yellow-700 dark:text-yellow-400 dark:hover:text-yellow-300"
                       data-turbo-frame="body">
                        <span class="inline-flex h-5 w-5 items-center justify-center rounded-full bg-yellow-100 text-xs font-bold text-yellow-700 dark:bg-yellow-900/30 dark:text-yellow-400">{{ summary.pendingCount }}</span>
                        {{ summary.pendingCount == 1 ? 'review' : 'reviews' }} pending moderation
                    </a>
                </div>
            {% endif %}
        </div>
    {% else %}
        <twig:EmptyState icon="flowbite:star-solid" message="No reviews yet"/>
    {% endif %}
</twig:Card>
