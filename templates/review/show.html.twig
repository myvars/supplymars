{% extends 'base.html.twig' %}

{% block title %}Review Details{% endblock %}

{% block body %}

    <div class="m-3 space-y-4">
        {{ include('review/_review_detail_card.html.twig', {review: result}) }}

        {% if result.status.value == 'PUBLISHED' or result.status.value == 'REJECTED' %}
            {{ include('review/_review_moderation_card.html.twig', {review: result}) }}
        {% endif %}
        <div class="flex">
            <a href="{{ path('app_review_index') }}"
               class="inline-flex items-center gap-1 text-sm font-medium text-primary-600 hover:text-primary-700 dark:text-primary-400 dark:hover:text-primary-300"
               data-turbo-frame="body">
                <twig:ux:icon name="bi:arrow-left" class="h-3.5 w-3.5"/>
                View all reviews
            </a>
        </div>
    </div>

{% endblock %}
