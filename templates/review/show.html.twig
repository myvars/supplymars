{# Review detail page — composes _review_detail_card and _review_moderation_card.
   Variable: result (Review) #}
{% extends 'base.html.twig' %}

{% block title %}Review Details{% endblock %}

{% block body %}

    <div class="m-3 space-y-4">
        <twig:Breadcrumb :href="path('app_review_index')" label="Reviews" :current="result.title"/>
        {{ include('review/_review_detail_card.html.twig', {review: result}) }}

        {% if result.status.value == 'PUBLISHED' or result.status.value == 'REJECTED' %}
            {{ include('review/_review_moderation_card.html.twig', {review: result}) }}
        {% endif %}
    </div>

{% endblock %}
