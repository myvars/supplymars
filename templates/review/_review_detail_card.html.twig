<twig:Card editLink="{{ review.status.allowEdit ? path('app_review_edit', {'id': review.publicId.value }) : null }}" title="Review">
    <div class="space-y-3">
        <div class="flex items-center justify-between">
            <h3 class="text-xl text-gray-900 dark:text-white">{{ review.title ?? 'Untitled Review' }}</h3>
            <span class="{{ review.status.color }} text-sm font-medium px-2 py-1 rounded">{{ review.status.value }}</span>
        </div>

        <div class="flex items-center space-x-1">
            {% for i in 1..5 %}
                {% if i <= review.rating %}
                    <twig:ux:icon name="flowbite:star-solid" class="w-5 h-5 text-yellow-400"/>
                {% else %}
                    <twig:ux:icon name="flowbite:star-solid" class="w-5 h-5 text-gray-300"/>
                {% endif %}
            {% endfor %}
            <span class="text-sm text-gray-500 ml-2">{{ review.rating }}/5</span>
        </div>

        {% if review.body %}
            <p class="text-gray-700 dark:text-gray-300">{{ review.body }}</p>
        {% endif %}

        <div class="border-t border-gray-200 pt-3 dark:border-gray-700">
            <dl class="grid grid-cols-2 gap-2 text-sm">
                <dt class="text-gray-500 dark:text-gray-400">Product</dt>
                <dd>
                    <a href="{{ path('app_catalog_product_show', {'id': review.product.publicId.value }) }}"
                       class="text-blue-600 hover:text-blue-800" data-turbo-frame="body">
                        {{ review.product.name }}
                    </a>
                </dd>
                <dt class="text-gray-500 dark:text-gray-400">Customer</dt>
                <dd class="text-gray-900 dark:text-white">{{ review.customer.fullName }}</dd>
                <dt class="text-gray-500 dark:text-gray-400">Order</dt>
                <dd>
                    <a href="{{ path('app_order_show', {'id': review.customerOrder.publicId.value }) }}"
                       class="text-blue-600 hover:text-blue-800" data-turbo-frame="body">
                        #{{ review.customerOrder.id }}
                    </a>
                </dd>
                {% if review.publishedAt %}
                    <dt class="text-gray-500 dark:text-gray-400">Published</dt>
                    <dd class="text-gray-900 dark:text-white">{{ review.publishedAt|ago }}</dd>
                {% endif %}
                <dt class="text-gray-500 dark:text-gray-400">Created</dt>
                <dd class="text-gray-900 dark:text-white">{{ review.createdAt|ago }}</dd>
            </dl>
        </div>

        <div class="flex items-center space-x-2 pt-3 border-t border-gray-200 dark:border-gray-700">
            {% if review.status.value == 'PENDING' %}
                <a href="{{ path('app_review_approve', {'id': review.publicId.value }) }}"
                   class="inline-flex items-center px-3 py-1.5 text-sm font-medium text-white bg-green-600 rounded hover:bg-green-700"
                   data-turbo-frame="body"
                   data-turbo-prefetch="false">Approve</a>
                <a href="{{ path('app_review_reject', {'id': review.publicId.value }) }}"
                   class="inline-flex items-center px-3 py-1.5 text-sm font-medium text-white bg-red-600 rounded hover:bg-red-700"
                   data-turbo-frame="modal">Reject</a>
            {% elseif review.status.value == 'PUBLISHED' %}
                <a href="{{ path('app_review_hide', {'id': review.publicId.value }) }}"
                   class="inline-flex items-center px-3 py-1.5 text-sm font-medium text-white bg-gray-600 rounded hover:bg-gray-700"
                   data-turbo-frame="body"
                   data-turbo-prefetch="false">Hide</a>
            {% elseif review.status.value == 'HIDDEN' %}
                <a href="{{ path('app_review_republish', {'id': review.publicId.value }) }}"
                   class="inline-flex items-center px-3 py-1.5 text-sm font-medium text-white bg-blue-600 rounded hover:bg-blue-700"
                   data-turbo-frame="body"
                   data-turbo-prefetch="false">Republish</a>
            {% endif %}
        </div>
    </div>
</twig:Card>
