{% extends 'base.html.twig' %}

{% block title %}Verify Email{% endblock %}

{% block body %}
    <div class="container px-3 my-3">
        <div class="row">
            <div class="alert alert-success mt-v p-4">
                <h1 class="h3 mb-3 font-weight-normal">Verify your Email</h1>
                <p>A verification email was sent to you.</p>
                <p>Please click the link in your email to enable your account before logging in.</p>
            </div>
        </div>
        <div class="row">
            <h1 class="h3 mb-0 font-weight-normal rounded-top text-white bg-dark p-4">Resend Verification Email</h1>
            <div class="bg-light p-4 rounded-bottom">
                <form method="post" action="{{ path('app_verify_send_email') }}">
                    <div class="mb-3">
                        <label for="inputEmail" class="form-label">Email</label>
                        <input type="email" name="email" id="inputEmail"
                               class="form-control"
                               autocomplete="email" value="{{ last_username }}" required autofocus>
                    </div>
                    <twig:Button type="submit" class="w-full">Send Again</twig:Button>
                </form>
            </div>
        </div>
    </div>
{% endblock %}