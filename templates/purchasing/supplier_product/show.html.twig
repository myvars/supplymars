{# Supplier product detail page — composes _supplier_product_card.
   Variable: result (SupplierProduct) #}
{% extends 'base.html.twig' %}

{% block title %}Supplier Product Details{% endblock %}

{% block body %}

    <div class="m-3 space-y-4">
        <twig:Breadcrumb :href="path('app_purchasing_supplier_product_index')" label="Supplier Products" :current="result.name"/>
        {{ include('purchasing/supplier_product/_supplier_product_card.html.twig', {supplierProduct: result}) }}
    </div>

{% endblock %}
