<twig:Card title="Supplier Products" colour="{{ result.colourScheme }}">
    <a href="{{ path('app_purchasing_supplier_product_index', {supplierId: result.id}) }}"
       class="flex items-center justify-start dark:hover:text-white"
       data-turbo-frame="body"
    >
        <span class="me-1">{{ result.supplierProducts.count }}</span>
        {{ result.supplierProducts.count == 1 ? 'product': 'products' }} from this supplier
    </a>
</twig:Card>
