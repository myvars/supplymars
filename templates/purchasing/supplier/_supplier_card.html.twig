{# Supplier detail card with inline-editable name, contact info, and colour scheme.
   Used on: supplier show page. Variable: supplier (Supplier) #}
<twig:Card
    editLink="{{ path('app_purchasing_supplier_edit', { id: supplier.publicId.value }) }}"
    title="Supplier"
    colour="{{ supplier.colourScheme }}"
    statusHighlight="{{ supplier.isActive ? 'ACTIVE' : 'INACTIVE' }}"
>
    <div class="mb-3 flex items-center gap-2.5">
        <twig:SupplierDot colour="{{ supplier.colourScheme }}"/>
        <div>{{ include('purchasing/supplier/_inline_name.html.twig', {supplier: supplier}) }}</div>
    </div>
    <twig:CardFooter :updatedAt="supplier.updatedAt">
        <twig:StatusBadge status="{{ supplier.isActive ? 'ACTIVE' : 'INACTIVE' }}"/>
    </twig:CardFooter>
    {% if supplier.supplierProducts.count > 0 %}
        <div class="-mx-3 -mb-3 mt-3 border-t border-gray-200 dark:border-white/[0.06]">
            <a href="{{ path('app_purchasing_supplier_product_index', {supplierId: supplier.id}) }}"
               class="group flex items-center justify-between rounded-b-xl px-3 py-2.5 text-sm text-gray-600 hover:bg-gray-50 hover:text-gray-900 dark:text-gray-400 dark:hover:bg-white/5 dark:hover:text-gray-200"
               data-turbo-frame="body"
            >
                <span class="flex items-center gap-2">
                    <twig:ux:icon name="bi:box-seam" class="h-4 w-4 text-gray-400 dark:text-gray-500"/>
                    {{ supplier.supplierProducts.count }}
                    {{ supplier.supplierProducts.count == 1 ? 'product': 'products' }} from this supplier
                </span>
                <twig:ux:icon name="bi:arrow-right" class="h-4 w-4 text-gray-400 transition-transform duration-150 group-hover:translate-x-0.5 group-hover:text-primary-500 dark:text-gray-500"/>
            </a>
        </div>
    {% endif %}
</twig:Card>
