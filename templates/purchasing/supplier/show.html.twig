{# Supplier detail page — composes _supplier_card, _supplier_products_card,
   and embedded sales dashboard. Variable: result (Supplier) #}
{% extends 'base.html.twig' %}

{% block title %}Supplier Details{% endblock %}

{% block body %}

    <div class="m-3 space-y-4">
        <twig:Breadcrumb :href="path('app_purchasing_supplier_index')" label="Suppliers" :current="result.name"/>
        {{ include('purchasing/supplier/_supplier_card.html.twig', {supplier: result}) }}
        {{ include('reporting/_dashboard_card.html.twig', {
            dashboardSrc: path('app_reporting_dashboard_product_sales', {supplierId: result.id})
        }) }}
    </div>

{% endblock %}
