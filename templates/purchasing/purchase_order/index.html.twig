{% extends 'base.html.twig' %}

{% block title %}Purchase Order Search{% endblock %}

{% block body %}
    <twig:Search
        flowModel="{{ flowModel }}"
        flowRoute="{{ flowRoute }}"
        results="{{ results }}"
    >
        <twig:block name="sort">
            <twig:Card>
                <div class="flex justify-between overflow-auto">
                    <twig:SortLink sortValue="id">PO</twig:SortLink>
                    <twig:SortLink sortValue="createdAt">Created</twig:SortLink>
                    <twig:SortLink sortValue="customerOrder.id">Order</twig:SortLink>
                    <twig:SortLink sortValue="totalPriceIncVat">Total</twig:SortLink>
                    <twig:SortLink sortValue="status">Status</twig:SortLink>
                </div>
            </twig:Card>
        </twig:block>

        <twig:block name="list_item">
            <twig:Card showLink="{{ path('app_purchasing_purchase_order_show', {'id': result.publicId.value }) }}">
                <div class="flex items-center justify-between">
                    <p class="mb-1 items-center text-lg text-gray-900 dark:text-white">
                        PO #{{ '%06d'|format(result.id) }}
                        <span class="text-base text-gray-600 dark:text-gray-500">- Order #{{ '%06d'|format(result.customerOrder.id) }}</span>
                    </p>
                    <p class="text-lg font-extralight"> {{ result.totalPriceIncVat|format_currency('GBP') }}</p>
                </div>
                <p class="mb-1 text-base">{{ result.customerOrder.customer.fullName }}</p>
                <p class="flex items-center justify-between text-sm">
                    <span class="text-gray-600 me-1 dark:text-gray-500">{{ result.createdAt|date('jS M Y H:i') }}</span>
                    {{ result.status.value|title }}
                </p>
            </twig:Card>
        </twig:block>

    </twig:Search>

{% endblock %}
