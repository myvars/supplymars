{% extends 'base.html.twig' %}

{% block title %}Purchase Order Search{% endblock %}

{% block body %}
    <twig:Search
        flowModel="{{ flowModel }}"
        routes="{{ routes }}"
        results="{{ results }}"
        showAdd="{{ false }}"
    >
        <twig:block name="sort">
            <twig:SortLink sortValue="id">PO</twig:SortLink>
            <twig:SortLink sortValue="createdAt">Created</twig:SortLink>
            <twig:SortLink sortValue="customerOrder.id">Order</twig:SortLink>
            <twig:SortLink sortValue="totalPriceIncVat">Total</twig:SortLink>
            <twig:SortLink sortValue="status">Status</twig:SortLink>
        </twig:block>

        <twig:block name="list_item">
            <twig:Card showLink="{{ path('app_purchasing_purchase_order_show', {'id': result.publicId.value }) }}" statusHighlight="{{ result.status.value }}">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-lg font-semibold text-gray-900 dark:text-white">
                            PO #{{ '%06d'|format(result.id) }}
                        </p>
                        <p class="text-xs text-gray-500 dark:text-gray-500">Order #{{ '%06d'|format(result.customerOrder.id) }}</p>
                    </div>
                    <div class="text-right">
                        <p class="text-lg font-light text-gray-900 dark:text-white">{{ result.totalPriceIncVat|format_currency('GBP') }}</p>
                        <p class="text-xs text-gray-500 dark:text-gray-500">{{ result.supplier.name }}</p>
                    </div>
                </div>
                <div class="mt-2 flex items-center justify-between">
                    <div class="flex items-center gap-3">
                        <p class="text-sm text-gray-700 dark:text-gray-300">{{ result.customerOrder.customer.fullName }}</p>
                        <span class="mx-1 text-gray-300 dark:text-gray-600">&middot;</span>
                        <p class="text-xs text-gray-500 dark:text-gray-500">{{ result.createdAt|date('jS M Y H:i') }}</p>
                    </div>
                    <twig:StatusBadge status="{{ result.status.value }}"/>
                </div>
            </twig:Card>
        </twig:block>

    </twig:Search>

{% endblock %}
