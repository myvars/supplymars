{% set colourScheme = purchaseOrder.supplier.colourScheme %}
<twig:Card colour="{{ colourScheme }}">
    <div class="flex justify-between text-sm text-gray-500 dark:text-gray-400">
        <div>
            <p class="mb-1 text-gray-300 dark:text-gray-200">Delivery Address</p>
            <p>{{ purchaseOrder.customerOrder.customer.fullName }}</p>
            <p>{{ purchaseOrder.customerOrder.shippingAddress.street }}</p>
            {% if purchaseOrder.customerOrder.shippingAddress.street2 is not null %}
                <p>{{ purchaseOrder.customerOrder.shippingAddress.street2 }}</p>
            {% endif %}
            <p>{{ purchaseOrder.customerOrder.shippingAddress.city }},
                {{ purchaseOrder.customerOrder.shippingAddress.postCode }}
            </p>
            <p>{{ purchaseOrder.customerOrder.shippingAddress.country }}</p>
        </div>
        <div>
            <p class="mb-1 text-gray-300 dark:text-gray-200">PO Summary</p>
            <div class="flex justify-between">
                <p class="me-10">Item(s)<span class="hidden md:inline"> subtotal</span>:</p>
                <p>{{ (purchaseOrder.totalPrice - purchaseOrder.shippingPrice)|format_currency('GBP') }}</p>
            </div>
            <div class="flex justify-between">
                <p class="me-10">Shipping:</p>
                <p>{{ purchaseOrder.shippingPrice|format_currency('GBP') }}</p>
            </div>
            <div class="flex justify-between hidden md:inline-flex">
                <p class="me-10">Total<span class="hidden md:inline"> before VAT</span>:</p>
                <p>{{ purchaseOrder.totalPrice|format_currency('GBP') }}</p>
            </div>
            <div class="flex justify-between">
                <p class="me-10">VAT:</p>
                <p>{{ (purchaseOrder.totalPriceIncVat - purchaseOrder.totalPrice)|format_currency('GBP') }}</p>
            </div>
            <div class="mt-1 flex justify-between text-gray-300 dark:text-gray-200">
                <p class="me-10"><span class="hidden md:inline">Grand </span>Total:</p>
                <p>{{ purchaseOrder.totalPriceIncVat|format_currency('GBP') }}</p>
            </div>
        </div>
    </div>
</twig:Card>