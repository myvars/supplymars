{# Purchase order header card with supplier, date, order link, and rewind action.
   Used on: purchase order show page. Variable: result/purchaseOrder (PurchaseOrder) #}
{% set colourScheme = result.supplier.colourScheme %}
<twig:Card colour="{{ colourScheme }}"
           editLink="{{ path('app_purchasing_purchase_order_rewind_confirm', {id: result.publicId.value}) }}"
           editIcon="mingcute:back-line"
           statusHighlight="{{ purchaseOrder.status.value }}">
    <h5 class="flex items-center text-xl font-semibold text-gray-900 dark:text-white">
        PO #{{ '%06d'|format(result.id) }}
        <span class="mx-1 text-gray-300 dark:text-gray-600">&middot;</span>
        <span class="text-base font-normal text-gray-500 dark:text-gray-400">{{ result.supplier.name }}</span>
    </h5>
    <div class="mt-1.5 flex items-center justify-between">
        <p class="text-sm text-gray-500 dark:text-gray-400">
            {{ purchaseOrder.createdAt|date('jS M Y H:i') }}
            <span class="mx-1 text-gray-300 dark:text-gray-600">&middot;</span>
            <a href="{{ path('app_order_show', {id: purchaseOrder.customerOrder.publicId.value}) }}"
               data-turbo-frame="body"
               class="text-gray-700 hover:text-blue-600 dark:text-gray-400 dark:hover:text-white">
                Order #{{ '%06d'|format(purchaseOrder.customerOrder.id) }}
            </a>
        </p>
        <a href="{{ path('app_purchase_order_status_log', {'id': purchaseOrder.publicId.value }) }}"
           data-turbo-frame="modal"
        >
            <twig:StatusBadge status="{{ purchaseOrder.status.value }}" :showIcon="true" :interactive="true"/>
        </a>
    </div>
</twig:Card>
