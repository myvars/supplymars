{% if colourScheme is not defined %}
    {% set colourScheme = purchaseOrderItem.purchaseOrder.supplier.colourScheme %}
{% endif %}
<li class="first:mt-3">
    <twig:Card
        editLink="{{ purchaseOrderItem.allowStatusChange ? path('app_purchasing_purchase_order_item_status_edit', {'id': purchaseOrderItem.publicId.value }) : null }}"
        padding="p-0"
        colour="{{ colourScheme }}"
    >
        <div class="overflow-hidden rounded-xl">
            <div class="flex items-center hover:bg-gray-50 dark:bg-gray-800 dark:hover:bg-gray-700">
                <twig:ProductImage
                    imageName="{{ purchaseOrderItem.customerOrderItem.product.hasProductImage ? purchaseOrderItem.customerOrderItem.product.getFirstImage.imageName : null }}"
                    filter="small_thumbnail"
                    alt="{{ purchaseOrderItem.customerOrderItem.product.name }}"
                    showLink="{{ path('app_catalog_product_show', {'id': purchaseOrderItem.customerOrderItem.product.publicId.value }) }}"
                ></twig:ProductImage>
                <div class="w-full p-3">
                    <p class="mb-1.5 text-sm font-medium text-gray-700 line-clamp-1 dark:text-gray-200">{{ purchaseOrderItem.supplierProduct.name }}</p>
                    <div class="flex items-center justify-between">
                        <div class="flex items-center gap-3 text-sm">
                            <span class="font-medium tabular-nums text-gray-900 dark:text-white">{{ purchaseOrderItem.priceIncVat|format_currency('GBP') }}</span>
                            <span class="text-gray-500 dark:text-gray-400">Qty: {{ purchaseOrderItem.quantity }}</span>
                            <span class="hidden text-gray-400 md:inline dark:text-gray-500">#{{ '%05d'|format(purchaseOrderItem.customerOrderItem.product.id) }}</span>
                        </div>
                        <div class="flex items-center gap-2">
                            {% if purchaseOrderItem.status.value|lower == 'delivered' and purchaseOrderItem.deliveredAt is not null %}
                                <span class="text-xs text-gray-400 dark:text-gray-500">{{ purchaseOrderItem.deliveredAt|date("jS M Y") }}</span>
                            {% endif %}
                            <a href="{{ path('app_purchase_order_item_status_log', {'id':purchaseOrderItem.publicId.value }) }}"
                               data-turbo-frame="modal"
                            >
                                <twig:StatusBadge status="{{ purchaseOrderItem.status.value }}" :interactive="true"/>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </twig:Card>
</li>
