{% extends 'modalBase.html.twig' %}

{% block title %}Edit VAT Rate{% endblock %}

{% block body %}
    <section class="bg-white dark:bg-gray-900">
        <div class="py-8 px-4 mx-auto max-w-screen-xl lg:py-16 lg:px-6">
            <div class="mx-auto max-w-screen-sm text-center">
                <h1 class="mb-4 text-5xl tracking-tight font-extrabold lg:text-7xl text-primary-600 dark:text-primary-500">Whoops</h1>
                <p class="mb-4 text-3xl tracking-tight font-bold text-gray-900 md:text-4xl dark:text-white">Template is missing.</p>
                <p class="mb-4 text-lg font-light text-gray-500 dark:text-gray-400">Sorry, we can't find that page. </p>
                <twig:Button
                    tag="a"
                    href="{{ path('app_homepage') }}"
                    class="flex items-center space-x-1 font-bold"
                >
                    Continue
                </twig:Button>
            </div>
        </div>
    </section>
{% endblock %}

