<twig:Card editLink="{{ path('app_supplier_edit', { id: supplier.id }) }}" title="Supplier">
    <p class="text-xl text-gray-900 dark:text-white">{{ supplier.name|u.truncate(30, '...') }}</p>
    <div class="mt-3 flex items-center justify-between">
        <p class="me-10 text-xs text-gray-600 dark:text-gray-500">Updated {{ supplier.updatedAt|ago }}</p>
        {% if supplier.isActive %}
            <p class="text-green-500">Active</p>
        {% else %}
            <p class="text-red-500">InActive</p>
        {% endif %}
    </div>
</twig:Card>