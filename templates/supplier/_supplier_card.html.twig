<twig:Card
    editLink="{{ path('app_supplier_edit', { id: supplier.id }) }}"
    title="Supplier"
    colour="{{ supplier.colourScheme }}"
>
    <p class="mb-2 text-xl text-gray-900 line-clamp-1 dark:text-white">{{ supplier.name }}</p>
    <div class="mt-2 flex items-center justify-between">
        <p class="text-xs text-gray-600 me-10 dark:text-gray-500">Updated {{ supplier.updatedAt|ago }}</p>
        {% if supplier.isActive %}
            <p class="text-green-500">Active</p>
        {% else %}
            <p class="text-red-500">InActive</p>
        {% endif %}
    </div>
</twig:Card>