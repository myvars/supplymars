<div class="relative h-full bg-white border border-gray-200 rounded-lg shadow dark:bg-gray-800 dark:border-gray-700">
    <a href="{{ path('app_supplier_edit', { id: supplier.id }) }}"
       class="absolute -top-1.5 -right-1 p-1.5 bg-white text-yellow-500 border border-gray-600 rounded-full shadow-lg dark:bg-gray-700 dark:hover:bg-gray-600"
       data-turbo-prefetch="false"
       data-turbo-frame="modal"
    >
        <twig:Icon name="edit" class="w-6 h-6 p-0.5"/>
    </a>
    <div class="p-5 text-sm text-gray-500 dark:text-gray-400">
        <p class="mb-1 text-gray-500 dark:text-gray-500">Supplier</p>
        <h5 class="mb-4 text-2xl text-gray-900 dark:text-white">{{ supplier.name|u.truncate(30, '...') }}</h5>
        <div class="mt-4 flex items-center justify-between">
            <p class="me-10 text-xs">Updated {{ supplier.updatedAt|ago }}</p>
            {% if supplier.isActive %}
                <p class="text-green-500">Active</p>
            {% else %}
                <p class="text-red-500">InActive</p>
            {% endif %}
        </div>
    </div>
</div>