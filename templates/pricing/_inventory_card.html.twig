{# Inventory card showing stock levels across all supplier sources.
   Used on: pricing stock page. Variable: result (Product) #}
<twig:Card padding="p-0" statusHighlight="{{ result.hasActiveProductSource ? 'ACTIVE' : 'INACTIVE' }}">
    {% if result.isValidProduct %}
        <div class="divide-y divide-gray-100 dark:divide-gray-800">
            <div class="grid grid-cols-2 gap-y-5 p-5 text-center md:grid-cols-4 md:gap-y-0 md:divide-x md:divide-gray-100 dark:md:divide-gray-800">
                <div class="md:px-5">
                    <p class="text-xs font-medium uppercase tracking-wide text-gray-500 dark:text-gray-500">Cost Price</p>
                    <p class="mt-1 text-2xl font-bold {{ type == 'cost' ? 'text-gray-500 dark:text-gray-500' : 'text-gray-800 dark:text-gray-200' }}">
                        {{ result.cost|format_currency('GBP') }}</p>
                    <p class="mt-0.5 text-xs text-gray-500 dark:text-gray-500">
                        {{ result.activeProductSource.supplier.name }}</p>
                </div>
                <div class="md:px-5">
                    <p class="text-xs font-medium uppercase tracking-wide text-gray-500 dark:text-gray-500">Stock</p>
                    <p class="mt-1 text-2xl font-bold {{ type == 'cost' ? 'text-gray-500 dark:text-gray-500' : 'text-gray-900 dark:text-white' }}">{{ result.stock }}</p>
                    <p class="mt-0.5 text-xs text-gray-500 dark:text-gray-500">
                        {{ result.activeProductSource.updatedAt|ago }}</p>
                </div>
                <div class="md:px-5">
                    <p class="text-xs font-medium uppercase tracking-wide text-gray-500 dark:text-gray-500">Sell Price</p>
                    <p class="mt-1 text-2xl font-bold {{ type == 'cost' ? 'text-gray-900 dark:text-white' : 'text-gray-500 dark:text-gray-400' }}">
                        {{ result.sellPrice|format_currency('GBP') }}</p>
                </div>
                <div class="md:px-5">
                    <p class="text-xs font-medium uppercase tracking-wide text-gray-500 dark:text-gray-500">Sell Inc VAT</p>
                    <p class="mt-1 text-2xl font-bold {{ type == 'cost' ? 'text-gray-900 dark:text-white' : 'text-gray-500 dark:text-gray-400' }}">
                        {{ result.sellPriceIncVat|format_currency('GBP') }}</p>
                </div>
            </div>
            <div class="px-5 py-3 text-center">
                <p class="text-xs font-medium uppercase tracking-wide text-gray-500 dark:text-gray-500">Mark-up</p>
                <p class="mt-0.5 text-xl font-semibold text-gray-800 dark:text-white">{{ result.markup|number_format(3) }}%</p>
                <p class="mt-1 text-xs text-gray-500 dark:text-gray-500 inline-flex max-md:hidden">
                    {{ result.category.vatRate.name|title }} VAT
                    <span class="mx-1 text-gray-300 dark:text-gray-600">&middot;</span>
                    {{ result.activePriceModelTarget|title }} price model
                    <span class="mx-1 text-gray-300 dark:text-gray-600">&middot;</span>
                    {{ result.activeMarkupTarget|title }} mark-up
                </p>
            </div>
        </div>
    {% else %}
        <div class="p-6 text-center">
            <twig:ux:icon name="bi:exclamation-triangle" class="mx-auto mb-2 h-8 w-8 text-red-400 dark:text-red-500"/>
            <p class="text-lg font-semibold text-red-500 dark:text-red-400">Incomplete Product</p>
            <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
                {% if not result.hasActiveProductSource %}
                    No active supplier
                {% else %}
                    Inactive category, subcategory or product
                {% endif %}
            </p>
        </div>
    {% endif %}
</twig:Card>
