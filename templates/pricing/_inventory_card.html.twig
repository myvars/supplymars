{# Inventory card showing stock levels across all supplier sources.
   Used on: pricing stock page. Variable: result (Product) #}
<twig:Card padding="p-0" statusHighlight="{{ result.hasActiveProductSource ? 'ACTIVE' : 'INACTIVE' }}">
    {% if result.isValidProduct %}
        {# KPI metrics grid #}
        <div class="grid grid-cols-2 gap-px overflow-hidden rounded-t-xl bg-gray-900/5 dark:bg-white/5 md:grid-cols-4">
            <twig:KpiCard title="Cost Price"
                value="{{ result.cost|format_currency('GBP') }}" valueType="text"
                subtitle="{{ result.activeProductSource.supplier.name }}"
                :muted="type == 'cost'"/>
            <twig:KpiCard title="Stock"
                value="{{ result.stock }}" valueType="count"
                subtitle="{{ result.activeProductSource.updatedAt|ago }}"
                :muted="type == 'cost'"/>
            <twig:KpiCard title="Sell Price"
                value="{{ result.sellPrice|format_currency('GBP') }}" valueType="text"
                subtitle="{{ result.activePriceModel.getName }}"
                :muted="type == 'stock'"/>
            <twig:KpiCard title="Sell Inc VAT"
                value="{{ result.sellPriceIncVat|format_currency('GBP') }}" valueType="text"
                subtitle="{{ result.category.vatRate.name|title }} VAT"
                :muted="type == 'stock'"/>
        </div>

        {# Markup section — prominent centered value with compact metadata #}
        <div class="border-t border-gray-900/5 px-5 py-2 text-center dark:border-white/5">
            <p class="text-xs font-medium uppercase tracking-wide text-gray-500 dark:text-gray-400">Mark-up</p>
            <p class="mt-0.5 text-lg font-semibold text-gray-800 dark:text-white">{{ result.markup|number_format(3) }}%</p>
            <p class="mt-0.5 inline-flex text-xs text-gray-500 dark:text-gray-400 max-md:hidden">
                {{ result.category.vatRate.name|title }} VAT
                <span class="mx-1 text-gray-300 dark:text-gray-600">&middot;</span>
                {{ result.activePriceModelTarget|title }} price model
                <span class="mx-1 text-gray-300 dark:text-gray-600">&middot;</span>
                {{ result.activeMarkupTarget|title }} mark-up
            </p>
        </div>
    {% else %}
        <div class="p-6 text-center">
            <twig:ux:icon name="bi:exclamation-triangle" class="mx-auto mb-2 h-8 w-8 text-red-400 dark:text-red-500"/>
            <p class="text-lg font-semibold text-red-500 dark:text-red-400">Incomplete Product</p>
            <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
                {% if not result.hasActiveProductSource %}
                    No active supplier
                {% else %}
                    Inactive category, subcategory or product
                {% endif %}
            </p>
        </div>
    {% endif %}
</twig:Card>
