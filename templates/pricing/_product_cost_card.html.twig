<twig:Card editLink="{{ path('app_pricing_product_cost_edit', {id: product.publicId.value}) }}" title="Product">
    <p class="mb-2 text-lg text-gray-900 line-clamp-1 dark:text-white">{{ product.name }}</p>
    <ul class="list-inside list-disc">
        <li>
            {% if product.hasDefaultMarkup %}
                {{ product.defaultMarkup|number_format(3) }}% mark-up
            {% else %}
                No product mark-up
            {% endif %}
        </li>
        <li>
            {% if product.hasPriceModel %}
                {{ product.priceModel.getName }} price model
            {% else %}
                No product price model
            {% endif %}
        </li>
    </ul>
    <div class="mt-2 flex items-center justify-between">
        <p class="text-xs text-gray-600 me-10 dark:text-gray-500">Updated {{ product.updatedAt|ago }}</p>
        {% if product.isActive %}
            <p class="text-green-500">Active</p>
        {% else %}
            <p class="text-red-500">InActive</p>
        {% endif %}
    </div>
</twig:Card>
