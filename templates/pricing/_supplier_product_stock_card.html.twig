{# Individual supplier product stock entry with cost and removal action.
   Used on: pricing stock page (inside _inventory_card). Variable: supplierProduct (SupplierProduct) #}
<twig:Card
    editLink="{{ path('app_purchasing_supplier_product_remove_confirm', {'id': supplierProduct.publicId.value }) }}"
    editIcon="bi:x-lg"
    colour="{{ activeProductSource is same as supplierProduct ? 'green' : 'gray' }}"
    borderColour="{{ activeProductSource is same as supplierProduct ? 'green' : null }}"
    statusHighlight="{{ supplierProduct.isActive ? 'ACTIVE' : 'INACTIVE' }}"
>
    <p class="text-xs font-medium text-gray-500 dark:text-gray-500">
        {{ supplierProduct.supplier.name }}
        {% if not supplierProduct.hasActiveSupplier %}
            <span class="text-red-600 dark:text-red-500">(Inactive)</span>
        {% endif %}
    </p>
    <p class="mt-1 text-lg font-semibold text-gray-900 line-clamp-1 dark:text-white">
        <a href="{{ path('app_purchasing_supplier_product_show', {'id': supplierProduct.publicId.value }) }}"
           data-turbo-frame="body"
           class="hover:text-blue-600 dark:hover:text-white/70">
            {{ supplierProduct.name }}
        </a>
    </p>
    <div class="mt-2 flex items-baseline justify-between">
        <p class="text-sm text-gray-500 dark:text-gray-400">{{ supplierProduct.productCode }}</p>
        <div class="text-right">
            <p class="text-lg font-light text-gray-900 dark:text-white">{{ supplierProduct.cost|format_currency('GBP') }}</p>
            <p class="text-xs text-gray-500 dark:text-gray-500">
                {% if supplierProduct.hasStock %}
                    {{ supplierProduct.stock }} in stock
                {% else %}
                    Out of stock ({{ supplierProduct.leadTimeDays }}d lead)
                {% endif %}
            </p>
        </div>
    </div>
    <div class="mt-3 flex items-center justify-between border-t border-gray-100 pt-2.5 dark:border-gray-600">
        <p class="text-xs text-gray-400 dark:text-gray-500">{{ supplierProduct.updatedAt|ago }}</p>
        <div class="inline-flex items-center gap-1.5">
            <a href="{{ path('app_purchasing_supplier_product_toggle_status', {'id': supplierProduct.publicId.value }) }}"
               data-turbo-prefetch="false"
               data-turbo-frame="body"
               class="text-gray-500 transition-colors hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200"
            >
                <twig:ux:icon name="bi:arrow-repeat" class="h-3.5 w-3.5"/>
            </a>
            <twig:StatusBadge status="{{ supplierProduct.isActive ? 'ACTIVE' : 'INACTIVE' }}"/>
        </div>
    </div>
</twig:Card>
