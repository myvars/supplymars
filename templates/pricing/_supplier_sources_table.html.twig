{# Compact supplier sources comparison table.
   Shows all supplier sources for a product with clear active-source indication.
   Variables: result (Product) #}
{% set activeSource = result.activeProductSource %}
{% set activeCost = activeSource ? activeSource.cost : null %}

<div class="space-y-2">
    <div class="flex items-baseline justify-between gap-2">
        <p class="text-xs font-medium uppercase tracking-wide text-gray-500 dark:text-gray-500">Supplier Sources</p>
        {% if activeSource %}
            <p class="text-xs text-gray-400 dark:text-gray-500">
                <twig:ux:icon name="bi:info-circle" class="mr-0.5 inline h-3 w-3 align-[-1px]"/>
                <span class="max-sm:hidden">Lowest cost with stock selected automatically</span>
                <span class="sm:hidden">Auto-selects lowest cost</span>
            </p>
        {% endif %}
    </div>

    <div class="overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm dark:border-white/[0.10] dark:bg-gray-800/70 dark:shadow-md dark:shadow-black/20">
        {% for supplierProduct in result.supplierProducts %}
            {% set isActive = activeSource is same as supplierProduct %}
            {% set isLast = loop.last %}
            {% set isFirst = loop.first %}

            <div class="relative {{ isActive ? 'bg-green-50/60 dark:bg-green-950/30' : '' }} {{ not isLast ? 'border-b border-gray-100 dark:border-white/[0.06]' : '' }}">
                {# Active source indicator — left accent bar #}
                {% if isActive %}
                    <div class="absolute inset-y-0 left-0 w-1 bg-green-500 {{ isFirst ? 'rounded-tl-xl' : '' }} {{ isLast ? 'rounded-bl-xl' : '' }} dark:bg-green-400"></div>
                {% endif %}

                <div class="px-4 py-2.5 {{ isActive ? 'pl-5' : '' }}">
                    {# Row 1: supplier name + badges + actions #}
                    <div class="flex items-center justify-between gap-2">
                        <div class="flex min-w-0 flex-1 items-center gap-2">
                            <twig:SupplierDot colour="{{ supplierProduct.supplier.colourScheme }}"/>
                            <a href="{{ path('app_purchasing_supplier_product_show', {'id': supplierProduct.publicId.value }) }}"
                               data-turbo-frame="body"
                               class="truncate text-sm font-medium text-gray-900 hover:text-blue-600 dark:text-white dark:hover:text-blue-400">
                                {{ supplierProduct.supplier.name }}
                            </a>
                            {% if isActive %}
                                <span class="inline-flex shrink-0 items-center gap-1 rounded-full bg-green-100 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wider text-green-700 dark:bg-green-900/60 dark:text-green-300">
                                    <twig:ux:icon name="bi:check-circle-fill" class="h-2.5 w-2.5"/>
                                    Best price
                                </span>
                            {% endif %}
                            {% if not supplierProduct.isActive %}
                                <twig:StatusBadge status="INACTIVE"/>
                            {% endif %}
                            {% if supplierProduct.isActive and not supplierProduct.hasActiveSupplier %}
                                <span class="shrink-0 text-[10px] font-medium text-red-500 dark:text-red-400">Supplier inactive</span>
                            {% endif %}
                        </div>
                        <div class="flex shrink-0 items-center gap-0.5">
                            <a href="{{ path('app_purchasing_supplier_product_toggle_status', {'id': supplierProduct.publicId.value }) }}"
                               data-turbo-prefetch="false"
                               data-turbo-frame="body"
                               class="rounded-md p-1.5 text-gray-400 transition-colors hover:bg-gray-100 hover:text-gray-600 dark:hover:bg-white/[0.06] dark:hover:text-gray-300"
                               title="{{ supplierProduct.isActive ? 'Deactivate source' : 'Activate source' }}"
                            >
                                <twig:ux:icon name="{{ supplierProduct.isActive ? 'bi:toggle-on' : 'bi:toggle-off' }}" class="h-4 w-4"/>
                            </a>
                            <a href="{{ path('app_purchasing_supplier_product_remove_confirm', {'id': supplierProduct.publicId.value }) }}"
                               data-turbo-frame="modal"
                               data-turbo-prefetch="false"
                               class="rounded-md p-1.5 text-gray-400 transition-colors hover:bg-red-50 hover:text-red-500 dark:hover:bg-red-950/40 dark:hover:text-red-400"
                               title="Remove source"
                            >
                                <twig:ux:icon name="bi:trash3" class="h-3.5 w-3.5"/>
                            </a>
                        </div>
                    </div>

                    {# Row 2: product description + metadata left, stock + diff + cost right #}
                    <div class="mt-1 flex items-baseline justify-between gap-3">
                        <p class="flex min-w-0 flex-1 items-center gap-1.5 text-xs text-gray-400 dark:text-gray-500">
                            <span class="truncate text-gray-500 max-sm:hidden dark:text-gray-400">{{ supplierProduct.name }}</span>
                            <span class="shrink-0 text-gray-300 max-sm:hidden dark:text-gray-600">&middot;</span>
                            <span class="shrink-0">{{ supplierProduct.productCode }}</span>
                            <span class="shrink-0 text-gray-300 dark:text-gray-600">&middot;</span>
                            <span class="shrink-0">{{ supplierProduct.updatedAt|ago }}</span>
                        </p>
                        <span class="w-18 shrink-0 whitespace-nowrap text-right text-xs text-gray-400 dark:text-gray-500">
                            {% if supplierProduct.hasStock %}
                                {{ supplierProduct.stock }} in stock
                            {% else %}
                                <span class="text-amber-600 dark:text-amber-400">No stock</span>
                            {% endif %}
                        </span>
                        <span class="w-18 shrink-0 text-right text-[10px] tabular-nums text-gray-400 max-sm:hidden dark:text-gray-500">
                            {% if not isActive and activeCost and supplierProduct.cost > activeCost %}
                                +{{ (supplierProduct.cost - activeCost)|format_currency('GBP') }}
                            {% endif %}
                        </span>
                        <span class="w-24 shrink-0 text-right text-sm font-semibold tabular-nums {{ isActive ? 'text-green-700 dark:text-green-400' : 'text-gray-900 dark:text-white' }}">
                            {{ supplierProduct.cost|format_currency('GBP') }}
                        </span>
                    </div>
                </div>
            </div>
        {% else %}
            <div class="px-4 py-8 text-center">
                <twig:ux:icon name="bi:box-seam" class="mx-auto mb-2 h-6 w-6 text-gray-300 dark:text-gray-600"/>
                <p class="text-sm text-gray-400 dark:text-gray-500">No supplier sources</p>
            </div>
        {% endfor %}
    </div>
</div>
