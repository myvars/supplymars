<twig:Card editLink="{{ path('app_pricing_category_cost_edit', {'id': product.publicId.value }) }}" title="Category">
    <p class="mb-2 text-lg text-gray-900 line-clamp-1 dark:text-white">{{ product.category.name }}</p>
    <ul class="list-inside list-disc">
        <li>{{ product.category.defaultMarkup|number_format(3) }}% mark-up</li>
        <li>{{ product.category.priceModel.getName }} price model</li>
    </ul>
    <div class="mt-2 flex items-center justify-between">
        <p class="text-xs text-gray-600 me-10 dark:text-gray-500">Updated {{ product.category.updatedAt|ago }}</p>
        {% if product.category.isActive %}
            <p class="text-green-500">Active</p>
        {% else %}
            <p class="text-red-500">InActive</p>
        {% endif %}
    </div>
</twig:Card>
