<twig:Card title="Categories">
    <a href="{{ path('app_catalog_category_index', {vatRateId: result.id}) }}"
       class="group flex items-center justify-between text-sm text-gray-600 dark:text-gray-400"
       data-turbo-frame="body"
    >
        <span class="flex items-center gap-2">
            <twig:ux:icon name="bi:folder" class="h-4 w-4 text-gray-400 dark:text-gray-500"/>
            <span class="font-medium text-gray-900 dark:text-white">{{ result.categories.count }}</span>
            {{ result.categories.count == 1 ? 'category': 'categories' }} with this VAT rate
        </span>
        <twig:ux:icon name="bi:arrow-right" class="h-4 w-4 text-gray-400 transition-transform duration-150 group-hover:translate-x-0.5 group-hover:text-primary-500 dark:text-gray-500"/>
    </a>
</twig:Card>
