<twig:Card editLink="{{ path('app_pricing_vat_rate_edit', { id: vatRate.publicId.value }) }}" title="VAT Rate">
    <p class="mb-2 text-xl text-gray-900 line-clamp-1 dark:text-white">{{ vatRate.name }}</p>
    <p class="text-lg font-extralight">
        {{ vatRate.rate|number_format(2) }}%
        <span class="text-sm"> rate</span>
    </p>
    <p class="mt-2 text-xs text-gray-600 me-10 dark:text-gray-500">Updated {{ vatRate.updatedAt|ago }}</p>
</twig:Card>
