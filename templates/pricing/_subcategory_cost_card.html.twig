<twig:Card editLink="{{ path('app_pricing_subcategory_cost_edit', {'id': product.publicId.value }) }}" title="Subcategory">
    <p class="mb-2 text-lg text-gray-900 line-clamp-1 dark:text-white">{{ product.subcategory.name }}</p>
    <ul class="list-inside list-disc">
        <li>
            {% if product.subcategory.hasDefaultMarkup %}
                {{ product.subcategory.defaultMarkup|number_format(3) }}% mark-up
            {% else %}
                No subcategory mark-up
            {% endif %}
        </li>
        <li>
            {% if product.subcategory.hasPriceModel %}
                {{ product.subcategory.priceModel.getName }} price model
            {% else %}
                No subcategory price model
            {% endif %}
        </li>
    </ul>
    <div class="mt-2 flex items-center justify-between">
        <p class="text-xs text-gray-600 me-10 dark:text-gray-500">Updated {{ product.subcategory.updatedAt|ago }}</p>
        {% if product.subcategory.isActive %}
            <p class="text-green-500">Active</p>
        {% else %}
            <p class="text-red-500">InActive</p>
        {% endif %}
    </div>
</twig:Card>
