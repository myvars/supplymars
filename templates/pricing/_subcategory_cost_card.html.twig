<twig:Card editLink="{{ path('app_pricing_subcategory_cost_edit', {'id': product.publicId.value }) }}" title="Subcategory" statusHighlight="{{ product.subcategory.isActive ? 'ACTIVE' : 'INACTIVE' }}">
    <p class="mb-3 text-lg font-semibold text-gray-900 line-clamp-1 dark:text-white">{{ product.subcategory.name }}</p>
    <div class="space-y-2 text-sm text-gray-600 dark:text-gray-400">
        <p class="flex items-center gap-2">
            <twig:ux:icon name="mdi:percent-outline" class="h-4 w-4 text-gray-400 dark:text-gray-500"/>
            {% if product.subcategory.hasDefaultMarkup %}
                {{ product.subcategory.defaultMarkup|number_format(3) }}% mark-up
                {% if product.activeMarkupTarget == 'SUBCATEGORY' %}
                    <twig:ux:icon name="bi:check-circle-fill" class="h-4 w-4 text-green-500 dark:text-green-400"/>
                {% endif %}
            {% else %}
                <span class="italic text-gray-400 dark:text-gray-500">No subcategory mark-up</span>
            {% endif %}
        </p>
        <p class="flex items-center gap-2">
            <twig:ux:icon name="mdi:tag-outline" class="h-4 w-4 text-gray-400 dark:text-gray-500"/>
            {% if product.subcategory.hasPriceModel %}
                {{ product.subcategory.priceModel.getName }} price model
                {% if product.activePriceModelTarget == 'SUBCATEGORY' %}
                    <twig:ux:icon name="bi:check-circle-fill" class="h-4 w-4 text-green-500 dark:text-green-400"/>
                {% endif %}
            {% else %}
                <span class="italic text-gray-400 dark:text-gray-500">No subcategory price model</span>
            {% endif %}
        </p>
    </div>
    <twig:CardFooter :updatedAt="product.subcategory.updatedAt">
        <twig:StatusBadge status="{{ product.subcategory.isActive ? 'ACTIVE' : 'INACTIVE' }}"/>
    </twig:CardFooter>
</twig:Card>
