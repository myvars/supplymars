<twig:Card title="Products">
    <a href="{{ path('app_product_index', {categoryId: result.id}) }}"
       class="flex items-center justify-start dark:hover:text-white"
       data-turbo-frame="body"
    >
        <span class="me-1">{{ result.products.count }}</span>
        {{ result.products.count == 1 ? 'product': 'products' }} in this category
    </a>
</twig:Card>