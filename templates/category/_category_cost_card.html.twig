<twig:Card editLink="{{ path('app_product_cost_category_edit', {'id': category.id }) }}" title="Category">
    <p class="mb-1 text-lg text-gray-900 dark:text-white">{{ category.name|u.truncate(30, '...') }}</p>
    <p class="text-lg font-extralight">
        {{ category.defaultMarkup|number_format(3) }}%
        <span class="font-normal text-sm"> mark-up</span>
    </p>
    <p class="font-extralight">{{ category.priceModel.getName }} price model</p>
    <div class="mt-2 flex items-center justify-between">
        <p class="me-10 text-xs text-gray-600 dark:text-gray-500">Updated {{ category.updatedAt|ago }}</p>
        {% if category.isActive %}
            <p class="text-green-500">Active</p>
        {% else %}
            <p class="text-red-500">InActive</p>
        {% endif %}
    </div>
</twig:Card>