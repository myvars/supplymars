{% extends 'base.html.twig' %}

{% block title %}Product Sales{% endblock %}

{% block body %}
    <twig:Card>
    <turbo-frame id="sales">

            <div class="flex items-center justify-between">
                <p class="mb-1 text-gray-600 dark:text-gray-500">Best Selling Products</p>
                <div class="flex justify-end text-xs uppercase text-gray-700 space-x-2 dark:text-gray-400">
                    {% set durations = { 'today': 'TODAY', 'last7': 'LAST 7', 'last30': 'LAST 30', 'mtd': 'MTD' } %}
                    {% for key, label in durations %}
                        <a href="{{ path(app.current_route, app.request.query.all|merge({'duration': key})) }}"
                           class="hover:text-gray-400 dark:hover:text-gray-300 {{ app.request.query.get('duration') == key or (key == 'mtd' and not app.request.query.get('duration')) ? 'text-gray-400 dark:text-gray-300' : '' }}"
                        >
                            {{ label }}
                        </a>
                        {% if not loop.last %}<span>|</span>{% endif %}
                    {% endfor %}
                </div>
            </div>

            <div class="relative mt-2 overflow-x-auto shadow-md sm:rounded-lg">
                <table class="w-full text-left text-sm text-gray-500 dark:text-gray-400">
                    <thead class="bg-gray-50 text-xs uppercase text-gray-700 dark:bg-gray-700 dark:text-gray-400">
                    <tr>
                        <th scope="col" class="px-6 py-3">
                            Product name
                        </th>
                        <th scope="col" class="px-6 py-3">
                            <twig:SortLink sortValue="salesQuantity">Qty</twig:SortLink>
                        </th>
                        <th scope="col" class="px-6 py-3">
                            <div class="flex justify-end">
                                <twig:SortLink sortValue="salesValue">Value</twig:SortLink>
                            </div>
                        </th>
                        <th scope="col" class="px-6 py-3">
                            <div class="flex justify-end">
                                <twig:SortLink sortValue="salesProfit">Profit</twig:SortLink>
                            </div>
                        </th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for result in results %}

                        <tr class="border-b odd:bg-white even:bg-gray-50 dark:border-gray-700 odd:dark:bg-gray-900 even:dark:bg-gray-800">
                            <th scope="row"
                                class="whitespace-nowrap px-6 py-4 font-medium text-gray-900 dark:text-gray-300">
                                <a href="{{ path('app_product_show', {'id': result.id }) }}"
                                   class="dark:hover:text-white"
                                   data-turbo-frame="body"
                                >
                                    {{ result.name|slug.truncate(30, '...') }}
                                </a>
                            </th>
                            <td class="px-6 py-4 text-center">
                                {{ result.salesQuantity }}
                            </td>
                            <td class="px-6 py-4 text-right">
                                {{ result.salesValue|format_currency('GBP') }}
                            </td>
                            <td class="px-6 py-4 text-right">
                                {{ result.salesProfit|format_currency('GBP') }}
                            </td>
                        </tr>

                    {% else %}

                        <tr>
                            <td colspan="4" class="px-6 py-4 text-center text-gray-500 dark:text-gray-400">
                                No sales data available
                            </td>
                        </tr>

                    {% endfor %}
                    </tbody>
                </table>
            </div>
    </turbo-frame>
    </twig:Card>

{% endblock %}