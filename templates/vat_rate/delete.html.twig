{% extends 'base.html.twig' %}

{% block title %}Delete VAT Rate{% endblock %}

{% block body %}
    <section class="bg-gray-50 dark:bg-gray-900 p-3 sm:p-5">
        <div class="flex flex-col items-center px-6 py-8 mx-auto lg:py-0">
            <div
                class="w-full bg-white rounded-lg shadow dark:border md:m-10 sm:max-w-md xl:p-0 dark:bg-gray-800 dark:border-gray-700">
                <div class="p-6 space-y-4 md:space-y-6 sm:p-8">
                    <h1 class="text-xl font-bold leading-tight tracking-tight text-gray-900 md:text-2xl dark:text-white">
                        Delete VAT Rate
                    </h1>
                    <p class="">
                        {{ vat_rate.name }}
                    </p>
                    <p class="text-sm font-light text-gray-500 dark:text-gray-400">
                        Are you sure you want to delete this VAT rate?
                    </p>
                    <form method="post" action="{{ path('app_vat_rate_delete', {'id': vat_rate.id}) }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ vat_rate.id) }}">
                        <twig:Button type="submit" variant="danger" class="w-full">Delete</twig:Button>
                    </form>
                    <p class="text-sm font-light text-gray-500 dark:text-gray-400">
                        <a href="{{ path('app_vat_rate_index') }}" class="hover:underline">Back to list</a>
                    </p>
                </div>
            </div>
        </div>
    </section>
{% endblock %}