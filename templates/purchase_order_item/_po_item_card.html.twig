{% if colourScheme is not defined %}
    {% set colourScheme = purchaseOrderItem.purchaseOrder.supplier.colourScheme %}
{% endif %}
<li class="first:mt-3">
    <twig:Card
        editLink="{{ purchaseOrderItem.allowStatusChange ? path('app_purchase_order_item_status_edit', {'id': purchaseOrderItem.id }) : null }}"
        padding="p-0"
        colour="{{ colourScheme }}"
    >
        <div class="flex items-center justify-between rounded-sm dark:bg-gray-800 dark:hover:bg-gray-700">
            <twig:ProductImage
                imageName="{{ purchaseOrderItem.customerOrderItem.product.hasProductImage ? purchaseOrderItem.customerOrderItem.product.getFirstImage.imageName : null }}"
                filter="small_thumbnail"
                alt="{{ purchaseOrderItem.customerOrderItem.product.name }}"
                showLink="{{ path('app_product_show', {'id': purchaseOrderItem.customerOrderItem.product.id }) }}"
            ></twig:ProductImage>
            <div class="w-full p-3">
                <p class="mb-2 text-sm text-gray-300 line-clamp-1 dark:text-gray-200">{{ purchaseOrderItem.supplierProduct.name }}</p>
                <div class="flex items-center justify-between">
                    <p class="text-lg font-extralight me-3">
                        {{ purchaseOrderItem.priceIncVat|format_currency('GBP') }}
                        <span class="text-sm ms-3">Qty: {{ purchaseOrderItem.quantity }}</span>
                        <span class="hidden text-sm ms-3 md:inline">Product #{{ '%05d'|format(purchaseOrderItem.customerOrderItem.product.id) }}</span>
                    </p>
                    <p class="text-gray-500">
                        <a href="{{ path('app_purchase_order_item_status_log', {'id':purchaseOrderItem.id }) }}"
                           class="text-grey-500 dark:hover:text-gray-800"
                           data-turbo-frame="modal"
                        >
                            {{ purchaseOrderItem.status.value|title }}
                        </a>
                        {% if purchaseOrderItem.status.value|lower == 'delivered' and purchaseOrderItem.deliveredAt is not null %}
                            <span class="py-1">on {{ purchaseOrderItem.deliveredAt|date("jS M Y") }}</span>
                        {% endif %}
                    </p>
                </div>
            </div>
        </div>
    </twig:Card>
</li>