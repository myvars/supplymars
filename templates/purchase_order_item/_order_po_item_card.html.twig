<li class="w-full relative first:mt-3 p-3 text-sm text-gray-500 dark:text-gray-400 border border-supplier-200 rounded-lg shadow dark:bg-supplier-800 dark:border-supplier-700 hover:bg-supplier-50 dark:hover:bg-supplier-700">
    {%  if purchaseOrderItem.allowEdit %}
    {% block purchase_order_item_edit %}
        <a href="{{ path('app_purchase_order_item_edit', {'id': purchaseOrderItem.id }) }}"
           class="absolute -top-1.5 -right-1 p-1.5 bg-white text-yellow-500 border border-supplier-600 rounded-full shadow-lg dark:bg-supplier-700 dark:hover:bg-supplier-600"
           data-turbo-prefetch="false"
           data-turbo-frame="modal"
        >
            <twig:ux:icon name="mynaui:edit-one" class="w-6 h-6 p-0.5"/>
        </a>
    {% endblock %}
    {% endif %}
        <div class="flex justify-between items-center">
            <p class="me-5 text-xs">
                {% if purchaseOrderItem.customerOrderItem.product.productImages|length > 0 %}
                    {% set firstImage = purchaseOrderItem.customerOrderItem.product.productImages|first %}
                    <img class="w-auto rounded-lg"
                         src="{{ asset(product_uploads~firstImage.imageName) | imagine_filter('my_thumbnail') }}"
                    >
                {% else %}
                    <span class="flex text-center">no image</span>
                {% endif %}
            </p>
            <div class="w-full">
                <p class="mb-2 text-sm text-gray-300 dark:text-gray-200">{{ purchaseOrderItem.customerOrderItem.product.name|u.truncate(50, '...') }}</p>
                <p class="flex justify-between items-center">
                    <span class="me-3 text-lg font-extralight">
                        £{{ purchaseOrderItem.customerOrderItem.priceIncVat|number_format(2) }}
                        <span class="ms-3 text-sm">
                            {% if purchaseOrderItem.isCancelled or purchaseOrderItem.isRejected or purchaseOrderItem.quantity is same as purchaseOrderItem.customerOrderItem.quantity %}
                                Qty: {{ purchaseOrderItem.quantity }}
                            {% else %}
                                Qty: {{ purchaseOrderItem.quantity }} of {{ purchaseOrderItem.customerOrderItem.quantity }}
                            {% endif %}
                        </span>
                        <a href="{{ path('app_product_show', {'id': purchaseOrderItem.customerOrderItem.product.id }) }}"
                           class="ms-3 text-sm hover:text-gray-500 dark:hover:text-white"
                           data-turbo-frame="_top"
                           data-turbo-prefetch="false"
                        >
                        Product #{{ '%05d'|format(purchaseOrderItem.customerOrderItem.product.id) }}
                        </a>
                    </span>
                    <span class="text-gray-500">
                        {{ purchaseOrderItem.status.value|title }}
                        {%  if purchaseOrderItem.status.value|lower == 'delivered' and purchaseOrderItem.deliveredAt is not null %}
                            <span class="py-1">on {{ purchaseOrderItem.deliveredAt|date("jS M Y") }}</span>
                        {% endif %}
                    </span>
                </p>
            </div>
        </div>
</li>