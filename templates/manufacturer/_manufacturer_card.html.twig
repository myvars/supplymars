<twig:Card editLink="{{ path('app_manufacturer_edit', {'id': manufacturer.id }) }}" title="Manufacturer">
    <p class="mb-1 text-xl text-gray-900 dark:text-white">{{ manufacturer.name|u.truncate(30, '...') }}</p>
    <div class="mt-3 flex items-center justify-between">
        <p class="me-10 text-xs text-gray-600 dark:text-gray-500">Updated {{ manufacturer.updatedAt|ago }}</p>
        {% if manufacturer.isActive %}
            <p class="text-green-500">Active</p>
        {% else %}
            <p class="text-red-500">InActive</p>
        {% endif %}
    </div>
</twig:Card>