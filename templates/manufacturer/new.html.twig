{% extends 'base.html.twig' %}

{% block title %}New Manufacturer{% endblock %}

{% block body %}
    <section class="bg-gray-50 dark:bg-gray-900 p-3 sm:p-5">
        <div class="flex flex-col items-center px-6 py-8 mx-auto lg:py-0">
            <div
                class="w-full bg-white rounded-lg shadow dark:border md:m-10 sm:max-w-md xl:p-0 dark:bg-gray-800 dark:border-gray-700">
                <div class="p-6 space-y-4 md:space-y-6 sm:p-8">

                    <h1 class="text-xl font-bold leading-tight tracking-tight text-gray-900 md:text-2xl dark:text-white">
                        Create new Manufacturer
                    </h1>
                    {{ include('manufacturer/_form.html.twig', {'button_label': 'Create Manufacturer'}) }}
                    <p class="text-sm font-light text-gray-500 dark:text-gray-400">
                        <a href="{{ path('app_manufacturer_index') }}" class="hover:underline">Back to list</a>
                    </p>
                </div>
            </div>
        </div>
    </section>
{% endblock %}