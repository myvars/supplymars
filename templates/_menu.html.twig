{# Sidebar navigation drawer. Managed by basic-drawer Stimulus controller.
   Active state managed by sidebar-active controller (JS), updated on drawer open.
   Sections: Home, Catalog, Orders, Purchasing, Customers, Reviews, Reporting, Admin, Notes #}
<div id="side-menu" class="fixed top-0 left-0 z-40 h-screen w-72 -translate-x-full overflow-y-auto bg-white dark:bg-gray-900" data-action="turbo:before-cache@window->basic-drawer#close" tabindex="-1" aria-hidden="true">
    <div class="flex h-full flex-col overflow-y-auto border-r border-gray-200 bg-white dark:border-gray-600 dark:bg-gray-900">
        <div class="flex items-center justify-between border-b border-gray-200 px-4 py-4 dark:border-gray-600">
            <a href="{{ path('app_homepage') }}" data-turbo-frame="body" data-action="basic-drawer#close">
                {{ include('_logo.html.twig', { 'logoHeight': 28 }) }}
            </a>
            <button type="button" data-action="basic-drawer#close" class="inline-flex items-center rounded-lg p-1.5 text-sm text-gray-400 transition-colors hover:bg-gray-200 hover:text-gray-900 dark:hover:bg-gray-700 dark:hover:text-white">
                <svg aria-hidden="true" class="h-5 w-5" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"></path></svg>
                <span class="sr-only">Close menu</span>
            </button>
        </div>
        {% set badges = sidebar_badges() %}
        <nav class="flex-1 px-3 py-4"
             data-controller="sidebar-active"
             data-action="turbo:frame-load@window->sidebar-active#update">
            <ul class="space-y-1">
                {# ── Home ── #}
                <li>
                    <a href="{{ path('app_homepage') }}"
                       data-nav="top"
                       class="flex items-center rounded-lg px-3 py-2.5 text-sm font-medium transition-colors text-gray-900 hover:bg-gray-100 dark:text-gray-200 dark:hover:bg-gray-800"
                       data-turbo-frame="body"
                       data-action="basic-drawer#close"
                    >
                        <twig:ux:icon name="flowbite:home-solid" data-nav="icon" class="h-5 w-5 text-gray-500 dark:text-gray-400"/>
                        <span class="ml-3">Home</span>
                    </a>
                </li>
                {# ── Catalog (Products, Categories, Subcategories, Manufacturers) ── #}
                <li>
                    <button type="button" data-nav="section" class="flex w-full items-center rounded-lg px-3 py-2.5 text-sm font-medium transition-colors text-gray-900 hover:bg-gray-100 dark:text-gray-200 dark:hover:bg-gray-800" aria-controls="dropdown-catalog" data-collapse-toggle="dropdown-catalog">
                        <twig:ux:icon name="bi:box-seam-fill" data-nav="icon" class="h-5 w-5 text-gray-500 dark:text-gray-400"/>
                        <span class="ml-3 flex-1 whitespace-nowrap text-left">Catalog</span>
                        <twig:ux:icon name="bi:chevron-down" data-nav="chevron" class="h-4 w-4 text-gray-400"/>
                    </button>
                    <ul id="dropdown-catalog" data-nav="dropdown" class="mt-1 hidden space-y-0.5 pl-4">
                        <li>
                            <a href="{{ path('app_catalog_product_index') }}"
                               data-nav="child"
                               class="flex w-full items-center rounded-lg px-3 py-2 pl-8 text-sm transition-colors text-gray-700 hover:bg-gray-100 dark:text-gray-400 dark:hover:bg-gray-800 dark:hover:text-gray-200"
                               data-turbo-frame="body"
                               data-action="basic-drawer#close"
                            >Products</a>
                        </li>
                        <li>
                            <a href="{{ path('app_catalog_category_index') }}"
                               data-nav="child"
                               class="flex w-full items-center rounded-lg px-3 py-2 pl-8 text-sm transition-colors text-gray-700 hover:bg-gray-100 dark:text-gray-400 dark:hover:bg-gray-800 dark:hover:text-gray-200"
                               data-turbo-frame="body"
                               data-action="basic-drawer#close"
                            >Categories</a>
                        </li>
                        <li>
                            <a href="{{ path('app_catalog_subcategory_index') }}"
                               data-nav="child"
                               class="flex w-full items-center rounded-lg px-3 py-2 pl-8 text-sm transition-colors text-gray-700 hover:bg-gray-100 dark:text-gray-400 dark:hover:bg-gray-800 dark:hover:text-gray-200"
                               data-turbo-frame="body"
                               data-action="basic-drawer#close"
                            >Subcategories</a>
                        </li>
                        <li>
                            <a href="{{ path('app_catalog_manufacturer_index') }}"
                               data-nav="child"
                               class="flex w-full items-center rounded-lg px-3 py-2 pl-8 text-sm transition-colors text-gray-700 hover:bg-gray-100 dark:text-gray-400 dark:hover:bg-gray-800 dark:hover:text-gray-200"
                               data-turbo-frame="body"
                               data-action="basic-drawer#close"
                            >Manufacturers</a>
                        </li>
                    </ul>
                </li>
                {# ── Orders ── #}
                <li>
                    <a href="{{ path('app_order_index') }}"
                       data-nav="top"
                       class="flex items-center rounded-lg px-3 py-2.5 text-sm font-medium transition-colors text-gray-900 hover:bg-gray-100 dark:text-gray-200 dark:hover:bg-gray-800"
                       data-turbo-frame="body"
                       data-action="basic-drawer#close"
                    >
                        <twig:ux:icon name="bi:bag-check" data-nav="icon" class="h-5 w-5 text-gray-500 dark:text-gray-400"/>
                        <span class="ml-3">Orders</span>
                    </a>
                </li>

                {# ── Purchasing (POs, Suppliers, Supplier Products) ── #}
                <li>
                    <button type="button" data-nav="section" class="flex w-full items-center rounded-lg px-3 py-2.5 text-sm font-medium transition-colors text-gray-900 hover:bg-gray-100 dark:text-gray-200 dark:hover:bg-gray-800" aria-controls="dropdown-purchasing" data-collapse-toggle="dropdown-purchasing">
                        <twig:ux:icon name="bi:building" data-nav="icon" class="h-5 w-5 text-gray-500 dark:text-gray-400"/>
                        <span class="ml-3 flex-1 whitespace-nowrap text-left">Purchasing</span>
                        <twig:ux:icon name="bi:chevron-down" data-nav="chevron" class="h-4 w-4 text-gray-400"/>
                    </button>
                    <ul id="dropdown-purchasing" data-nav="dropdown" class="mt-1 hidden space-y-0.5 pl-4">
                        <li>
                            <a href="{{ path('app_purchasing_purchase_order_index') }}"
                               data-nav="child"
                               class="flex w-full items-center rounded-lg px-3 py-2 pl-8 text-sm transition-colors text-gray-700 hover:bg-gray-100 dark:text-gray-400 dark:hover:bg-gray-800 dark:hover:text-gray-200"
                               data-turbo-frame="body"
                               data-action="basic-drawer#close"
                            >Purchase Orders</a>
                        </li>
                        <li>
                            <a href="{{ path('app_purchasing_supplier_index') }}"
                               data-nav="child"
                               class="flex w-full items-center rounded-lg px-3 py-2 pl-8 text-sm transition-colors text-gray-700 hover:bg-gray-100 dark:text-gray-400 dark:hover:bg-gray-800 dark:hover:text-gray-200"
                               data-turbo-frame="body"
                               data-action="basic-drawer#close"
                            >Suppliers</a>
                        </li>
                        <li>
                            <a href="{{ path('app_purchasing_supplier_product_index') }}"
                               data-nav="child"
                               class="flex w-full items-center rounded-lg px-3 py-2 pl-8 text-sm transition-colors text-gray-700 hover:bg-gray-100 dark:text-gray-400 dark:hover:bg-gray-800 dark:hover:text-gray-200"
                               data-turbo-frame="body"
                               data-action="basic-drawer#close"
                            >Supplier Products</a>
                        </li>
                    </ul>
                </li>
                {# ── Customers ── #}
                <li>
                    <a href="{{ path('app_customer_index') }}"
                       data-nav="top"
                       class="flex items-center rounded-lg px-3 py-2.5 text-sm font-medium transition-colors text-gray-900 hover:bg-gray-100 dark:text-gray-200 dark:hover:bg-gray-800"
                       data-turbo-frame="body"
                       data-action="basic-drawer#close"
                    >
                        <twig:ux:icon name="flowbite:users-solid" data-nav="icon" class="h-5 w-5 text-gray-500 dark:text-gray-400"/>
                        <span class="ml-3 flex-1 whitespace-nowrap text-left">Customers</span>
                    </a>
                </li>
                {# ── Reviews (Search, Moderation Queue) ── #}
                <li>
                    <button type="button" data-nav="section" class="flex w-full items-center rounded-lg px-3 py-2.5 text-sm font-medium transition-colors text-gray-900 hover:bg-gray-100 dark:text-gray-200 dark:hover:bg-gray-800" aria-controls="dropdown-reviews" data-collapse-toggle="dropdown-reviews">
                        <twig:ux:icon name="flowbite:star-solid" data-nav="icon" class="h-5 w-5 text-gray-500 dark:text-gray-400"/>
                        <span class="ml-3 flex-1 whitespace-nowrap text-left">Reviews</span>
                        <twig:ux:icon name="bi:chevron-down" data-nav="chevron" class="h-4 w-4 text-gray-400"/>
                    </button>
                    <ul id="dropdown-reviews" data-nav="dropdown" class="mt-1 hidden space-y-0.5 pl-4">
                        <li>
                            <a href="{{ path('app_review_index') }}"
                               data-nav="child"
                               class="flex w-full items-center rounded-lg px-3 py-2 pl-8 text-sm transition-colors text-gray-700 hover:bg-gray-100 dark:text-gray-400 dark:hover:bg-gray-800 dark:hover:text-gray-200"
                               data-turbo-frame="body"
                               data-action="basic-drawer#close"
                            >Review Search</a>
                        </li>
                        <li>
                            <a href="{{ path('app_review_index', {reviewStatus: 'PENDING'}) }}"
                               data-nav="child"
                               class="flex w-full items-center justify-between rounded-lg px-3 py-2 pl-8 text-sm transition-colors text-gray-700 hover:bg-gray-100 dark:text-gray-400 dark:hover:bg-gray-800 dark:hover:text-gray-200"
                               data-turbo-frame="body"
                               data-action="basic-drawer#close"
                            >Moderation Queue{% if badges.pendingReviews > 0 %}<span class="ml-auto inline-flex items-center rounded-full bg-red-100 px-2 py-0.5 text-xs font-medium text-red-800 dark:bg-red-900/30 dark:text-red-400">{{ badges.pendingReviews }}</span>{% endif %}</a>
                        </li>
                    </ul>
                </li>
                {# ── Reporting (Dashboards, Summaries) ── #}
                <li>
                    <button type="button" data-nav="section" class="flex w-full items-center rounded-lg px-3 py-2.5 text-sm font-medium transition-colors text-gray-900 hover:bg-gray-100 dark:text-gray-200 dark:hover:bg-gray-800" aria-controls="dropdown-reporting" data-collapse-toggle="dropdown-reporting">
                        <twig:ux:icon name="bi:bar-chart-line-fill" data-nav="icon" class="h-5 w-5 text-gray-500 dark:text-gray-400"/>
                        <span class="ml-3 flex-1 whitespace-nowrap text-left">Reporting</span>
                        <twig:ux:icon name="bi:chevron-down" data-nav="chevron" class="h-4 w-4 text-gray-400"/>
                    </button>
                    <ul id="dropdown-reporting" data-nav="dropdown" class="mt-1 hidden space-y-0.5 pl-4">
                        <li>
                            <a href="{{ path('app_reporting_dashboard') }}"
                               data-nav="child"
                               class="flex w-full items-center rounded-lg px-3 py-2 pl-8 text-sm transition-colors text-gray-700 hover:bg-gray-100 dark:text-gray-400 dark:hover:bg-gray-800 dark:hover:text-gray-200"
                               data-turbo-frame="body"
                               data-action="basic-drawer#close"
                            >Dashboard</a>
                        </li>
                        <li>
                            <a href="{{ path('app_reporting_dashboard_product_sales') }}"
                               data-nav="child"
                               class="flex w-full items-center rounded-lg px-3 py-2 pl-8 text-sm transition-colors text-gray-700 hover:bg-gray-100 dark:text-gray-400 dark:hover:bg-gray-800 dark:hover:text-gray-200"
                               data-turbo-frame="body"
                               data-action="basic-drawer#close"
                            >Product Sales</a>
                        </li>
                        <li>
                            <a href="{{ path('app_reporting_dashboard_order_summary') }}"
                               data-nav="child"
                               class="flex w-full items-center rounded-lg px-3 py-2 pl-8 text-sm transition-colors text-gray-700 hover:bg-gray-100 dark:text-gray-400 dark:hover:bg-gray-800 dark:hover:text-gray-200"
                               data-turbo-frame="body"
                               data-action="basic-drawer#close"
                            >Order Summary</a>
                        </li>
                        <li>
                            <a href="{{ path('app_reporting_dashboard_customer_insights') }}"
                               data-nav="child"
                               class="flex w-full items-center rounded-lg px-3 py-2 pl-8 text-sm transition-colors text-gray-700 hover:bg-gray-100 dark:text-gray-400 dark:hover:bg-gray-800 dark:hover:text-gray-200"
                               data-turbo-frame="body"
                               data-action="basic-drawer#close"
                            >Customer Insights</a>
                        </li>
                        <li>
                            <a href="{{ path('app_reporting_dashboard_po_performance') }}"
                               data-nav="child"
                               class="flex w-full items-center rounded-lg px-3 py-2 pl-8 text-sm transition-colors text-gray-700 hover:bg-gray-100 dark:text-gray-400 dark:hover:bg-gray-800 dark:hover:text-gray-200"
                               data-turbo-frame="body"
                               data-action="basic-drawer#close"
                            >PO Performance</a>
                        </li>
                        <li>
                            <a href="{{ path('app_reporting_dashboard_overdue_orders', {'duration': 'last30'}) }}"
                               data-nav="child"
                               class="flex w-full items-center justify-between rounded-lg px-3 py-2 pl-8 text-sm transition-colors text-gray-700 hover:bg-gray-100 dark:text-gray-400 dark:hover:bg-gray-800 dark:hover:text-gray-200"
                               data-turbo-frame="body"
                               data-action="basic-drawer#close"
                            >Overdue Orders{% if badges.overdueOrders > 0 %}<span class="ml-auto inline-flex items-center rounded-full bg-orange-100 px-2 py-0.5 text-xs font-medium text-orange-800 dark:bg-orange-900/30 dark:text-orange-400">{{ badges.overdueOrders }}</span>{% endif %}</a>
                        </li>
                        <li>
                            <a href="{{ path('app_purchasing_purchase_order_index', {'purchaseOrderStatus': 'REJECTED'}) }}"
                               data-nav="child"
                               class="flex w-full items-center justify-between rounded-lg px-3 py-2 pl-8 text-sm transition-colors text-gray-700 hover:bg-gray-100 dark:text-gray-400 dark:hover:bg-gray-800 dark:hover:text-gray-200"
                               data-turbo-frame="body"
                               data-action="basic-drawer#close"
                            >Rejected POs{% if badges.rejectedPos > 0 %}<span class="ml-auto inline-flex items-center rounded-full bg-red-100 px-2 py-0.5 text-xs font-medium text-red-800 dark:bg-red-900/30 dark:text-red-400">{{ badges.rejectedPos }}</span>{% endif %}</a>
                        </li>
                    </ul>
                </li>
                {# ── Admin (VAT Rates) ── #}
                <li>
                    <button type="button" data-nav="section" class="flex w-full items-center rounded-lg px-3 py-2.5 text-sm font-medium transition-colors text-gray-900 hover:bg-gray-100 dark:text-gray-200 dark:hover:bg-gray-800" aria-controls="dropdown-admin" data-collapse-toggle="dropdown-admin">
                        <twig:ux:icon name="flowbite:cog-solid" data-nav="icon" class="h-5 w-5 text-gray-500 dark:text-gray-400"/>
                        <span class="ml-3 flex-1 whitespace-nowrap text-left">Admin</span>
                        <twig:ux:icon name="bi:chevron-down" data-nav="chevron" class="h-4 w-4 text-gray-400"/>
                    </button>
                    <ul id="dropdown-admin" data-nav="dropdown" class="mt-1 hidden space-y-0.5 pl-4">
                        <li>
                            <a href="{{ path('app_pricing_vat_rate_index') }}"
                               data-nav="child"
                               class="flex w-full items-center rounded-lg px-3 py-2 pl-8 text-sm transition-colors text-gray-700 hover:bg-gray-100 dark:text-gray-400 dark:hover:bg-gray-800 dark:hover:text-gray-200"
                               data-turbo-frame="body"
                               data-action="basic-drawer#close"
                            >VAT Rates</a>
                        </li>
                    </ul>
                </li>
            </ul>
            {# ── Notes (Tickets, Pools) — separated by divider ── #}
            <div class="mt-4 border-t border-gray-200 pt-4 dark:border-gray-600">
                <ul class="space-y-1">
                    <li>
                        <button type="button" data-nav="section" class="flex w-full items-center rounded-lg px-3 py-2.5 text-sm font-medium transition-colors text-gray-900 hover:bg-gray-100 dark:text-gray-200 dark:hover:bg-gray-800" aria-controls="dropdown-notes" data-collapse-toggle="dropdown-notes">
                            <twig:ux:icon name="bi:inbox-fill" data-nav="icon" class="h-5 w-5 text-gray-500 dark:text-gray-400"/>
                            <span class="ml-3 flex-1 whitespace-nowrap text-left">Notes</span>
                            <twig:ux:icon name="bi:chevron-down" data-nav="chevron" class="h-4 w-4 text-gray-400"/>
                        </button>
                        <ul id="dropdown-notes" data-nav="dropdown" class="mt-1 hidden space-y-0.5 pl-4">
                            <li>
                                <a href="{{ path('app_note_ticket_index', {'myPools': 1}) }}"
                                   data-nav="child"
                                   class="flex w-full items-center justify-between rounded-lg px-3 py-2 pl-8 text-sm transition-colors text-gray-700 hover:bg-gray-100 dark:text-gray-400 dark:hover:bg-gray-800 dark:hover:text-gray-200"
                                   data-turbo-frame="body"
                                   data-action="basic-drawer#close"
                                >My Queue{% if badges.myQueue > 0 %}<span class="ml-auto inline-flex items-center rounded-full bg-blue-100 px-2 py-0.5 text-xs font-medium text-blue-800 dark:bg-blue-900/30 dark:text-blue-400">{{ badges.myQueue }}</span>{% endif %}</a>
                            </li>
                            <li>
                                <a href="{{ path('app_note_ticket_index') }}"
                                   data-nav="child"
                                   class="flex w-full items-center rounded-lg px-3 py-2 pl-8 text-sm transition-colors text-gray-700 hover:bg-gray-100 dark:text-gray-400 dark:hover:bg-gray-800 dark:hover:text-gray-200"
                                   data-turbo-frame="body"
                                   data-action="basic-drawer#close"
                                >Tickets</a>
                            </li>
                            <li>
                                <a href="{{ path('app_note_pool_index') }}"
                                   data-nav="child"
                                   class="flex w-full items-center rounded-lg px-3 py-2 pl-8 text-sm transition-colors text-gray-700 hover:bg-gray-100 dark:text-gray-400 dark:hover:bg-gray-800 dark:hover:text-gray-200"
                                   data-turbo-frame="body"
                                   data-action="basic-drawer#close"
                                >Pools</a>
                            </li>
                        </ul>
                    </li>
                </ul>
            </div>
        </nav>
    </div>
</div>
