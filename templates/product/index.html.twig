{% extends 'base.html.twig' %}

{% block title %}{{ section }} index{% endblock %}

{% block body %}
    <twig:Search
        section="{{ section }}"
        results="{{ results }}"
    >
        <twig:block name="sort">
            <twig:Card>
                <div class="flex justify-between overflow-auto">
                    <twig:SortLink sortValue="id">Id</twig:SortLink>
                    <twig:SortLink sortValue="name">Product</twig:SortLink>
                    <twig:SortLink sortValue="stock">Stock</twig:SortLink>
                    <twig:SortLink sortValue="sellPriceIncVat">Price</twig:SortLink>
                    <twig:SortLink sortValue="isActive">Status</twig:SortLink>
                </div>
            </twig:Card>
        </twig:block>

        <twig:block name="list_item">
            <twig:Card
                editLink="{{ path('app_product_edit', {'id': result.id }) }}"
                showLink="{{ path('app_product_show', {'id': result.id }) }}"
                padding="p-0"
            >
                <div class="flex justify-between items-center">
                    <p class="text-xs me-1">
                        {% if result.productImages|length > 0 %}
                            {% set firstImage = result.productImages|first %}
                            <img class="w-auto rounded-s-lg"
                                 src="{{ asset(product_uploads~firstImage.imageName) | imagine_filter('medium_thumbnail') }}"
                                 alt=""
                            >
                        {% else %}
                            <span class="flex text-center">no image</span>
                        {% endif %}
                    </p>
                    <div class="w-full p-3">
                        <p class="mb-1 text-lg text-gray-900 dark:text-white">{{ result.name|u.truncate(30, '...') }}</p>
                        <p class="mb-1 text-sm">Product {{ '%06d'|format(result.id) }}</p>
                        <p class="flex justify-between items-center">
                            {% if result.hasOwner %}
                                <span class="me-1 text-xs text-gray-600 dark:text-gray-500">Managed by {{ result.owner.fullName }}</span>
                            {% else %}
                                <span class="me-1 text-xs text-gray-600 dark:text-gray-500">No product manager</span>
                            {% endif %}
                            <span class="me-1 font-extralight">{{ result.stock }} stock</span>
                            <span
                                class="me-1 text-base sm:text-lg font-extralight">{{ result.sellPriceIncVat|format_currency('GBP') }}
                                <span class="me-1 font-normal text-sm text-nowrap text-gray-500 dark:text-gray-400"> inc VAT</span>
                            </span>
                            {% if result.isActive %}
                                <span class="text-green-500">Active</span>
                            {% else %}
                                <span class="text-red-500">InActive</span>
                            {% endif %}
                        </p>
                    </div>
                </div>
            </twig:Card>
        </twig:block>

        <twig:block name="add">
            <twig:Button
                tag="a"
                href="{{ path('app_product_new') }}"
                class="flex items-center space-x-1 font-bold"
                data-turbo-frame="modal"
            >
                <twig:ux:icon name="flowbite:circle-plus-outline" class="w-5"/>
                <span>Create Product</span>
            </twig:Button>
        </twig:block>

    </twig:Search>

{% endblock %}