{% extends 'base.html.twig' %}

{% block title %}{{ section }} index{% endblock %}

{% block body %}
    <twig:DataList
        section="{{ section }}"
        results="{{ results }}"
    >
        <twig:block name="list_sort">
            <twig:SortLink sortValue="id">Id</twig:SortLink>
            <twig:SortLink sortValue="name">Product</twig:SortLink>
            <twig:SortLink sortValue="stock">Stock</twig:SortLink>
            <twig:SortLink sortValue="sellPriceIncVat">Price</twig:SortLink>
            <twig:SortLink sortValue="isActive">Status</twig:SortLink>
        </twig:block>

        <twig:block name="list_item">
            <p class="mb-1 items-center text-lg text-gray-900 dark:text-white">{{ result.name|u.truncate(30, '...') }}</p>
            <p class="mb-1 items-center text-sm">Product {{ '%06d'|format(result.id) }}</p>
            <p class="flex justify-between items-center">
                {% if result.owner is not null%}
                    <span class="me-1 text-gray-600 dark:text-gray-500">Managed by {{ result.owner.fullName }}</span>
                {% else %}
                    <span class="me-1 text-gray-600 dark:text-gray-500">No product manager</span>
                {% endif %}
                <span class="me-1 font-extralight">{{ result.stock }} stock</span>
                <span class="me-1 text-base sm:text-lg font-extralight">£{{ result.sellPriceIncVat|number_format(2) }}
                    <span class="me-1 font-normal text-sm text-nowrap text-gray-500 dark:text-gray-400"> inc VAT</span>
                </span>
                {% if result.isActive %}
                    <span class="text-green-500">Active</span>
                {% else %}
                    <span class="text-red-500">InActive</span>
                {% endif %}
            </p>
        </twig:block>

        <twig:block name="list_add">
            <twig:Button
                tag="a"
                href="{{ path('app_'~section|lower|u.snake~'_new') }}"
                class="flex items-center space-x-1 font-bold"
                data-turbo-frame="modal"
            >
                <twig:ux:icon name="flowbite:circle-plus-outline" class="w-5"/>
                <span>Add {{ section }}</span>
            </twig:Button>
        </twig:block>

        <twig:block name="filter"></twig:block>
    </twig:DataList>

{% endblock %}