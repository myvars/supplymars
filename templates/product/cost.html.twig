{% extends 'base.html.twig' %}

{% block title %}Product Cost{% endblock %}

{% block body %}

<section class="bg-gray-50 dark:bg-gray-900 p-3 sm:p-5">
    <div class="p-6 space-y-4 md:space-y-6 sm:p-8">
        <h1 class="text-2xl font-semibold text-white mb-4">Product Costing</h1>

        {% if result.isActive and result.category.isActive and result.subcategory.isActive and result.activeProductSource is not null%}
            <section class="bg-white dark:bg-gray-900 border border-gray-700 rounded-lg">
                <div class="max-w-screen-xl px-4 py-8 mx-auto text-center lg:py-14 lg:px-6">
                    <dl class="grid max-w-screen-md gap-8 mx-auto text-gray-900 sm:grid-cols-3 dark:text-white">
                        <div class="flex flex-col items-center justify-center">
                            <dt class="mb-2 font-light text-gray-500 dark:text-gray-400">Cost Price</dt>
                            <dd class="text-3xl md:text-4xl font-bold text-gray-600 dark:text-gray-500">£{{ result.cost|number_format(2) }}</dd>
                        </div>
                        <div class="flex flex-col items-center justify-center">
                            <dt class="mb-2 font-light text-gray-500 dark:text-gray-400">Sell Price</dt>
                            <dd class="text-3xl md:text-4xl font-bold">£{{ result.sellPrice|number_format(2) }}</dd>
                        </div>
                        <div class="flex flex-col items-center justify-center">
                            <dt class="mb-2 font-light text-gray-500 dark:text-gray-400">Sell Price Inc VAT</dt>
                            <dd class="text-3xl md:text-4xl font-bold">£{{ result.sellPriceIncVat|number_format(2) }}</dd>
                        </div>
                    </dl>
                </div>
            </section>
            <section class="bg-white dark:bg-gray-900 border border-gray-700 rounded-lg">
                <div class="p-4 text-center">
                    <p class="text-2xl font-light text-gray-700 dark:text-gray-500">Active Markup: {{ result.markup|number_format(3) }}%</p>
                </div>
            </section>
        {% endif %}

        {% if result.isActive and result.category.isActive and result.subcategory.isActive and result.activeProductSource is not null%}
        {% else %}
            <section class="bg-white dark:bg-gray-900 border border-gray-700 rounded-lg">
                <div class="p-4 text-center">
                    <p class="mb-2 text-2xl font-light text-red-400 dark:text-red-400">Inactive Product</p>
                    {% if result.activeProductSource is null%}
                        <p class="text-sm font-light text-red-600 dark:text-gray-500">No Active Supplier</p>
                    {% else %}
                        <p class="text-sm font-light text-red-600 dark:text-gray-500">Inactive Category, Subcategory or Product</p>
                    {% endif %}
                </div>
            </section>
        {% endif %}

        <table class="w-full text-sm text-left text-gray-500 dark:text-gray-400">
            <thead class="text-xs text-gray-700 uppercase bg-gray-50 dark:bg-gray-700 dark:text-gray-400">
            <tr>
                <td class="p-2 ps-4">Name</td>
                <td class="text-nowrap">Price Model</td>
                <td>Markup</td>
                <td>Status</td>
                <td></td>
            </tr>
            </thead>
            <tbody>
            <tr class="border-b dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600">
                <td class="min-w-0 flex-auto p-4">
                    <p class="text-xs text-gray-500">Category</p>
                    <p class="mt-1 text-base leading-5 text-gray-300">{{ result.category.name|u.truncate(30, '...', false) }}</p>
                </td>
                <td class="mt-1 text-sm leading-5 text-gray-300">{{ result.category.priceModel.getName }}</td>
                <td class="mt-1 text-sm leading-5 text-gray-300">{{ result.category.defaultMarkup|number_format(3) }}%</td>
                <td>
                    <div class="flex items-center text-gray-300">
                        {{ result.category.isActive ?
                        '<span class="flex w-2.5 h-2.5 me-2 rounded-full bg-green-500"></span>Active'
                        : '<span class="flex w-2.5 h-2.5 me-2 rounded-full bg-red-500 "></span>Inactive' }}
                    </div>
                </td>
                <td class="px-4">
                    <div class="shrink-0 sm:flex sm:flex-col sm:items-end">
                        <a href="{{ path('app_product_cost_category_edit', {'id': result.id }) }}"
                           class="flex items-center block py-1 px-4 text-yellow-700 dark:text-yellow-500 hover:bg-gray-100 dark:hover:bg-gray-600"
                           data-turbo-frame="modal"
                        >
                            <twig:Icon name="edit" class="w-4 me-1.5"></twig:Icon>
                            Edit</a>
                        <p class="text-xs leading-5 text-gray-500">Last updated {{ result.category.updatedAt|ago }}</p>
                    </div>
                </td>
            </tr>
            <tr class="border-b dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600">
                <td class="min-w-0 flex-auto p-4">
                    <p class="text-xs text-gray-500">Subcategory</p>
                    <p class="mt-1 text-base leading-5 text-gray-300">{{ result.subcategory.name|u.truncate(30, '...', false) }}</p>
                </td>
                <td class="mt-1 text-sm leading-5 text-gray-300">{{ result.subcategory.priceModel.getName }}</td>
                <td class="mt-1 text-sm leading-5 text-gray-300">{{ result.subcategory.defaultMarkup|number_format(3) }}%</td>
                <td>
                    <div class="flex items-center text-gray-300">
                        {{ result.subcategory.isActive ?
                        '<span class="flex w-2.5 h-2.5 me-2 rounded-full bg-green-500"></span>Active'
                        : '<span class="flex w-2.5 h-2.5 me-2 rounded-full bg-red-500 "></span>Inactive' }}
                    </div>
                </td>
                <td class="px-4">
                    <div class="shrink-0 sm:flex sm:flex-col sm:items-end">
                        <a href="{{ path('app_product_cost_subcategory_edit', {'id': result.id }) }}"
                           class="flex items-center block py-1 px-4 text-yellow-700 dark:text-yellow-500 hover:bg-gray-100 dark:hover:bg-gray-600"
                           data-turbo-frame="modal"
                        >
                            <twig:Icon name="edit" class="w-4 me-1.5"></twig:Icon>
                            Edit</a>
                        <p class="text-xs leading-5 text-gray-500">Last
                            updated {{ result.subcategory.updatedAt|ago }}</p>
                    </div>
                </td>
            </tr>
            <tr class="border-b dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600">
                <td class="min-w-0 flex-auto p-4">
                    <p class="text-xs text-gray-500">Product</p>
                    <p class="mt-1 text-base leading-5 text-gray-300">{{ result.name|u.truncate(30, '...', false) }}</p>
                </td>
                <td class="mt-1 text-sm leading-5 text-gray-300">{{ result.priceModel.getName }}</td>
                <td class="mt-1 text-sm leading-5 text-gray-300">{{ result.defaultMarkup|number_format(3) }}%</td>
                <td>
                    <div class="flex items-center text-gray-300">
                        {{ result.isActive ?
                        '<span class="flex w-2.5 h-2.5 me-2 rounded-full bg-green-500"></span>Active'
                        : '<span class="flex w-2.5 h-2.5 me-2 rounded-full bg-red-500 "></span>Inactive' }}
                    </div>
                </td>
                <td class="px-4">
                    <div class="shrink-0 sm:flex sm:flex-col sm:items-end">
                        <a href="{{ path('app_product_cost_edit', {'id': result.id }) }}"
                           class="flex items-center block py-1 px-4 text-yellow-700 dark:text-yellow-500 hover:bg-gray-100 dark:hover:bg-gray-600"
                           data-turbo-frame="modal"
                        >
                            <twig:Icon name="edit" class="w-4 me-1.5"></twig:Icon>
                            Edit</a>
                        <p class="text-xs leading-5 text-gray-500">Last updated {{ result.updatedAt|ago }}</p>
                    </div>
                </td>
            </tr>
            </tbody>
        </table>
    </div>
</section>
{% endblock %}



