{% extends 'product/_navigation.html.twig' %}

{% block title %}Product Images{% endblock %}

{% block detail %}

    <div class="p-6 sm:p-8 space-y-4 md:space-y-6 text-sm text-gray-500 dark:text-gray-400">
        <div class="mb-8">
            <h1 class="mb-4 text-2xl font-semibold text-white">
                Product Images
                <span class="ms-3 text-base font-light text-sm text-gray-500 dark:text-gray-400">
                    {{ result.productImages|length }} {% if result.productImages|length == 1 %}result{% else %}results{% endif %}
                </span>
            </h1>
            <form action="{{ path('app_product_image_create', {id: result.id}) }}"
                  method="post"
                  enctype="multipart/form-data"
                  class="dropzone"
                  data-controller="dropzone"
                  data-dropzone-url-value="{{ path('app_product_image_create', {id: result.id}) }}"
                  data-dropzone-param-name-value="imageFile"
            >
            </form>
        </div>
        <div class="flex flex-wrap justify-center gap-4"
             data-controller="sortable"
             data-sortable-reorder-url-value="{{ path('app_product_image_reorder', {id: result.id}) }}"
        >
            {% for productImage in result.productImages %}
                <div class="relative border border-gray-200 rounded-lg shadow dark:bg-gray-800 dark:border-gray-700"
                     data-id="{{ productImage.id }}"
                >
                    <a href="{{ path('app_product_image_remove', {id: productImage.id}) }}"
                       class="absolute -top-1.5 -right-1 p-1.5 bg-white text-gray-300 border border-gray-600 dark:bg-gray-700 dark:hover:bg-gray-600 rounded-full shadow-lg"
                       data-turbo-prefetch="false"
                    >
                        <twig:Icon name="delete" class="w-6 h-6 p-0.5"/>
                    </a>
                    <img class="w-60 mx-auto rounded-lg"
                         src="{{ asset(product_uploads~productImage.imageName) | imagine_filter('large_thumbnail') }}"
                         alt=""
                    >
                    <div class="p-5">
                        <h5 class="mb-2 font-bold text-gray-300 dark:text-white">{{ productImage.imageName|u.truncate(25, '...') }}</h5>
                        <div class="flex items-center justify-between text-xs">
                            <p>Uploaded {{ productImage.createdAt|ago }}</p>
                            <p>{{ (productImage.imageSize/1000)|number_format(1) }}Kb</p>
                        </div>
                    </div>
                </div>
            {% else %}
                <p class="mb-1 text-2xl">No product images found</p>
            {% endfor %}
        </div>
    </div>

{% endblock %}