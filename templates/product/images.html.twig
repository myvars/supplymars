{% extends 'product/_navigation.html.twig' %}

{% block title %}Product Images{% endblock %}

{% block detail %}
<div class="p-6 space-y-4 md:space-y-6 sm:p-8">
        <h1 class="text-2xl font-semibold text-white mb-4">Product Images</h1>
        <div class="flex flex-col space-y-4">
            <div class="flex flex-col space-y-2">
                <div class="flex flex-col space-y-2">

                    {% for productImage in result.productImages %}
                        <div class="flex flex-col space-y-2">
                            <div class="flex flex-row items-center space-x-2">
                                 <a href="{{ path('app_product_image_delete_confirm', {id: productImage.id}) }}" class="text-red-500 hover:underline">Delete</a>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </div>
            <div class="flex flex-col space-y-2">
                <h2 class="text-lg font-semibold text-white">Add Image</h2>
                <form action="{{ path('app_product_image_new', {id: result.id}) }}" method="post" enctype="multipart/form-data">
                    <div class="flex flex-col space-y-2">
                        <input type="file" name="file" class="p-2 border border-gray-300 rounded-md" required>
                    </div>
                    <div class="flex flex-col space-y-2">
                        <twig:Button type="submit" class="w-full" name="btnSubmit" value="submit">Add Image</twig:Button>
                    </div>
                </form>
            </div>
</div>
{% endblock %}