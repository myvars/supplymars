{% extends 'product/_navigation.html.twig' %}

{% block title %}Product Attachments{% endblock %}

{% block detail %}
<div class="p-6 space-y-4 md:space-y-6 sm:p-8">
        <h1 class="text-2xl font-semibold text-white mb-4">Product Attachments</h1>
        <div class="flex flex-col space-y-4">
            <div class="flex flex-col space-y-2">
                <h2 class="text-lg font-semibold text-white">Attachments</h2>
                <div class="flex flex-col space-y-2">
{#
                    {% for attachment in product.attachments %}
                        <div class="flex flex-col space-y-2">
                            <div class="flex flex-row items-center space-x-2">
                                <a href="{{ asset('uploads/attachments/' ~ attachment.file) }}" class="text-blue-500 hover:underline" target="_blank">{{ attachment.file }}</a>
                                <a href="{{ path('product_attachment_delete', {id: attachment.id}) }}" class="text-red-500 hover:underline">Delete</a>
                            </div>
                        </div>
                    {% endfor %}
#}
                </div>
            </div>
            <div class="flex flex-col space-y-2">
                <h2 class="text-lg font-semibold text-white">Add Attachment</h2>
{#
                <form action="{{ path('product_attachment_add', {id: product.id}) }}" method="post" enctype="multipart/form-data">
                    <div class="flex flex-col space-y-2">
                        <input type="file" name="attachment" class="p-2 border border-gray-300 rounded-md" required>
                    </div>
                    <div class="flex flex-col space-y-2">
                        <button type="submit" class="p-2 bg-blue-500 text-white rounded-md">Add Attachment</button>
                    </div>
                </form>
#}
            </div>

</div>
{% endblock %}