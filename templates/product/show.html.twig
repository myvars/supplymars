{% extends 'product/_navigation.html.twig' %}

{% block title %}Product Details{% endblock %}

{% block detail %}
    <div class="p-6 space-y-4 md:space-y-6 sm:p-8">
        <h1 class="text-2xl font-semibold text-white mb-4">Product Details</h1>

        <div class="relative max-w-sm bg-white border border-gray-200 rounded-lg shadow dark:bg-gray-800 dark:border-gray-700">
                <a href="{{ path('app_product_edit', {id: result.id}) }}"
                   class="absolute -top-1.5 -right-1 p-1.5 bg-white text-yellow-500 border border-gray-600 dark:bg-gray-700 dark:hover:bg-gray-600 rounded-full shadow-lg"
                   data-turbo-prefetch="false"
                   data-turbo-frame="modal"
                >
                    <twig:Icon name="edit" class="w-6 h-6 p-0.5"/>
                </a>
                {% if result.productImages|length > 0 %}
                <a href="#">
                    <img class="w-auto m-5 mb-0 rounded-lg"
                        {% set firstImage = result.productImages|first %}
                         src="{{ asset(product_uploads~firstImage.imageName) | imagine_filter('medium_image') }}"
                         alt="">
                </a>
                {% endif %}
                <div class="p-5">
                    <p class="mb-1 text-sm text-gray-500 dark:text-gray-500">Product</p>
                    <h5 class="mb-2 text-2xl font-bold tracking-tight text-gray-900 dark:text-white">{{ result.name }}</h5>
                    <nav class="flex mb-4" aria-label="Breadcrumb">
                        <ol class="inline-flex items-center space-x-1 md:space-x-2">
                            <li>
                                <div class="flex items-center">
                                    <a href="{{ path('app_category_show', {id: result.category.id}) }}"
                                       data-turbo-frame="_top"
                                       class="text-sm font-medium text-gray-700 hover:text-blue-600 dark:text-gray-400 dark:hover:text-white">{{ result.category.name|u.truncate(25, '...') }}</a>
                                </div>
                            </li>
                            <li aria-current="page">
                                <div class="flex items-center">
                                    <svg class="w-3 h-3 text-gray-400 mx-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 6 10"><path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 9 4-4-4-4"/></svg>
                                    <a href="{{ path('app_subcategory_show', {id: result.subcategory.id}) }}"
                                       data-turbo-frame="_top"
                                       class="ms-1 text-sm font-medium text-gray-700 hover:text-blue-600 md:ms-2 dark:text-gray-400 dark:hover:text-white">{{ result.subcategory.name|u.truncate(25, '...') }}</a>
                                </div>
                            </li>
                        </ol>
                    </nav>
                    <p class="text-right mb-1 text-2xl text-gray-500 dark:text-white">
                        £{{ result.sellPriceIncVat|number_format(2) }} <span class="text-base">inc VAT</span></p>
                    <p class="text-right mb-2 text-sm text-gray-500 dark:text-gray-400">{{ result.stock }} in stock</p>
                    <p class="mb-1 text-sm font-medium text-gray-700 dark:text-gray-400">{{ result.manufacturer.name }} {{ result.mfrPartNumber }}</p>
                    <p class="mb-1 text-sm font-medium text-gray-700 dark:text-gray-400">Product {{ '%06d'|format(result.id) }}</p>

                    <div class="flex items-center justify-between mt-4">
                        <p class="text-sm text-gray-500 dark:text-gray-400">Managed by {{ result.owner.fullName }}</p>
                        <p class="text-sm text-gray-500 dark:text-gray-400">
                            {{ result.isActive ? '<span class="text-green-500">Active</span>' : '<span class="text-red-500">Inactive</span>' }}
                        </p>
                    </div>
                </div>
        </div>
        <div class="mt-4">
            <p class="text-sm font-light text-gray-500 dark:text-gray-400">
                <a href="{{ path('app_'~section|lower|u.snake~'_index') }}"
                   class="hover:underline"
                   data-turbo-frame="_top"
                >Back to list</a>
            </p>
        </div>
    </div>
{% endblock %}