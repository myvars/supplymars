{% extends 'product/_navigation.html.twig' %}

{% block title %}Product Details{% endblock %}

{% block detail %}

    <div class="p-3 space-y-3 text-sm text-gray-500 dark:text-gray-400">
        <h1 class="mb-3 text-xl text-gray-900 dark:text-white">Product Details</h1>
        <div class="flex flex-wrap justify-center gap-8">
            {{ include('product/_product_card.html.twig', {product: result}) }}
        </div>
        <div class="mt-3">
            <p>
                <a href="{{ path('app_product_index') }}"
                   class="font-light hover:text-gray-300 dark:hover:text-white"
                   data-turbo-frame="_top"
                   data-turbo-prefetch="false"
                >Back to list</a>
            </p>
        </div>
    </div>

{% endblock %}