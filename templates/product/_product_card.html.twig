<twig:Card editLink="{{ path('app_product_edit', {id: product.id}) }}" title="Product" width="w-[344px]">
    <twig:block name="cardImage">
        {% if product.hasProductImage %}
            <a href="{{ path('app_product_images', {id: product.category.id}) }}">
                <img class="w-auto rounded-t-lg"
                     src="{{ asset(product_uploads~product.getFirstImage.imageName) | imagine_filter('medium_image') }}"
                 alt="">
            </a>
        {% endif %}
    </twig:block>
    <h5 class="mb-1 text-xl text-gray-900 dark:text-white">{{ product.name|u.truncate(30, '...') }}</h5>
    <nav class="mb-3 flex" aria-label="Breadcrumb">
        <ol class="inline-flex items-center space-x-1 md:space-x-2">
            <li>
                <div class="flex items-center">
                    <a href="{{ path('app_category_show', {id: product.category.id}) }}"
                       data-turbo-frame="body"
                       class="text-gray-700 hover:text-blue-600 dark:text-gray-400 dark:hover:text-white">{{ product.category.name|u.truncate(25, '...') }}</a>
                </div>
            </li>
            <li aria-current="page">
                <div class="flex items-center">
                    >>
                    <a href="{{ path('app_subcategory_show', {id: product.subcategory.id}) }}"
                       data-turbo-frame="body"
                       class="ms-1 md:ms-2 text-gray-700 hover:text-blue-600 dark:text-gray-400 dark:hover:text-white">{{ product.subcategory.name|u.truncate(25, '...') }}</a>
                </div>
            </li>
        </ol>
    </nav>
    <p class="mb-1">{{ product.description }}</p>
    <p class="mb-1 text-right text-xl font-extralight text-gray-500 dark:text-white">
        {{ product.sellPriceIncVat|format_currency('GBP') }} <span class="text-base">inc VAT</span></p>
    <p class="mb-2 text-right">{{ product.stock }} in stock</p>
    <p>{{ product.manufacturer.name }} : {{ product.mfrPartNumber }}</p>
    <p>Product #{{ '%06d'|format(product.id) }}</p>
    {% if product.hasOwner %}
        <p>Managed by {{ product.owner.fullName }}</p>
    {% else %}
        <p>No product manager</p>
    {% endif %}
    <div class="mt-3 flex items-center justify-between">
        <p class="me-10 text-xs text-gray-600 dark:text-gray-500">Updated {{ product.updatedAt|ago }}</p>
        {% if product.isActive %}
            <p class="text-green-500">Active</p>
        {% else %}
            <p class="text-red-500">InActive</p>
        {% endif %}
    </div>
</twig:Card>