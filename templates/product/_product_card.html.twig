<div class="relative h-full w-[368px] bg-white border border-gray-200 rounded-lg shadow dark:bg-gray-800 dark:border-gray-700">
    <a href="{{ path('app_product_edit', {id: product.id}) }}"
       class="absolute -top-1.5 -right-1 p-1.5 bg-white text-yellow-500 border border-gray-600 rounded-full shadow-lg dark:bg-gray-700 dark:hover:bg-gray-600"
       data-turbo-prefetch="false"
       data-turbo-frame="modal"
    >
        <twig:ux:icon name="mynaui:edit-one" class="w-6 h-6 p-0.5" />
    </a>
    {% if product.hasProductImage %}
        <a href="#">
            <img class="w-auto m-3 mb-0 rounded-lg"
                 src="{{ asset(product_uploads~product.getFirstImage.imageName) | imagine_filter('medium_image') }}"
                 alt=""
            >
        </a>
    {% endif %}
    <div class="p-3 text-sm text-gray-500 dark:text-gray-400">
        <p class="text-gray-500 dark:text-gray-500">Product</p>
        <h5 class="mb-1 text-xl text-gray-900 dark:text-white">{{ product.name|u.truncate(30, '...') }}</h5>
        <nav class="mb-3 flex" aria-label="Breadcrumb">
            <ol class="inline-flex items-center space-x-1 md:space-x-2">
                <li>
                    <div class="flex items-center">
                        <a href="{{ path('app_category_show', {id: product.category.id}) }}"
                           data-turbo-frame="_top"
                           data-turbo-prefetch="false"
                           class="text-gray-700 hover:text-blue-600 dark:text-gray-400 dark:hover:text-white">{{ product.category.name|u.truncate(25, '...') }}</a>
                    </div>
                </li>
                <li aria-current="page">
                    <div class="flex items-center">
                        <svg class="w-2 h-2 text-gray-400 mx-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 6 10"><path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 9 4-4-4-4"/></svg>
                        <a href="{{ path('app_subcategory_show', {id: product.subcategory.id}) }}"
                           data-turbo-frame="_top"
                           data-turbo-prefetch="false"
                           class="ms-1 md:ms-2 text-gray-700 hover:text-blue-600 dark:text-gray-400 dark:hover:text-white">{{ product.subcategory.name|u.truncate(25, '...') }}</a>
                    </div>
                </li>
            </ol>
        </nav>
        <p class="mb-1">{{ product.description }}</p>
        <p class="mb-1 text-right text-xl font-extralight text-gray-500 dark:text-white">£{{ product.sellPriceIncVat|number_format(2) }} <span class="text-base">inc VAT</span></p>
        <p class="mb-2 text-right">{{ product.stock }} in stock</p>
        <p>{{ product.manufacturer.name }} : {{ product.mfrPartNumber }}</p>
        <p>Product #{{ '%06d'|format(product.id) }}</p>
        {% if product.hasOwner %}
            <p>Managed by {{ product.owner.fullName }}</p>
        {% else %}
            <p>No product manager</p>
        {% endif %}
        <div class="mt-3 flex items-center justify-between">
            <p class="me-10 text-xs text-gray-600 dark:text-gray-500">Updated {{ product.updatedAt|ago }}</p>
            {% if product.isActive %}
                <p class="text-green-500">Active</p>
            {% else %}
                <p class="text-red-500">InActive</p>
            {% endif %}
        </div>
    </div>
</div>