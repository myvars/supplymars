{% extends 'modalBase.html.twig' %}

{% block title %}{{ section }} index{% endblock %}

{% block body %}
    <twig:DataTable
        section="{{ section }}"
        results="{{ results }}"
        colspan="4"
    >
        <twig:block name="table_header">
            <twig:TableHeader sortValue="id">Id</twig:TableHeader>
            <twig:TableHeader>Default Data Table</twig:TableHeader>
            <twig:TableHeader><span class="sr-only">Actions</span></twig:TableHeader>
        </twig:block>

        <twig:block name="table_rows">
            <th scope="row" class="px-4 py-3">{{ result.id }}</th>
            <th scope="row" class="px-4 py-3 font-normal">Please create an 'index' page for {{ section }} ({{ section|lower|u.snake }}/index.html.twig)</th>
        </twig:block>

        <twig:block name="table_actions">
            <li>
                <a href="{{ path('app_'~section|lower|u.snake~'_show', {'id': result.id }) }}"
                   class="flex items-center block py-2 px-4 hover:bg-gray-100 dark:hover:bg-gray-600 dark:hover:text-white"
                   target="_top"
                ><twig:Icon name="show" class="w-4 me-1.5"></twig:Icon>Show</a>
            </li>
            <li>
                <a href="{{ path('app_'~section|lower|u.snake~'_edit', {'id': result.id }) }}"
                   class="flex items-center block py-2 px-4 text-yellow-700 dark:text-yellow-500 hover:bg-gray-100 dark:hover:bg-gray-600"
                   data-turbo-frame="modal"
                ><twig:Icon name="edit" class="w-4 me-1.5"></twig:Icon>Edit</a>
            </li>
            <li>
                <a href="{{ path('app_'~section|lower|u.snake~'_delete_confirm', {'id': result.id }) }}"
                   class="flex items-center block py-2 px-4 text-red-700 hover:bg-gray-100 dark:hover:bg-red-600 dark:text-red-500 dark:hover:text-white"
                   data-turbo-frame="modal"
                ><twig:Icon name="delete" class="w-4 me-1.5"></twig:Icon>Delete</a>
            </li>
        </twig:block>

        <twig:block name="table_add">
            <twig:Button
                tag="a"
                href="{{ path('app_'~section|lower|u.snake~'_new') }}"
                class="flex items-center space-x-1 font-bold"
                data-turbo-frame="modal"
            >
                <twig:Icon name="add" class="w-4"></twig:Icon><span>Add {{ section }}</span>
            </twig:Button>
        </twig:block>

        <twig:block name="filter"></twig:block>

    </twig:DataTable>
{% endblock %}