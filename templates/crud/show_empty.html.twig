{% extends 'modalBase.html.twig' %}

{% block title %}{{ section }}{% endblock %}

{% block body %}
    <section class="bg-white dark:bg-gray-900">
        <div class="py-8 px-4 mx-auto max-w-screen-xl lg:py-16 lg:px-6">
            <div class="mx-auto max-w-screen-sm text-center">
                <p class="mb-6 text-3xl tracking-tight font-bold text-gray-900 md:text-4xl dark:text-white">{{ section }} is missing !</p>
                <p class="mb-6 text-lg font-light text-gray-500 dark:text-gray-400">Sorry, we can't find that {{ section }}. </p>
                <twig:Button
                    tag="a"
                    href="{{ path('app_'~section|lower|u.snake~'_index') }}"
                    class="flex items-center space-x-1 font-bold"
                >
                    Go Back
                </twig:Button>
            </div>
        </div>
    </section>
{% endblock %}




