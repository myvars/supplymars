{
    "type": "project",
    "license": "proprietary",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "php": ">=8.3",
        "ext-bcmath": "*",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "babdev/pagerfanta-bundle": "^4.5",
        "beberlei/doctrineextensions": "^1.5",
        "doctrine/doctrine-bundle": "^2.14",
        "doctrine/doctrine-migrations-bundle": "^3.4.2",
        "doctrine/orm": "^3.3.3",
        "knplabs/knp-time-bundle": "^2.4",
        "league/flysystem-aws-s3-v3": "^3.29",
        "liip/imagine-bundle": ">=2.13.3",
        "oneup/flysystem-bundle": ">=4.12.4",
        "pagerfanta/doctrine-orm-adapter": "^4.7.1",
        "pagerfanta/twig": "^4.7.1",
        "phpdocumentor/reflection-docblock": "^5.6.2",
        "phpstan/phpdoc-parser": "^2.1",
        "stof/doctrine-extensions-bundle": "^1.14",
        "symfony/amazon-mailer": "7.2.*",
        "symfony/asset": "7.2.*",
        "symfony/asset-mapper": "7.2.*",
        "symfony/console": "7.2.*",
        "symfony/doctrine-messenger": "7.2.*",
        "symfony/dotenv": "7.2.*",
        "symfony/expression-language": "7.2.*",
        "symfony/flex": "^2.6.0",
        "symfony/form": "7.2.*",
        "symfony/framework-bundle": "7.2.*",
        "symfony/http-client": "7.2.*",
        "symfony/intl": "7.2.*",
        "symfony/mailer": "7.2.*",
        "symfony/mime": "7.2.*",
        "symfony/monolog-bundle": "^3.10",
        "symfony/notifier": "7.2.*",
        "symfony/process": "7.2.*",
        "symfony/property-access": "7.2.*",
        "symfony/property-info": "7.2.*",
        "symfony/rate-limiter": "7.2.*",
        "symfony/runtime": "7.2.*",
        "symfony/security-bundle": "7.2.*",
        "symfony/serializer": "7.2.*",
        "symfony/stimulus-bundle": "^2.25.2",
        "symfony/string": "7.2.*",
        "symfony/translation": "7.2.*",
        "symfony/twig-bundle": "7.2.*",
        "symfony/ux-chartjs": "^2.25.2",
        "symfony/ux-icons": "^2.25",
        "symfony/ux-turbo": "^2.25.2",
        "symfony/ux-twig-component": "^2.25.2",
        "symfony/validator": "7.2.*",
        "symfony/web-link": "7.2.*",
        "symfony/yaml": "7.2.*",
        "symfonycasts/dynamic-forms": "^0.1.3",
        "symfonycasts/reset-password-bundle": "^1.23.1",
        "symfonycasts/tailwind-bundle": "^0.10.0",
        "symfonycasts/verify-email-bundle": "^1.17.3",
        "tales-from-a-dev/flowbite-bundle": "^0.8.0",
        "twig/cssinliner-extra": "^3.21",
        "twig/extra-bundle": "^2.12|^3.21",
        "twig/inky-extra": "^3.21",
        "twig/intl-extra": "^3.21",
        "twig/string-extra": "^3.21",
        "twig/twig": "^2.12|^3.21.1"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true,
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "bump-after-update": true,
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*",
        "symfony/polyfill-php73": "*",
        "symfony/polyfill-php74": "*",
        "symfony/polyfill-php80": "*",
        "symfony/polyfill-php81": "*",
        "symfony/polyfill-php82": "*"
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd",
            "importmap:install": "symfony-cmd"
        },
        "post-install-cmd": [
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ]
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "7.2.*"
        }
    },
    "require-dev": {
        "dama/doctrine-test-bundle": "^8.2.2",
        "dg/bypass-finals": "^1.9",
        "doctrine/doctrine-fixtures-bundle": "^4.1",
        "phpunit/phpunit": "^9.6.23",
        "rector/rector": "^2.0.16",
        "symfony/browser-kit": "7.2.*",
        "symfony/css-selector": "7.2.*",
        "symfony/debug-bundle": "7.2.*",
        "symfony/maker-bundle": "^1.63.0",
        "symfony/phpunit-bridge": "^7.2.6",
        "symfony/stopwatch": "7.2.*",
        "symfony/web-profiler-bundle": "7.2.*",
        "zenstruck/browser": "^1.9.1",
        "zenstruck/foundry": "^2.5"
    }
}
